<?xml version="1.0" encoding="UTF-8"?>
<?ifndef UpgradeCode ?>
<?define UpgradeCode = "11111111-1111-1111-1111-111111111111" ?>
<?endif?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <?include "Fragments/Directories.wxs" ?>
  <?include "Fragments/Components.wxs" ?>
  <?include "Fragments/Features.wxs" ?>
  <?include "Fragments/Prerequisites.wxs" ?>

  <Package
    Name="kano-git-master-skill"
    Manufacturer="Kano"
    Version="$(var.ProductVersion)"
    UpgradeCode="$(var.UpgradeCode)"
    Scope="perUser"
    Language="1033"
    InstallerVersion="500"
    Compressed="yes">
    <SummaryInformation
      Description="Per-user MSI scaffold for kano-git-master-skill under %USERPROFILE%\.agents\skills\kano_installed."
      Manufacturer="Kano" />

    <util:QueryWindowsDirectories />

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of kano-git-master-skill is already installed."
      Schedule="afterInstallInitialize" />

    <Launch Condition="Installed OR KANO_GFW_INSTALLPATH_HKCU OR KANO_GFW_INSTALLPATH_HKLM OR KANO_GFW_INSTALLPATH_HKLM32 OR KANO_GFW_INSTALLLOCATION_UNINSTALL_HKCU OR KANO_GFW_INSTALLLOCATION_UNINSTALL_HKLM OR KANO_GFW_INSTALLLOCATION_UNINSTALL_HKLM32 OR KANO_GIT_EXE_DEFAULT_PROGRAMFILES64 OR KANO_GIT_EXE_DEFAULT_PROGRAMFILES OR KANO_GIT_EXE_DEFAULT_LOCALAPPDATA" Message="kano-git-master-skill requires Git for Windows. Install or repair Git for Windows so the installer can resolve a valid Git installation root or canonical git.exe location. This MSI does not bundle Git for Windows." />

    <Launch Condition="Installed OR KANO_GIT_EXE_CMD_HKCU OR KANO_GIT_EXE_CMD_HKLM OR KANO_GIT_EXE_CMD_HKLM32 OR KANO_GIT_EXE_MINGW64_HKCU OR KANO_GIT_EXE_MINGW64_HKLM OR KANO_GIT_EXE_MINGW64_HKLM32 OR KANO_GIT_EXE_MINGW32_HKCU OR KANO_GIT_EXE_MINGW32_HKLM OR KANO_GIT_EXE_MINGW32_HKLM32 OR KANO_GIT_EXE_DEFAULT_PROGRAMFILES64 OR KANO_GIT_EXE_DEFAULT_PROGRAMFILES OR KANO_GIT_EXE_DEFAULT_LOCALAPPDATA" Message="kano-git-master-skill requires Git for Windows to provide git.exe. Install, repair, or update Git for Windows so a canonical git.exe exists. This MSI does not bundle Git for Windows." />

    <Launch Condition="Installed OR KANO_BASH_EXE_BIN_HKCU OR KANO_BASH_EXE_BIN_HKLM OR KANO_BASH_EXE_BIN_HKLM32 OR KANO_BASH_EXE_USRBIN_HKCU OR KANO_BASH_EXE_USRBIN_HKLM OR KANO_BASH_EXE_USRBIN_HKLM32 OR KANO_BASH_EXE_DEFAULT_PROGRAMFILES64 OR KANO_BASH_EXE_DEFAULT_PROGRAMFILES OR KANO_BASH_EXE_DEFAULT_LOCALAPPDATA" Message="kano-git-master-skill requires Git for Windows to provide bash.exe. Install, repair, or update Git for Windows so a canonical bash.exe exists. This MSI does not bundle Git for Windows." />

    <Launch Condition="Installed OR KANO_GIT_EXE_MIN244_CMD_HKCU OR KANO_GIT_EXE_MIN244_CMD_HKLM OR KANO_GIT_EXE_MIN244_CMD_HKLM32 OR KANO_GIT_EXE_MIN244_MINGW64_HKCU OR KANO_GIT_EXE_MIN244_MINGW64_HKLM OR KANO_GIT_EXE_MIN244_MINGW64_HKLM32 OR KANO_GIT_EXE_MIN244_MINGW32_HKCU OR KANO_GIT_EXE_MIN244_MINGW32_HKLM OR KANO_GIT_EXE_MIN244_MINGW32_HKLM32 OR KANO_GIT_EXE_MIN244_DEFAULT_PROGRAMFILES64 OR KANO_GIT_EXE_MIN244_DEFAULT_PROGRAMFILES OR KANO_GIT_EXE_MIN244_DEFAULT_LOCALAPPDATA OR KANO_GFW_VERSION_UNINSTALL_HKCU OR KANO_GFW_VERSION_UNINSTALL_HKLM OR KANO_GFW_VERSION_UNINSTALL_HKLM32" Message="kano-git-master-skill requires Git for Windows 2.44 or newer. Update Git for Windows so the detected installation provides git.exe version 2.44+. Detected registered version: [KANO_GFW_CURRENTVERSION_HKCU][KANO_GFW_CURRENTVERSION_HKLM][KANO_GFW_CURRENTVERSION_HKLM32][KANO_GFW_VERSION_UNINSTALL_HKCU][KANO_GFW_VERSION_UNINSTALL_HKLM][KANO_GFW_VERSION_UNINSTALL_HKLM32]." />

    <Launch Condition="Installed OR (NOT KANO_INSTALLROOT_GITDIR_HEAD AND NOT KANO_INSTALLROOT_GITFILE)" Message="kano-git-master-skill detected an existing git/manual checkout at %USERPROFILE%\.agents\skills\kano_installed. That existing content remains authoritative, and this MSI will not overwrite or merge into it. Remove or relocate the existing checkout if you want the MSI-managed copy instead." />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <FeatureRef Id="CoreFiles" />
    <FeatureRef Id="ShellIntegration" />
  </Package>
</Wix>
