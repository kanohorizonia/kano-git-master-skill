            "binaryDir": "${sourceDir}/out/obj/windows-ninja-clang-coverage",
            "cacheVariables": {
                "BUILD_SHARED_LIBS": "OFF",
                "KOG_ENABLE_MODULES": "OFF",
                "KOG_ENABLE_COVERAGE": "ON",
                "KOG_BUILD_TYPE": "Debug",
                "KOG_PRESET_NAME": "windows-ninja-clang-coverage"
