        },
        {
            "name": "windows-ninja-msvc-arm64-release",
            "configurePreset": "windows-ninja-msvc-arm64",
            "configuration": "Release"
        },
        {
            "name": "windows-ninja-clang-debug",
            "configurePreset": "windows-ninja-clang",
            "configuration": "Debug"
        },
        {
            "name": "windows-ninja-clang-release",
            "configurePreset": "windows-ninja-clang",
            "configuration": "Release"
        },
        {
            "name": "linux-ninja-gcc-debug",
            "configurePreset": "linux-ninja-gcc",
            "configuration": "Debug"
        },
        {
            "name": "linux-ninja-gcc-release",
            "configurePreset": "linux-ninja-gcc",
            "configuration": "Release"
        },
        {
            "name": "linux-ninja-clang-debug",
            "configurePreset": "linux-ninja-clang",
            "configuration": "Debug"
        },
        {
            "name": "linux-ninja-clang-release",
            "configurePreset": "linux-ninja-clang",
            "configuration": "Release"
        },
        {
            "name": "macos-ninja-clang-debug",
            "configurePreset": "macos-ninja-clang",
            "configuration": "Debug"
        },
        {
            "name": "macos-ninja-clang-release",
            "configurePreset": "macos-ninja-clang",
