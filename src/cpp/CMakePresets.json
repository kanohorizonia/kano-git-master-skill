{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "kog-fetch-thirdparty-defaults",
            "hidden": true,
            "cacheVariables": {
                "KOG_CLI11_SOURCE_MODE": "fetch",
                "KOG_FTXUI_SOURCE_MODE": "fetch"
            }
        },
        {
            "name": "windows-msbuild",
            "displayName": "Windows MSBuild",
            "description": "Uses Visual Studio 17 2022 generator",
            "inherits": "kog-fetch-thirdparty-defaults",
            "generator": "Visual Studio 17 2022",
            "cacheVariables": {
                "CMAKE_CXX_FLAGS": "/experimental:external-",
                "KOG_PRESET_NAME": "windows-msbuild"
            },
            "architecture": {
                "value": "x64",
                "strategy": "set"
            },
            "toolset": {
                "value": "v143",
                "strategy": "set"
            },
            "binaryDir": "${sourceDir}/out/obj/windows-msbuild"
        },
        {
            "name": "windows-ninja-msvc",
            "displayName": "Windows Ninja Multi-Config (MSVC)",
            "description": "Uses Ninja Multi-Config with default MSVC compiler (requires vcvars64.bat)",
            "inherits": "kog-fetch-thirdparty-defaults",
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/out/obj/win-ninja-msvc",
            "cacheVariables": {
                "KOG_PRESET_NAME": "windows-ninja-msvc"
            }
        },
        {
            "name": "windows-ninja-msvc-arm64",
            "displayName": "Windows Ninja Multi-Config (MSVC ARM64)",
            "description": "Uses Ninja Multi-Config with MSVC cross-compile toolchain (amd64_arm64)",
            "inherits": "kog-fetch-thirdparty-defaults",
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/out/obj/windows-ninja-msvc-arm64",
            "cacheVariables": {
                "KOG_PRESET_NAME": "windows-ninja-msvc-arm64"
            }
        },
        {
            "name": "windows-fastbuild-msvc",
            "displayName": "Windows FASTBuild (MSVC)",
            "description": "Uses FASTBuild generator with MSVC compiler (requires vcvars64.bat and CMake 4.2+)",
            "inherits": "kog-fetch-thirdparty-defaults",
            "generator": "FASTBuild",
            "binaryDir": "${sourceDir}/out/obj/windows-fastbuild-msvc",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_SCAN_FOR_MODULES": "OFF",
                "KOG_ENABLE_MODULES": "OFF",
                "KOG_COMPILER_LAUNCHER": "none",
                "KOG_PRESET_NAME": "windows-fastbuild-msvc"
            }
        },
        {
            "name": "windows-ninja-clang",
            "displayName": "Windows Ninja Multi-Config (Clang)",
            "description": "Uses Ninja Multi-Config with LLVM Clang compiler",
