#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
PATH="$SCRIPT_DIR:$PATH"
LAUNCHER_STATE_DIR="$PROJECT_ROOT/.kano/launcher"
REBUILD_DIRECTION="unknown"
REBUILD_REASON=""
if [[ "$(uname -s 2>/dev/null || true)" == "Darwin" ]]; then
  KOG_BUILD_USE_LLVM="${KOG_BUILD_USE_LLVM:-1}"
  KOG_BUILD_ENABLE_MODULES="${KOG_BUILD_ENABLE_MODULES:-1}"
else
  KOG_BUILD_USE_LLVM="${KOG_BUILD_USE_LLVM:-0}"
  KOG_BUILD_ENABLE_MODULES="${KOG_BUILD_ENABLE_MODULES:-0}"
fi
KOG_ALLOW_IGNORE_GATE="${KOG_ALLOW_IGNORE_GATE:-0}"

is_interactive_terminal() {
  [[ -t 0 && -t 1 ]]
}

ensure_launcher_state_dir() {
  mkdir -p "$LAUNCHER_STATE_DIR"
}

state_file_for() {
  local name="$1"
  printf '%s/%s\n' "$LAUNCHER_STATE_DIR" "$name"
}

file_mtime_epoch() {
  local file="$1"
  if [[ ! -e "$file" ]]; then
    printf '%s\n' "0"
    return 0
  fi

  if stat -c %Y "$file" >/dev/null 2>&1; then
    stat -c %Y "$file"
    return 0
  fi

  if stat -f %m "$file" >/dev/null 2>&1; then
    stat -f %m "$file"
    return 0
  fi

  printf '%s\n' "0"
}

current_epoch() {
  date +%s 2>/dev/null || printf '%s\n' "0"
}

should_run_interval_check() {
  local stamp_file="$1"
  local interval_seconds="$2"
  local now last delta

  if [[ "$interval_seconds" -le 0 ]]; then
    return 0
  fi

  now="$(current_epoch)"
  last="$(file_mtime_epoch "$stamp_file")"
  if [[ "$last" -le 0 ]]; then
    return 0
  fi

  delta=$((now - last))
  [[ "$delta" -ge "$interval_seconds" ]]
}

touch_stamp_file() {
  local stamp_file="$1"
  ensure_launcher_state_dir
  : > "$stamp_file"
}

log_launcher_status() {
  local step="$1"
  local status="$2"
  local message="${3:-}"

  if [[ -n "$message" ]]; then
    echo "[launcher][$step][$status] $message" >&2
  else
    echo "[launcher][$step][$status]" >&2
  fi
}

run_with_progress() {
  local label="$1"
  shift

  local interval pid start now elapsed
  interval="${KANO_GIT_PROGRESS_INTERVAL_SECONDS:-30}"
  if [[ ! "$interval" =~ ^[0-9]+$ || "$interval" -le 0 ]]; then
    interval=30
  fi

  if [[ "${KANO_GIT_PROGRESS_HEARTBEAT:-1}" == "1" && -t 1 ]]; then
    "$@" &
    pid=$!
    start="$(current_epoch)"
    while kill -0 "$pid" 2>/dev/null; do
      sleep "$interval"
      if ! kill -0 "$pid" 2>/dev/null; then
        break
      fi
      now="$(current_epoch)"
      elapsed=$((now - start))
      log_launcher_status "$label" "running" "elapsed=${elapsed}s"
    done
    wait "$pid"
    return $?
  fi

  "$@"
}

maybe_prompt_yes_no() {
  local prompt="$1"
  local answer

  if ! is_interactive_terminal; then
    return 1
  fi

  read -r -p "$prompt [y/N]: " answer
  case "${answer,,}" in
    y|yes) return 0 ;;
  esac
  return 1
}

plan_template_path() {
  printf '%s\n' "$PROJECT_ROOT/assets/plan/default-plan.json"
}

ignore_gate_allowlist_path() {
  printf '%s\n' "$PROJECT_ROOT/assets/gitignore/ignore-gate-allowlist.txt"
}

default_plan_output_path() {
  local workspace_root="${KANO_GIT_MASTER_ROOT:-$PWD}"
  printf '%s\n' "$workspace_root/.kano/cache/git/plans/default-plan.json"
}

current_utc_iso8601() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

plan_has_executed_timestamp() {
  local plan_file="$1"
  local executed_at=""

  [[ -f "$plan_file" ]] || return 1

  if has_command jq; then
    executed_at="$(jq -r '.meta.executed_at_utc // ""' "$plan_file" 2>/dev/null || true)"
  else
    executed_at="$(sed -n 's/.*"executed_at_utc"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$plan_file" 2>/dev/null | head -n 1)"
  fi

  executed_at="$(printf '%s' "$executed_at" | tr -d '\r\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
  [[ -n "$executed_at" ]]
}

has_command() {
  command -v "$1" >/dev/null 2>&1
}

ensure_windows_ai_runtime_paths() {
  # npm-based wrappers (codex/copilot) require node runtime in PATH.
  # Add common Windows node path when running in Git Bash/WSL style environments.
  if ! has_command node && [[ -x "/mnt/c/Program Files/nodejs/node.exe" ]]; then
    PATH="/mnt/c/Program Files/nodejs:$PATH"
  fi

  # In Linux shells (WSL/Git-Bash style), wrappers may call `node` (without .exe).
  # Create a lightweight shim so npm CLI wrappers can execute consistently.
  if ! has_command node && [[ -x "/mnt/c/Program Files/nodejs/node.exe" ]]; then
    local shim_dir="$PROJECT_ROOT/.kano/cache/runtime-shims"
    mkdir -p "$shim_dir"
    cat > "$shim_dir/node" <<'EOF'
#!/usr/bin/env bash
if [[ "$#" -gt 0 && "$1" == /* ]] && command -v wslpath >/dev/null 2>&1; then
  first_arg="$(wslpath -w "$1" 2>/dev/null || printf '%s' "$1")"
  shift
  exec "/mnt/c/Program Files/nodejs/node.exe" "$first_arg" "$@"
fi
exec "/mnt/c/Program Files/nodejs/node.exe" "$@"
EOF
    chmod +x "$shim_dir/node" >/dev/null 2>&1 || true
    PATH="$shim_dir:$PATH"
  fi
}

is_working_command() {
  local cmd="$1"
  shift || true
  has_command "$cmd" || return 1
  "$cmd" "$@" >/dev/null 2>&1
}

resolve_plan_ai_provider() {
  local requested="${1:-auto}"
  local provider="${requested,,}"
  provider="${provider// /}"

  if [[ -n "$provider" && "$provider" != "auto" ]]; then
    case "$provider" in
      codex|opencode|copilot)
        ;;
      *)
        return 1
        ;;
    esac
    printf '%s\n' "$provider"
    return 0
  fi

  if is_working_command copilot --help || (has_command gh && gh copilot --version >/dev/null 2>&1); then
    printf '%s\n' "copilot"
    return 0
  fi
  if is_working_command codex --help; then
    printf '%s\n' "codex"
    return 0
  fi
  if is_working_command opencode --help; then
    printf '%s\n' "opencode"
    return 0
  fi

  return 1
}

resolve_plan_ai_model() {
  local provider="${1:-}"
  local requested="${2:-auto}"
  local model="$requested"
  if [[ -z "$model" || "$model" == "auto" ]]; then
    case "$provider" in
      codex|opencode|copilot)
        model="gpt-5-mini"
        ;;
      *)
        model=""
        ;;
    esac
  fi
  printf '%s\n' "$model"
}

collect_dirty_repo_context_text() {
  local workspace_root="$1"
  local -a repos=()
  local repo rel status_out line_count
  local output=""

  mapfile -t repos < <(discover_workspace_git_repos "$workspace_root")
  if [[ "${#repos[@]}" -eq 0 ]]; then
    repos=("$workspace_root")
  fi

  for repo in "${repos[@]}"; do
    [[ -n "$repo" ]] || continue
    if ! status_out="$(run_git_quick "$repo" status --porcelain --untracked-files=all 2>/dev/null)"; then
      continue
    fi
    if [[ -z "$status_out" ]]; then
      continue
    fi

    rel="$(repo_rel_path "$workspace_root" "$repo")"
    line_count="$(printf '%s\n' "$status_out" | awk 'NF {c+=1} END {print c+0}')"
    output+="repo: $rel"$'\n'
    output+="changes: $line_count"$'\n'
    output+="status:"$'\n'
    output+="$(printf '%s\n' "$status_out" | head -n 80)"$'\n'
    output+=$'\n'
  done

  printf '%s' "$output"
}

extract_json_between_markers() {
  local text="$1"
  local begin_marker="$2"
  local end_marker="$3"

  printf '%s\n' "$text" | sed -n "/$begin_marker/,/$end_marker/p" | sed '1d;$d'
}

normalize_ai_json_text() {
  local text="$1"
  local normalized="$text"
  normalized="${normalized//$'\r'/}"
  normalized="$(printf '%s\n' "$normalized" | sed -E 's/^[[:space:]]*[-*•][[:space:]]*//')"
  normalized="$(printf '%s\n' "$normalized" | sed -E 's#</?p>##g; s#</?div>##g; s#</?span>##g')"
  normalized="${normalized//&quot;/\"}"
  normalized="${normalized//&#34;/\"}"
  normalized="${normalized//&apos;/\'}"
  normalized="${normalized//&#39;/\'}"
  normalized="${normalized//&amp;/&}"
  normalized="${normalized//&lt;/<}"
  normalized="${normalized//&gt;/>}"
  printf '%s\n' "$normalized"
}

run_plan_ai_generate_once() {
  local provider="$1"
  local model="$2"
  local prompt="$3"

  case "$provider" in
    codex)
      if [[ -n "$model" ]]; then
        codex -q --model "$model" "$prompt" 2>&1
      else
        codex -q "$prompt" 2>&1
      fi
      ;;
    opencode)
      if [[ -n "$model" ]]; then
        opencode run --model "$model" "$prompt" 2>&1
      else
        opencode run "$prompt" 2>&1
      fi
      ;;
    copilot)
      if has_command copilot; then
        if [[ -n "$model" ]]; then
          copilot -s -p "$prompt" --model "$model" --no-color --stream off --no-ask-user 2>&1
        else
          copilot -s -p "$prompt" --no-color --stream off --no-ask-user 2>&1
        fi
      elif has_command gh && gh copilot --version >/dev/null 2>&1; then
        if [[ -n "$model" ]]; then
          gh copilot -- -s -p "$prompt" --model "$model" --no-color --stream off --no-ask-user 2>&1
        else
          gh copilot -- -s -p "$prompt" --no-color --stream off --no-ask-user 2>&1
        fi
      else
        echo "copilot command unavailable" >&2
        return 1
      fi
      ;;
    *)
      echo "unsupported provider: $provider" >&2
      return 1
      ;;
  esac
}

ensure_plan_provider_usable() {
  local provider="$1"
  local debug_ai="${KOG_DEBUG_AI:-0}"
  case "$provider" in
    codex)
      if is_working_command codex --help; then
        return 0
      fi
      if [[ "$debug_ai" == "1" ]]; then
        echo "[debug-ai] codex path: $(command -v codex 2>/dev/null || echo '<missing>')" >&2
        codex --help 2>&1 | sed -n '1,6p' >&2 || true
      fi
      return 1
      ;;
    opencode)
      if is_working_command opencode --help; then
        return 0
      fi
      if [[ "$debug_ai" == "1" ]]; then
        echo "[debug-ai] opencode path: $(command -v opencode 2>/dev/null || echo '<missing>')" >&2
        opencode --help 2>&1 | sed -n '1,6p' >&2 || true
      fi
      return 1
      ;;
    copilot)
      if is_working_command copilot --help || (has_command gh && gh copilot --version >/dev/null 2>&1); then
        return 0
      fi
      if [[ "$debug_ai" == "1" ]]; then
        echo "[debug-ai] node path: $(command -v node 2>/dev/null || echo '<missing>')" >&2
        echo "[debug-ai] copilot path: $(command -v copilot 2>/dev/null || echo '<missing>')" >&2
        copilot --help 2>&1 | sed -n '1,8p' >&2 || true
        if has_command gh; then
          gh copilot --version 2>&1 | sed -n '1,8p' >&2 || true
        fi
      fi
      return 1
      ;;
    *)
      return 1
      ;;
  esac
}

summarize_text_head() {
  local text="$1"
  local max_lines="${2:-4}"
  printf '%s\n' "$text" | sed -n "1,${max_lines}p" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g;s/^ //;s/ $//'
}

plan_prompt_template_path() {
  local custom="${KOG_PLAN_PROMPT_TEMPLATE:-}"
  if [[ -n "$custom" ]]; then
    printf '%s\n' "$custom"
    return 0
  fi
  printf '%s\n' "$PROJECT_ROOT/assets/prompts/base/plan-init.md"
}

plan_debug_dir() {
  local workspace_root="$1"
  printf '%s\n' "$workspace_root/.kano/cache/git/plans/debug"
}

build_plan_prompt() {
  local provider="$1"
  local model="$2"
  local template_json="$3"
  local dirty_context="$4"
  local prompt_file prompt

  prompt_file="$(plan_prompt_template_path)"
  if [[ -f "$prompt_file" ]]; then
    prompt="$(cat "$prompt_file")"
    prompt="${prompt//'{{PROVIDER}}'/$provider}"
    prompt="${prompt//'{{MODEL}}'/$model}"
    prompt="${prompt//'{{TEMPLATE_JSON}}'/$template_json}"
    prompt="${prompt//'{{DIRTY_CONTEXT}}'/$dirty_context}"
    printf '%s\n' "$prompt"
    return 0
  fi

  cat <<EOF
You are generating a complete plan JSON for kano-git.
Return STRICT JSON ONLY between markers:
BEGIN_KOG_PLAN_JSON
<json>
END_KOG_PLAN_JSON

Rules:
- Output a full JSON object with keys: meta, stages.
- Keep existing meta fields that are already concrete values (plan_id/generated_at_utc/base_head_sha/dirty_fingerprint).
- meta.planner.provider must be "${provider}".
- meta.planner.ai-model must be "${model}".
- meta.review.verdict must be "pass".
- meta.review.reason must be a concise overall review summary.
- stages.commit must contain dirty repos only.
- For each repo entry, provide commits array.
- Every commit item must include:
  - message (Conventional Commit one-line)
  - review.verdict = "pass"
  - review.reason = concise reason
- stages.post_sync must be [].
- Do NOT include placeholder values.

Current template JSON (fill it, do not remove required keys):
$template_json

Workspace dirty context:
$dirty_context
EOF
}

plan_init_ai_fill() {
  local out_path="$1"
  local workspace_root="$2"
  local requested_provider="${3:-auto}"
  local requested_model="${4:-auto}"
  local debug_ai="${5:-0}"
  local provider model dirty_context prompt ai_raw ai_json
  local template_json
  local tmp_json tmp_out tmp_err
  local debug_dir debug_prefix debug_enabled

  debug_enabled=0
  if [[ "$debug_ai" == "1" || "$debug_ai" == "true" || "${KOG_DEBUG_AI:-0}" == "1" ]]; then
    debug_enabled=1
  fi
  if [[ "$debug_enabled" -eq 1 ]]; then
    export KOG_DEBUG_AI=1
    debug_dir="$(plan_debug_dir "$workspace_root")"
    mkdir -p "$debug_dir"
    debug_prefix="$debug_dir/pia-$(date -u +%Y%m%dT%H%M%SZ)-$$"
  fi

  ensure_windows_ai_runtime_paths

  provider="$(resolve_plan_ai_provider "$requested_provider" || true)"
  if [[ -z "$provider" ]]; then
    echo "Error: no AI provider found for plan init -ai (supported: codex/opencode/copilot)." >&2
    return 2
  fi
  if ! ensure_plan_provider_usable "$provider"; then
    echo "Error: selected AI provider is not executable in current shell: $provider" >&2
    echo "Hint: ensure runtime dependencies (e.g. node for npm-based CLIs) are available in PATH." >&2
    return 2
  fi
  model="$(resolve_plan_ai_model "$provider" "$requested_model")"
  dirty_context="$(collect_dirty_repo_context_text "$workspace_root")"
  if [[ -z "$dirty_context" ]]; then
    echo "Error: no dirty repository changes found; nothing to generate for plan." >&2
    return 2
  fi

  template_json="$(cat "$out_path")"
  prompt="$(build_plan_prompt "$provider" "$model" "$template_json" "$dirty_context")"
  if [[ "$debug_enabled" -eq 1 ]]; then
    printf '%s\n' "$prompt" > "${debug_prefix}.prompt.txt"
  fi

  if ! ai_raw="$(run_plan_ai_generate_once "$provider" "$model" "$prompt")"; then
    echo "Error: AI provider command failed for plan generation." >&2
    echo "Provider: $provider  Model: ${model:-auto}" >&2
    if [[ "$debug_enabled" -eq 1 ]]; then
      printf '%s\n' "$ai_raw" > "${debug_prefix}.raw.txt"
      echo "Debug: ${debug_prefix}.raw.txt" >&2
      echo "Debug: ${debug_prefix}.prompt.txt" >&2
    fi
    local ai_fail_summary
    ai_fail_summary="$(summarize_text_head "$ai_raw" 6)"
    [[ -n "$ai_fail_summary" ]] && echo "Detail: $ai_fail_summary" >&2
    return 2
  fi
  if [[ "$debug_enabled" -eq 1 ]]; then
    printf '%s\n' "$ai_raw" > "${debug_prefix}.raw.txt"
  fi
  local ai_normalized
  ai_normalized="$(normalize_ai_json_text "$ai_raw")"
  ai_json="$(extract_json_between_markers "$ai_normalized" "BEGIN_KOG_PLAN_JSON" "END_KOG_PLAN_JSON")"
  if [[ -z "$ai_json" ]]; then
    ai_json="$(printf '%s\n' "$ai_normalized" | sed -n '/^{/,/^}/p')"
  fi
  if [[ -z "$ai_json" ]]; then
    echo "Error: AI did not return JSON payload for plan." >&2
    if [[ "$debug_enabled" -eq 1 ]]; then
      echo "Debug: ${debug_prefix}.raw.txt" >&2
      echo "Debug: ${debug_prefix}.prompt.txt" >&2
    fi
    local ai_out_summary
    ai_out_summary="$(summarize_text_head "$ai_raw" 6)"
    [[ -n "$ai_out_summary" ]] && echo "Detail: $ai_out_summary" >&2
    return 2
  fi

  tmp_json="$(mktemp)"
  tmp_out="$(mktemp)"
  tmp_err="$(mktemp)"
  printf '%s\n' "$ai_json" > "$tmp_json"
  if [[ "$debug_enabled" -eq 1 ]]; then
    printf '%s\n' "$ai_normalized" > "${debug_prefix}.normalized.txt"
    cp "$tmp_json" "${debug_prefix}.extracted.json"
  fi

  if has_command jq; then
    if ! jq -e '
        (.meta|type=="object") and
        (.stages|type=="object") and
        (.stages.commit|type=="array") and
        (.stages.post_sync|type=="array")
      ' "$tmp_json" >/dev/null 2>"$tmp_err"; then
      echo "Error: AI JSON payload schema invalid for plan generation." >&2
      if [[ "$debug_enabled" -eq 1 ]]; then
        cp "$tmp_err" "${debug_prefix}.schema.err.txt"
        echo "Debug: ${debug_prefix}.extracted.json" >&2
        echo "Debug: ${debug_prefix}.normalized.txt" >&2
        echo "Debug: ${debug_prefix}.schema.err.txt" >&2
        echo "Debug: ${debug_prefix}.raw.txt" >&2
        echo "Debug: ${debug_prefix}.prompt.txt" >&2
      fi
      rm -f "$tmp_json" "$tmp_out" "$tmp_err"
      return 2
    fi

    if ! jq -e '
        [.stages.commit[]?.commits[]?] as $c |
        ( ($c|length) > 0 ) and
        all($c[]; (.message|type=="string" and length>0)
                    and (.review.verdict=="pass")
                    and (.review.reason|type=="string" and length>0))
      ' "$tmp_json" >/dev/null 2>"$tmp_err"; then
      echo "Error: AI JSON payload missing required per-commit review fields." >&2
      if [[ "$debug_enabled" -eq 1 ]]; then
        cp "$tmp_err" "${debug_prefix}.review.err.txt"
        echo "Debug: ${debug_prefix}.extracted.json" >&2
        echo "Debug: ${debug_prefix}.normalized.txt" >&2
        echo "Debug: ${debug_prefix}.review.err.txt" >&2
        echo "Debug: ${debug_prefix}.raw.txt" >&2
        echo "Debug: ${debug_prefix}.prompt.txt" >&2
      fi
      rm -f "$tmp_json" "$tmp_out" "$tmp_err"
      return 2
    fi

    jq '.' "$tmp_json" > "$tmp_out"
    mv "$tmp_out" "$out_path"
    rm -f "$tmp_json" "$tmp_err"
  else
    if ! grep -q '"meta"' "$tmp_json" || ! grep -q '"stages"' "$tmp_json" || ! grep -q '"commit"' "$tmp_json"; then
      echo "Error: AI JSON payload missing required plan sections (meta/stages/commit)." >&2
      if [[ "$debug_enabled" -eq 1 ]]; then
        echo "Debug: ${debug_prefix}.extracted.json" >&2
        echo "Debug: ${debug_prefix}.normalized.txt" >&2
        echo "Debug: ${debug_prefix}.raw.txt" >&2
        echo "Debug: ${debug_prefix}.prompt.txt" >&2
      fi
      rm -f "$tmp_json" "$tmp_out" "$tmp_err"
      return 2
    fi
    if grep -q 'replace-with-' "$tmp_json"; then
      echo "Error: AI JSON payload still contains placeholder values." >&2
      if [[ "$debug_enabled" -eq 1 ]]; then
        echo "Debug: ${debug_prefix}.extracted.json" >&2
        echo "Debug: ${debug_prefix}.normalized.txt" >&2
        echo "Debug: ${debug_prefix}.raw.txt" >&2
        echo "Debug: ${debug_prefix}.prompt.txt" >&2
      fi
      rm -f "$tmp_json" "$tmp_out" "$tmp_err"
      return 2
    fi
    if ! grep -q '"review"' "$tmp_json" || ! grep -q '"verdict"[[:space:]]*:[[:space:]]*"pass"' "$tmp_json"; then
      echo "Error: AI JSON payload missing required review verdict fields." >&2
      if [[ "$debug_enabled" -eq 1 ]]; then
        echo "Debug: ${debug_prefix}.extracted.json" >&2
        echo "Debug: ${debug_prefix}.normalized.txt" >&2
        echo "Debug: ${debug_prefix}.raw.txt" >&2
        echo "Debug: ${debug_prefix}.prompt.txt" >&2
      fi
      rm -f "$tmp_json" "$tmp_out" "$tmp_err"
      return 2
    fi
    mv "$tmp_json" "$out_path"
    rm -f "$tmp_err"
  fi

  echo "Filled plan with AI: provider=$provider model=${model:-auto}"
  if [[ "$debug_enabled" -eq 1 ]]; then
    echo "Debug: ${debug_prefix}.prompt.txt" >&2
    echo "Debug: ${debug_prefix}.raw.txt" >&2
    echo "Debug: ${debug_prefix}.normalized.txt" >&2
    echo "Debug: ${debug_prefix}.extracted.json" >&2
  fi
  return 0
}

maybe_handle_plan_init_request() {
  local -a args=("$@")
  local out_path force template parent allow_ignore_gate ai_auto ai_provider ai_model debug_ai

  if [[ "${args[0]:-}" != "plan" || "${args[1]:-}" != "init" ]]; then
    return 1
  fi

  out_path="$(default_plan_output_path)"
  force=0
  allow_ignore_gate=0
  ai_auto=0
  ai_provider="auto"
  ai_model="auto"
  debug_ai=0

  local i arg
  for ((i = 2; i < ${#args[@]}; i++)); do
    arg="${args[$i]}"
    case "$arg" in
      --output|-o)
        if ((i + 1 >= ${#args[@]})); then
          echo "Error: $arg requires a value" >&2
          return 2
        fi
        out_path="${args[$((i + 1))]}"
        i=$((i + 1))
        ;;
      --output=*|-o=*)
        out_path="${arg#*=}"
        ;;
      --force|-f)
        force=1
        ;;
      --allow-ignore-gate)
        allow_ignore_gate=1
        ;;
      -ai|--ai-auto)
        ai_auto=1
        ;;
      --ai-provider|--provider)
        if ((i + 1 >= ${#args[@]})); then
          echo "Error: $arg requires a value" >&2
          return 2
        fi
        ai_provider="${args[$((i + 1))]}"
        i=$((i + 1))
        ;;
      --ai-provider=*|--provider=*)
        ai_provider="${arg#*=}"
        ;;
      --ai-model|--model)
        if ((i + 1 >= ${#args[@]})); then
          echo "Error: $arg requires a value" >&2
          return 2
        fi
        ai_model="${args[$((i + 1))]}"
        i=$((i + 1))
        ;;
      --ai-model=*|--model=*)
        ai_model="${arg#*=}"
        ;;
      --debug-ai)
        debug_ai=1
        ;;
      -h|--help)
        cat <<'EOF'
Usage: kog plan init [--output <path>] [--force] [--allow-ignore-gate]
                           [--ai-auto|-ai] [--ai-provider <name>] [--ai-model <name>]
                           [--debug-ai]

Create plan JSON from assets template.
Default output:
  ./.kano/cache/git/plans/default-plan.json
EOF
        return 0
        ;;
      *)
        echo "Error: unknown argument for plan init: $arg" >&2
        return 2
        ;;
    esac
  done

  if [[ "$allow_ignore_gate" -eq 1 ]]; then
    KOG_ALLOW_IGNORE_GATE=1
  fi

  local workspace_root="${KANO_GIT_MASTER_ROOT:-$PWD}"
  check_ignore_gate "$workspace_root" "plan-init"
  local ignore_gate_status=$?
  if [[ "$ignore_gate_status" -ne 0 ]]; then
    return "$ignore_gate_status"
  fi

  template="$(plan_template_path)"
  if [[ ! -f "$template" ]]; then
    echo "Error: plan template not found: $template" >&2
    return 2
  fi

  if [[ -e "$out_path" && "$force" -ne 1 ]]; then
    if plan_has_executed_timestamp "$out_path"; then
      force=1
      echo "[plan] existing plan has meta.executed_at_utc; overwrite enabled automatically." >&2
    else
      echo "Error: output already exists: $out_path" >&2
      echo "Hint: pass --force to overwrite." >&2
      return 2
    fi
  fi

  parent="$(dirname "$out_path")"
  mkdir -p "$parent"
  cp "$template" "$out_path"

  local workspace_root base_head dirty_fp state_pair generated_at
  workspace_root="${KANO_GIT_MASTER_ROOT:-$PWD}"
  local ignore_ds_root ignore_ds_manifest
  ignore_ds_root="$PROJECT_ROOT/assets/ignore-sources"
  ignore_ds_manifest="$PROJECT_ROOT/assets/ignore-sources/local/datasource.manifest.json"
  sed -i "s|replace-with-ignore-datasource-root|$ignore_ds_root|g" "$out_path"
  sed -i "s|replace-with-ignore-datasource-manifest|$ignore_ds_manifest|g" "$out_path"
  if git -C "$workspace_root" rev-parse --git-dir >/dev/null 2>&1; then
    state_pair="$(collect_workspace_state_hashes "$workspace_root")"
    base_head="${state_pair%% *}"
    dirty_fp="${state_pair#* }"
    generated_at="$(current_utc_iso8601)"
    if [[ -n "$generated_at" ]]; then
      sed -i "s/replace-with-generated-at-utc/$generated_at/g" "$out_path"
    fi
    if [[ -n "$base_head" ]]; then
      sed -i "s/replace-with-head-sha/$base_head/g" "$out_path"
    fi
    if [[ -n "$dirty_fp" ]]; then
      sed -i "s/replace-with-dirty-fingerprint/$dirty_fp/g" "$out_path"
    fi
  fi

  if [[ "$ai_auto" -eq 1 ]]; then
    if ! plan_init_ai_fill "$out_path" "$workspace_root" "$ai_provider" "$ai_model" "$debug_ai"; then
      return 2
    fi
  fi

  echo "Wrote plan template: $out_path"
  return 0
}

resolve_abs_path_from_base() {
  # moved to native C++ command
  printf '%s\n' "$2"
}

merge_gitignore_with_rules() {
  # moved to native C++ command
  return 0
}

apply_ignore_stage_from_plan() {
  # moved to native C++ command
  return 0
}

maybe_handle_plan_stage_request() {
  # Moved to native C++ command implementation.
  return 1
}

normalize_launcher_args() {
  local -n out_ref="$1"
  shift

  out_ref=()
  if [[ "$#" -eq 0 ]]; then
    return 0
  fi

  local command="$1"
  case "$command" in
    pi)
      out_ref=("plan" "init" "${@:2}")
      return 0
      ;;
    pia)
      out_ref=("plan" "init" "--ai-auto" "${@:2}")
      return 0
      ;;
    pa)
      command="commit-push"
      ;;
    pv)
      out_ref=("plan" "verify" "${@:2}")
      return 0
      ;;
  esac

  if [[ "$command" != "commit" && "$command" != "amend" && "$command" != "commit-push" ]]; then
    out_ref=("$@")
    return 0
  fi

  local disable_auto_plan=0
  local allow_ignore_gate=0
  if [[ "$1" == "pa" ]]; then
    out_ref+=("commit-push" "--ai-auto")
    shift
  fi

  local token
  for token in "$@"; do
    case "$token" in
      -ai)
        out_ref+=("--ai-auto")
        ;;
      --no-plan-auto)
        disable_auto_plan=1
        ;;
      --allow-ignore-gate)
        allow_ignore_gate=1
        ;;
      *)
        out_ref+=("$token")
        ;;
    esac
  done

  if [[ "$allow_ignore_gate" -eq 1 ]]; then
    KOG_ALLOW_IGNORE_GATE=1
  fi

  # Default policy: when AI mode is requested for commit/commit-push, route through plan.
  # Users can opt out with launcher-only flag: --no-plan-auto
  local normalized_command="${out_ref[0]:-}"
  if [[ "$disable_auto_plan" -eq 0 ]] && [[ "$normalized_command" == "commit" || "$normalized_command" == "commit-push" ]]; then
    local ai_requested=0
    local has_plan_file=0
    local has_message=0
    local agent_mode_requested=0
    local arg
    local idx
    for ((idx = 0; idx < ${#out_ref[@]}; idx++)); do
      arg="${out_ref[$idx]}"
      case "$arg" in
        --ai-auto|--ai-provider|--ai-model|--provider|--model)
          ai_requested=1
          ;;
        --ai-provider=*|--ai-model=*|--provider=*|--model=*)
          ai_requested=1
          ;;
        --plan-file|--plan-file=*)
          has_plan_file=1
          ;;
        -m|--message)
          if ((idx + 1 < ${#out_ref[@]})); then
            has_message=1
          fi
          ;;
        -m=*|--message=*)
          has_message=1
          ;;
        --agent)
          if ((idx + 1 < ${#out_ref[@]})) && [[ -n "${out_ref[$((idx + 1))]}" ]] && [[ "${out_ref[$((idx + 1))]}" != "manual" ]]; then
            agent_mode_requested=1
          fi
          ;;
        --agent=*)
          if [[ "${arg#--agent=}" != "manual" && -n "${arg#--agent=}" ]]; then
            agent_mode_requested=1
          fi
          ;;
      esac
    done

    if [[ "$ai_requested" -eq 1 ]] && [[ "$has_plan_file" -eq 0 ]]; then
      # Fast-path: in agent mode with explicit -m and trivial single-change workspace,
      # skip plan generation and run direct commit pipeline.
      if [[ "${KANO_AGENT_MODE:-0}" == "1" || "$agent_mode_requested" -eq 1 ]] && [[ "$has_message" -eq 1 ]]; then
        local workspace_root="${KANO_GIT_MASTER_ROOT:-$PWD}"
        local dirty_stats dirty_repo_count dirty_change_count
        dirty_stats="$(compute_dirty_workspace_scope "$workspace_root")"
        dirty_repo_count="${dirty_stats%% *}"
        dirty_change_count="${dirty_stats#* }"
        if [[ "$dirty_repo_count" == "1" && "$dirty_change_count" == "1" ]]; then
          return 0
        fi
      fi
      local workspace_root="${KANO_GIT_MASTER_ROOT:-$PWD}"
      local default_plan_file="${KOG_PLAN_FILE:-$workspace_root/.kano/cache/git/plans/default-plan.json}"
      out_ref+=("--plan-file" "$default_plan_file")
    fi
  fi
}

compute_dirty_workspace_scope() {
  local workspace_root="$1"
  local -a repos=()
  local repo status_out line_count
  local dirty_repos=0
  local total_changes=0

  mapfile -t repos < <(discover_workspace_git_repos "$workspace_root")
  if [[ "${#repos[@]}" -eq 0 ]]; then
    repos=("$workspace_root")
  fi

  for repo in "${repos[@]}"; do
    [[ -n "$repo" ]] || continue
    status_out="$(run_git_quick "$repo" status --porcelain --untracked-files=all 2>/dev/null || true)"
    [[ -n "$status_out" ]] || continue
    line_count="$(printf '%s\n' "$status_out" | awk 'NF {c+=1} END {print c+0}')"
    if [[ "$line_count" =~ ^[0-9]+$ ]] && [[ "$line_count" -gt 0 ]]; then
      dirty_repos=$((dirty_repos + 1))
      total_changes=$((total_changes + line_count))
    fi
  done

  printf '%s %s\n' "$dirty_repos" "$total_changes"
}

is_ai_mode_commit_command() {
  local -a args=("$@")
  local cmd="${args[0]:-}"
  local arg

  if [[ "$cmd" != "commit" && "$cmd" != "commit-push" ]]; then
    return 1
  fi

  for arg in "${args[@]:1}"; do
    case "$arg" in
      --ai-auto|--ai-provider|--ai-model|--provider|--model)
        return 0
        ;;
      --ai-provider=*|--ai-model=*|--provider=*|--model=*)
        return 0
        ;;
    esac
  done

  return 1
}

extract_plan_file_from_args() {
  local -n out_ref="$1"
  shift
  local -a args=("$@")
  local i arg

  out_ref=""
  for ((i = 0; i < ${#args[@]}; i++)); do
    arg="${args[$i]}"
    case "$arg" in
      --plan-file)
        if ((i + 1 < ${#args[@]})); then
          out_ref="${args[$((i + 1))]}"
          return 0
        fi
        ;;
      --plan-file=*)
        out_ref="${arg#--plan-file=}"
        return 0
        ;;
    esac
  done

  return 1
}

extract_ai_options_from_args() {
  local -n out_provider_ref="$1"
  local -n out_model_ref="$2"
  shift 2

  local -a args=("$@")
  local i arg

  out_provider_ref="auto"
  out_model_ref="auto"

  for ((i = 0; i < ${#args[@]}; i++)); do
    arg="${args[$i]}"
    case "$arg" in
      --ai-provider|--provider)
        if ((i + 1 < ${#args[@]})); then
          out_provider_ref="${args[$((i + 1))]}"
          i=$((i + 1))
        fi
        ;;
      --ai-provider=*|--provider=*)
        out_provider_ref="${arg#*=}"
        ;;
      --ai-model|--model)
        if ((i + 1 < ${#args[@]})); then
          out_model_ref="${args[$((i + 1))]}"
          i=$((i + 1))
        fi
        ;;
      --ai-model=*|--model=*)
        out_model_ref="${arg#*=}"
        ;;
    esac
  done
}

plan_file_needs_refresh() {
  local plan_file="$1"
  local bytes=0

  if [[ ! -f "$plan_file" || ! -r "$plan_file" ]]; then
    return 0
  fi

  bytes=$(wc -c <"$plan_file" 2>/dev/null || echo 0)
  if [[ ! "$bytes" =~ ^[0-9]+$ || "$bytes" -le 0 ]]; then
    return 0
  fi

  if grep -q 'replace-with-' "$plan_file" 2>/dev/null; then
    return 0
  fi

  return 1
}

print_plan_summary() {
  local plan_file="$1"
  [[ -f "$plan_file" ]] || return 0

  if has_command jq; then
    local meta_line
    meta_line="$(jq -r '
      "[plan] meta: plan_id=\(.meta.plan_id // "-") generated=\(.meta.generated_at_utc // "-") provider=\(.meta.planner.provider // "-") ai-model=\(.meta.planner["ai-model"] // "-")"
    ' "$plan_file" 2>/dev/null || true)"
    [[ -n "$meta_line" ]] && echo "$meta_line" >&2

    local counts
    counts="$(jq -r '
      .stages.commit as $c |
      "[plan] commits: repos=\(($c // [])|length) total=\(($c // [])|map((.commits // [])|length)|add // 0)"
    ' "$plan_file" 2>/dev/null || true)"
    [[ -n "$counts" ]] && echo "$counts" >&2

    jq -r '
      .stages.commit[]? as $r |
      ($r.repo // "?") as $repo |
      ($r.commits // [])[]? |
      "[plan] - \($repo): \(.message // "")"
    ' "$plan_file" 2>/dev/null | head -n 10 >&2 || true
  else
    echo "[plan] file: $plan_file (install jq for detailed summary)" >&2
  fi
}

maybe_show_plan_summary_for_ai_command() {
  local -a args=("$@")
  local plan_file=""

  if ! is_ai_mode_commit_command "${args[@]}"; then
    return 0
  fi
  if ! extract_plan_file_from_args plan_file "${args[@]}"; then
    return 0
  fi
  print_plan_summary "$plan_file"
}

maybe_auto_prepare_plan_for_ai_command() {
  local -a args=("$@")
  local cmd="${args[0]:-}"
  local plan_file="" ai_provider="auto" ai_model="auto"
  local allow_ignore_gate=0
  local i arg status
  local -a init_args=()

  # Focus on pa flow (normalized to commit-push) and commit --ai flows.
  if [[ "$cmd" != "commit" && "$cmd" != "commit-push" ]]; then
    return 0
  fi
  if ! is_ai_mode_commit_command "${args[@]}"; then
    return 0
  fi
  if ! extract_plan_file_from_args plan_file "${args[@]}"; then
    return 0
  fi
  if ! plan_file_needs_refresh "$plan_file"; then
    return 0
  fi

  extract_ai_options_from_args ai_provider ai_model "${args[@]}"

  for ((i = 0; i < ${#args[@]}; i++)); do
    arg="${args[$i]}"
    case "$arg" in
      --allow-ignore-gate)
        allow_ignore_gate=1
        ;;
    esac
  done

  init_args=("plan" "init" "--output" "$plan_file" "--force" "--ai-auto" "--ai-provider" "$ai_provider" "--ai-model" "$ai_model")
  if [[ "$allow_ignore_gate" -eq 1 ]]; then
    init_args+=("--allow-ignore-gate")
  fi

  if [[ "${KOG_PA_AUTO_PLAN_DEBUG:-0}" == "1" ]]; then
    init_args+=("--debug-ai")
  fi

  echo "[plan] auto-prepare start: $plan_file" >&2
  if maybe_handle_plan_init_request "${init_args[@]}"; then
    echo "[plan] auto-prepare done: $plan_file" >&2
    return 0
  fi
  status=$?
  echo "Error: auto-prepare plan failed (exit=$status)." >&2
  return "$status"
}

sha256_from_stdin() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum | awk '{print $1}'
    return 0
  fi
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 | awk '{print $1}'
    return 0
  fi
  if command -v openssl >/dev/null 2>&1; then
    openssl dgst -sha256 | awk '{print $NF}'
    return 0
  fi
  echo "Error: no SHA-256 tool found (sha256sum/shasum/openssl)." >&2
  return 1
}

workspace_root_abs() {
  local in_root="$1"
  local normalized="$in_root"

  if [[ "$normalized" =~ ^([A-Za-z]):[\\/](.*)$ ]]; then
    local drive="${BASH_REMATCH[1],,}"
    local rest="${BASH_REMATCH[2]}"
    rest="${rest//\\//}"
    normalized="/mnt/${drive}/${rest}"
  fi

  in_root="$normalized"
  if [[ -d "$in_root" ]]; then
    (cd "$in_root" && pwd -P)
    return 0
  fi
  printf '%s\n' "$in_root"
}

GIT_EXE_FAST_PATH=""

resolve_git_exe_fast_path() {
  if [[ -n "$GIT_EXE_FAST_PATH" ]]; then
    printf '%s\n' "$GIT_EXE_FAST_PATH"
    return 0
  fi
  if command -v git.exe >/dev/null 2>&1; then
    GIT_EXE_FAST_PATH="$(command -v git.exe)"
    printf '%s\n' "$GIT_EXE_FAST_PATH"
    return 0
  fi
  if [[ -x "/mnt/c/Program Files/Git/cmd/git.exe" ]]; then
    GIT_EXE_FAST_PATH="/mnt/c/Program Files/Git/cmd/git.exe"
    printf '%s\n' "$GIT_EXE_FAST_PATH"
    return 0
  fi
  return 1
}

to_windows_path() {
  local p="$1"
  if [[ "$p" =~ ^/mnt/([a-zA-Z])/(.*)$ ]]; then
    local drive="${BASH_REMATCH[1]}"
    local rest="${BASH_REMATCH[2]}"
    rest="${rest//\//\\}"
    printf '%s:\\%s\n' "${drive^^}" "$rest"
    return 0
  fi
  if [[ "$p" =~ ^([A-Za-z]):[\\/] ]]; then
    printf '%s\n' "$p"
    return 0
  fi
  return 1
}

run_git_quick() {
  local repo="$1"
  shift || true
  local mode="${KOG_GIT_EXE_FAST:-auto}"
  local git_exe win_repo

  if [[ "$mode" != "0" && "$mode" != "off" ]]; then
    if git_exe="$(resolve_git_exe_fast_path 2>/dev/null)"; then
      if win_repo="$(to_windows_path "$repo" 2>/dev/null)"; then
        "$git_exe" -C "$win_repo" "$@"
        return $?
      fi
    fi
  fi

  git -C "$repo" "$@"
}

repo_rel_path() {
  local workspace_root="$1"
  local repo_root="$2"
  local ws_abs repo_abs
  ws_abs="$(workspace_root_abs "$workspace_root")"
  repo_abs="$(workspace_root_abs "$repo_root")"

  if [[ "$repo_abs" == "$ws_abs" ]]; then
    printf '.\n'
    return 0
  fi
  if [[ "$repo_abs" == "$ws_abs/"* ]]; then
    printf '%s\n' "${repo_abs#"$ws_abs/"}"
    return 0
  fi
  printf '%s\n' "$repo_abs"
}

extract_repo_paths_from_discover_cache() {
  local cache_file="$1"

  if [[ ! -f "$cache_file" ]]; then
    return 0
  fi

  if command -v jq >/dev/null 2>&1; then
    jq -r '.repos[]?.path // empty' "$cache_file" 2>/dev/null || true
    return 0
  fi

  # Minimal JSON field extraction fallback for environments without jq.
  # We only need `.repos[].path` from our generated discover cache.
  sed -n 's/.*"path"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$cache_file" 2>/dev/null || true
}

discover_workspace_git_repos() {
  local workspace_root="$1"
  local ws_abs
  local -A seen=()
  local -a repos=()
  local candidate meta_path cache_file scan_depth enable_find_scan
  ws_abs="$(workspace_root_abs "$workspace_root")"
  cache_file="$ws_abs/.kano/cache/git/discover-repos/discover-repos.json"
  scan_depth="${KOG_MERKLE_SCAN_DEPTH:-6}"
  enable_find_scan="${KOG_MERKLE_ENABLE_FIND_SCAN:-0}"

  if git -C "$ws_abs" rev-parse --git-dir >/dev/null 2>&1; then
    repos+=("$ws_abs")
    seen["$ws_abs"]=1
  fi

  if [[ -f "$cache_file" ]]; then
    while IFS= read -r candidate; do
      [[ -n "$candidate" ]] || continue
      candidate="$(workspace_root_abs "$candidate")"
      if [[ -n "${seen["$candidate"]:-}" ]]; then
        continue
      fi
      seen["$candidate"]=1
      repos+=("$candidate")
    done < <(extract_repo_paths_from_discover_cache "$cache_file")
    if ((${#repos[@]} > 0)); then
      printf '%s\n' "${repos[@]}" | awk 'NF {print}' | sort -u
      return 0
    fi
  fi

  if git -C "$ws_abs" rev-parse --git-dir >/dev/null 2>&1; then
    while IFS= read -r candidate; do
      [[ -n "$candidate" ]] || continue
      candidate="$(workspace_root_abs "$candidate")"
      if [[ -n "${seen["$candidate"]:-}" ]]; then
        continue
      fi
      seen["$candidate"]=1
      repos+=("$candidate")
    done < <(git -C "$ws_abs" submodule foreach --quiet --recursive 'pwd' 2>/dev/null || true)
  fi

  if [[ "$enable_find_scan" == "1" || "$enable_find_scan" == "true" ]] && command -v find >/dev/null 2>&1; then
    while IFS= read -r meta_path; do
      [[ -n "$meta_path" ]] || continue
      candidate="$(dirname "$meta_path")"
      if [[ -n "${seen["$candidate"]:-}" ]]; then
        continue
      fi
      seen["$candidate"]=1
      repos+=("$candidate")
    done < <(find "$ws_abs" -maxdepth "$scan_depth" -name .git -print 2>/dev/null || true)
  fi

  if ((${#repos[@]} == 0)); then
    return 0
  fi
  printf '%s\n' "${repos[@]}" | awk 'NF {print}' | sort -u
}

hash_text_or_clean() {
  local text="$1"
  if [[ -z "$text" ]]; then
    printf '%s\n' "clean"
    return 0
  fi
  printf '%s' "$text" | sha256_from_stdin
}

WORKSPACE_STATE_CACHE_ROOT=""
WORKSPACE_STATE_CACHE_BASE=""
WORKSPACE_STATE_CACHE_DIRTY=""

collect_workspace_state_hashes() {
  local workspace_root="$1"
  local -a repos=()
  local repo rel status_out head status_fp
  local line_count=0
  local base_aggregate=""
  local dirty_aggregate=""

  mapfile -t repos < <(discover_workspace_git_repos "$workspace_root")
  if [[ "${KOG_DEBUG_MERKLE:-0}" == "1" ]]; then
    echo "[merkle] repos=${#repos[@]}" >&2
  fi
  if [[ "${#repos[@]}" -eq 0 ]]; then
    printf '%s\n' "no-repo clean"
    return 0
  fi

  for repo in "${repos[@]}"; do
    [[ -n "$repo" ]] || continue
    if [[ "${KOG_DEBUG_MERKLE:-0}" == "1" ]]; then
      echo "[merkle] status $repo" >&2
    fi
    if ! status_out="$(run_git_quick "$repo" status --porcelain=v2 --branch --untracked-files=normal --ignore-submodules=none 2>/dev/null)"; then
      if [[ "${KOG_DEBUG_MERKLE:-0}" == "1" ]]; then
        echo "[merkle] skip(non-repo): $repo" >&2
      fi
      continue
    fi
    rel="$(repo_rel_path "$workspace_root" "$repo")"
    head="$(printf '%s\n' "$status_out" | awk '/^# branch\.oid /{print $3; exit}')"
    if [[ -z "$head" || "$head" == "(initial)" ]]; then
      head="no-head"
    fi
    status_fp="$(hash_text_or_clean "$status_out")"
    base_aggregate+="${rel}|${head}"$'\n'
    dirty_aggregate+="${rel}|${head}|${status_fp}"$'\n'
    line_count=$((line_count + 1))
  done

  if [[ "$line_count" -eq 0 ]]; then
    printf '%s\n' "no-repo clean"
    return 0
  fi

  printf '%s %s\n' \
    "$(printf '%s' "$base_aggregate" | sha256_from_stdin)" \
    "$(printf '%s' "$dirty_aggregate" | sha256_from_stdin)"
}

ensure_workspace_state_cache() {
  local workspace_root="$1"
  local resolved_root computed
  resolved_root="$(workspace_root_abs "$workspace_root")"
  if [[ "$WORKSPACE_STATE_CACHE_ROOT" == "$resolved_root" ]] && [[ -n "$WORKSPACE_STATE_CACHE_BASE" ]] && [[ -n "$WORKSPACE_STATE_CACHE_DIRTY" ]]; then
    return 0
  fi
  computed="$(collect_workspace_state_hashes "$resolved_root")"
  WORKSPACE_STATE_CACHE_ROOT="$resolved_root"
  WORKSPACE_STATE_CACHE_BASE="${computed%% *}"
  WORKSPACE_STATE_CACHE_DIRTY="${computed#* }"
}

current_dirty_fingerprint() {
  local repo_root="$1"
  ensure_workspace_state_cache "$repo_root"
  printf '%s\n' "$WORKSPACE_STATE_CACHE_DIRTY"
}

current_head_sha() {
  local repo_root="$1"
  ensure_workspace_state_cache "$repo_root"
  printf '%s\n' "$WORKSPACE_STATE_CACHE_BASE"
}

is_probable_ignore_artifact_path() {
  local p="${1//\\//}"
  local lower="${p,,}"
  case "$lower" in
    */.cache/*|.cache/*|*/.pytest_cache/*|.pytest_cache/*|*/.mypy_cache/*|.mypy_cache/*|*/.idea/*|.idea/*|*/.vscode/*|.vscode/*)
      return 0
      ;;
    */node_modules/*|node_modules/*|*/dist/*|dist/*|*/obj/*|obj/*|*/target/*|target/*|*/out/*|out/*)
      return 0
      ;;
    *.log|*.tmp|*.temp|*.cache|*.bak|*.swp|*.swo|*.class|*.obj|*.o|*.pdb|*.ilk|*.dmp|*.pyc)
      return 0
      ;;
  esac
  return 1
}

is_ignore_gate_allowlisted_path() {
  local p="${1//\\//}"
  local lower="${p,,}"
  local allowlist_file pattern

  allowlist_file="$(ignore_gate_allowlist_path)"
  [[ -f "$allowlist_file" ]] || return 1

  while IFS= read -r pattern || [[ -n "$pattern" ]]; do
    pattern="${pattern%$'\r'}"
    [[ -n "$pattern" ]] || continue
    [[ "${pattern:0:1}" == "#" ]] && continue
    local norm="${pattern//\\//}"
    local norm_lower="${norm,,}"
    if [[ "$lower" == $norm_lower ]]; then
      return 0
    fi
  done < "$allowlist_file"

  return 1
}

check_ignore_gate() {
  local repo_root="$1"
  local context="${2:-plan}"
  local allow="${KOG_ALLOW_IGNORE_GATE:-0}"
  local -a repos=()
  local -a untracked=()
  local -a candidates=()
  local repo rel path

  if [[ "$allow" == "1" || "$allow" == "true" ]]; then
    return 0
  fi
  if [[ "${KOG_IGNORE_GATE:-on}" == "off" ]]; then
    return 0
  fi
  if ! git -C "$repo_root" rev-parse --git-dir >/dev/null 2>&1; then
    return 0
  fi

  mapfile -t repos < <(discover_workspace_git_repos "$repo_root")
  if [[ "${#repos[@]}" -eq 0 ]]; then
    repos=("$repo_root")
  fi

  for repo in "${repos[@]}"; do
    rel="$(repo_rel_path "$repo_root" "$repo")"
    mapfile -t untracked < <(run_git_quick "$repo" ls-files --others --exclude-standard 2>/dev/null || true)
    for path in "${untracked[@]}"; do
      if is_ignore_gate_allowlisted_path "$path"; then
        continue
      fi
      if is_probable_ignore_artifact_path "$path"; then
        if [[ "$rel" == "." ]]; then
          candidates+=("$path")
        else
          candidates+=("$rel/$path")
        fi
      fi
    done
  done

  if [[ "${#candidates[@]}" -eq 0 ]]; then
    return 0
  fi

  echo "Error: ignore gate failed (${context}); unresolved untracked artifact-like files detected." >&2
  local i limit
  limit=20
  for ((i = 0; i < ${#candidates[@]} && i < limit; i++)); do
    echo "  - ${candidates[$i]}" >&2
  done
  if (( ${#candidates[@]} > limit )); then
    echo "  ... and $(( ${#candidates[@]} - limit )) more" >&2
  fi
  if [[ "$context" == "ai-commit" ]]; then
    echo "Reason: current plan-driven AI commit run is blocked by ignore gate to prevent accidental artifact commits." >&2
    echo "Action: either add/remove those files now, or bypass once on the same command with --allow-ignore-gate." >&2
  else
    echo "Reason: ignore gate requires artifact-like untracked files to be handled before proceeding." >&2
    echo "Action: add/remove those files, or bypass once with --allow-ignore-gate." >&2
  fi
  return 3
}

maybe_handle_ignore_doctor_request() {
  # Moved to native C++ command implementation.
  return 1
}

validate_plan_required_fields_for_ai_mode() {
  local -a args=("$@")
  local plan_file=""
  local bytes=0

  if ! is_ai_mode_commit_command "${args[@]}"; then
    return 0
  fi

  local workspace_root="${KANO_GIT_MASTER_ROOT:-$PWD}"
  check_ignore_gate "$workspace_root" "ai-commit"
  local ignore_gate_status=$?
  if [[ "$ignore_gate_status" -ne 0 ]]; then
    return "$ignore_gate_status"
  fi

  if ! extract_plan_file_from_args plan_file "${args[@]}"; then
    echo "Error: AI mode commit requires --plan-file." >&2
    echo "Hint: set KOG_PLAN_FILE or pass --plan-file <path>." >&2
    return 2
  fi

  if [[ ! -f "$plan_file" ]]; then
    echo "Error: plan file not found: $plan_file" >&2
    return 2
  fi
  if [[ ! -r "$plan_file" ]]; then
    echo "Error: plan file is not readable: $plan_file" >&2
    return 2
  fi

  bytes=$(wc -c <"$plan_file" 2>/dev/null || echo 0)
  if [[ ! "$bytes" =~ ^[0-9]+$ || "$bytes" -le 0 ]]; then
    echo "Error: plan file is empty: $plan_file" >&2
    return 2
  fi

  # Content validation is handled in native C++ commit command.
  # Shell launcher only enforces file presence and readability.
  return 0
}

apply_agent_mode_from_args() {
  local arg next
  next=""

  if [[ "${KANO_AGENT_MODE:-}" == "1" || "${KANO_AGENT_MODE:-}" == "true" ]]; then
    return 0
  fi

  for arg in "$@"; do
    if [[ "$next" == "agent" ]]; then
      if [[ -n "$arg" && "$arg" != "manual" ]]; then
        export KANO_AGENT_MODE=1
        return 0
      fi
      next=""
      continue
    fi

    case "$arg" in
      --agent)
        next="agent"
        ;;
      --agent=*)
        local agent_value="${arg#--agent=}"
        if [[ -n "$agent_value" && "$agent_value" != "manual" ]]; then
          export KANO_AGENT_MODE=1
          return 0
        fi
        ;;
    esac
  done
}

has_non_manual_agent_arg() {
  local arg next
  next=""

  for arg in "$@"; do
    if [[ "$next" == "agent" ]]; then
      [[ -n "$arg" && "$arg" != "manual" ]] && return 0
      next=""
      continue
    fi

    case "$arg" in
      --agent)
        next="agent"
        ;;
      --agent=*)
        local agent_value="${arg#--agent=}"
        [[ -n "$agent_value" && "$agent_value" != "manual" ]] && return 0
        ;;
    esac
  done

  return 1
}

clean_native_build_artifacts() {
  remove_tree_best_effort() {
    local target_path="$1"
    [[ -e "$target_path" ]] || return 0

    if rm -rf "$target_path" 2>/dev/null; then
      return 0
    fi

    sleep 0.1
    rm -rf "$target_path" 2>/dev/null || true

    if [[ -e "$target_path" ]]; then
      log_launcher_status "build-native" "warn" "cleanup skipped (path still exists): $target_path"
    fi
  }

  local preset
  local base_build="$PROJECT_ROOT/src/cpp/build"

  while IFS= read -r preset; do
    [[ -z "$preset" ]] && continue
    remove_tree_best_effort "$base_build/_intermediate/$preset"
    remove_tree_best_effort "$base_build/bin/$preset"
    remove_tree_best_effort "$base_build/lib/$preset"
  done < <(candidate_presets)

  remove_tree_best_effort "$base_build/release"
  remove_tree_best_effort "$base_build/debug"
}

run_native_build_mode() {
  local mode="$1"
  local prereq_script build_script prereq_stamp prereq_interval now_epoch last_epoch cooldown_left

  ensure_cpp_build_submodules() {
    local -a required_paths update_paths
    local path abs_path status_line state
    required_paths=(
      "src/cpp/code/thirdparty/cli11"
      "src/cpp/code/thirdparty/ftxui"
    )

    if [[ ! -f "$PROJECT_ROOT/.gitmodules" ]]; then
      return 0
    fi

    if ! command -v git >/dev/null 2>&1; then
      echo "Error: git command not found; cannot prepare required submodules before build." >&2
      return 1
    fi

    log_launcher_status "build-native" "step" "prepare-submodules"

    for path in "${required_paths[@]}"; do
      abs_path="$PROJECT_ROOT/$path"
      status_line="$(git -C "$PROJECT_ROOT" submodule status -- "$path" 2>/dev/null || true)"
      state="${status_line:0:1}"

      if [[ "$state" == "-" && -d "$abs_path" ]]; then
        if find "$abs_path" -mindepth 1 -print -quit 2>/dev/null | grep -q .; then
          log_launcher_status "build-native" "warn" "removing stale uninitialized submodule dir: $path"
          rm -rf "$abs_path" || {
            echo "Error: failed to clean stale submodule directory: $path" >&2
            return 1
          }
        fi
      fi

      if [[ -z "$status_line" ]]; then
        continue
      fi

      update_paths+=("$path")
    done

    if [[ "${#update_paths[@]}" -eq 0 ]]; then
      log_launcher_status "build-native" "ok" "no registered C++ submodules to prepare"
      return 0
    fi

    (
      cd "$PROJECT_ROOT"
      git submodule sync -- "${update_paths[@]}" >/dev/null
      git submodule update --init --recursive -- "${update_paths[@]}"
    ) || {
      echo "Error: failed to initialize required C++ submodules (cli11/ftxui)." >&2
      echo "Hint: run 'git submodule update --init --recursive -- src/cpp/code/thirdparty/cli11 src/cpp/code/thirdparty/ftxui' and retry." >&2
      return 1
    }

    log_launcher_status "build-native" "ok" "submodules ready"
    return 0
  }

  ensure_cpp_build_submodules || return 1

  if ! mapfile -t _scripts < <(script_paths); then
    echo "Error: no native build scripts for platform $(platform_name) ($(arch_name))." >&2
    return 1
  fi

  prereq_script="${_scripts[0]:-}"
  build_script="${_scripts[1]:-}"
  if [[ -z "$prereq_script" || -z "$build_script" ]]; then
    echo "Error: missing native build script mapping for this platform." >&2
    return 1
  fi

  case "$mode" in
    incremental)
      log_launcher_status "build-native" "start" "mode=incremental"
      ;;
    full)
      log_launcher_status "build-native" "start" "mode=full"
      log_launcher_status "build-native" "step" "clean-artifacts"
      clean_native_build_artifacts
      ;;
    *)
      echo "Error: unsupported build mode: $mode (expected: incremental|full)" >&2
      return 2
      ;;
  esac

  if run_shell_script "$build_script"; then
    log_launcher_status "build-native" "ok" "build completed"
  else
    prereq_stamp="$(state_file_for build-prereq.stamp)"
    prereq_interval="${KANO_GIT_PREREQ_RETRY_INTERVAL_SECONDS:-21600}"
    if [[ ! "$prereq_interval" =~ ^[0-9]+$ || "$prereq_interval" -lt 0 ]]; then
      prereq_interval=21600
    fi

    if should_run_interval_check "$prereq_stamp" "$prereq_interval"; then
      log_launcher_status "build-native" "step" "install-prerequisites"
      touch_stamp_file "$prereq_stamp"
    else
      now_epoch="$(current_epoch)"
      last_epoch="$(file_mtime_epoch "$prereq_stamp")"
      cooldown_left=$((prereq_interval - (now_epoch - last_epoch)))
      if [[ "$cooldown_left" -lt 0 ]]; then
        cooldown_left=0
      fi
      log_launcher_status "build-native" "warn" "skip prerequisite reinstall (cooldown=${cooldown_left}s)"
      log_launcher_status "build-native" "fail" "build failed"
      return 1
    fi

    run_shell_script "$prereq_script" || {
      log_launcher_status "build-native" "fail" "prerequisite install failed"
      return 1
    }
    run_shell_script "$build_script" || {
      log_launcher_status "build-native" "fail" "build failed after prerequisite install"
      return 1
    }
    log_launcher_status "build-native" "ok" "build completed after prerequisite install"
  fi

  local binary
  binary="$(find_binary || true)"
  if [[ -n "$binary" && -f "$binary" ]]; then
    echo "Native binary ready: $binary"
    return 0
  fi

  echo "Warning: build finished but binary path could not be resolved." >&2
  return 1
}

maybe_handle_launcher_build_request() {
  if [[ "$#" -eq 0 ]]; then
    return 1
  fi

  local first="$1"
  shift || true
  local mode=""
  local extra

  case "$first" in
    build)
      mode="incremental"
      ;;
    rebuild)
      mode="full"
      ;;
    *)
      return 1
      ;;
  esac

  for extra in "$@"; do
    case "$extra" in
      --llvm)
        KOG_BUILD_USE_LLVM="1"
        ;;
      --modules)
        KOG_BUILD_ENABLE_MODULES="1"
        ;;
      --no-modules)
        KOG_BUILD_ENABLE_MODULES="0"
        ;;
      --apple-clang)
        KOG_BUILD_USE_LLVM="0"
        ;;
      *)
        echo "Error: unsupported build option: $extra" >&2
        echo "Hint: supported options are --llvm, --apple-clang, --modules, --no-modules" >&2
        return 2
        ;;
    esac
  done

  run_native_build_mode "$mode"
  return $?
}

append_once_to_file() {
  local file="$1"
  local marker="$2"
  local content="$3"

  mkdir -p "$(dirname "$file")"
  touch "$file"

  if grep -Fq "$marker" "$file" 2>/dev/null; then
    return 0
  fi

  printf '\n%s\n' "$content" >> "$file"
}

install_bash_completion() {
  local binary="$1"
  local completion_dir completion_file bash_rc source_block

  completion_dir="${HOME}/.local/share/bash-completion/completions"
  completion_file="$completion_dir/kog"
  bash_rc="${HOME}/.bashrc"

  mkdir -p "$completion_dir"
  KANO_GIT_MASTER_ROOT="${KANO_GIT_MASTER_ROOT:-$PROJECT_ROOT}" "$binary" completion bash > "$completion_file"
  chmod 0644 "$completion_file" 2>/dev/null || true

  source_block=$(cat <<EOF
# kano-git bash completion
if [[ -r "$completion_file" ]]; then
  source "$completion_file"
fi
EOF
)
  append_once_to_file "$bash_rc" "# kano-git bash completion" "$source_block"

  echo "Bash completion installed: $completion_file"
  echo "Reload shell with: source $bash_rc"
}

maybe_handle_completion_install_request() {
  if [[ "$#" -eq 0 ]]; then
    return 1
  fi

  local first="$1"
  local second="${2:-}"
  local third="${3:-}"
  local shell_name=""
  local binary=""

  case "$first" in
    completion-install)
      shell_name="${second:-bash}"
      ;;
    completion)
      if [[ "$second" != "install" ]]; then
        return 1
      fi
      shell_name="${third:-bash}"
      ;;
    *)
      return 1
      ;;
  esac

  if [[ "$shell_name" != "bash" ]]; then
    echo "Error: completion install currently supports bash only." >&2
    echo "Hint: use './kog completion install bash'" >&2
    return 2
  fi

  binary="$(find_binary || true)"
  if [[ -z "$binary" || ! -f "$binary" ]]; then
    if try_auto_prepare_binary; then
      binary="$(find_binary || true)"
    fi
  fi

  if [[ -z "$binary" || ! -f "$binary" ]]; then
    echo "Error: native binary unavailable; cannot install completion." >&2
    return 1
  fi

  if [[ ! -x "$binary" ]]; then
    chmod u+x "$binary" >/dev/null 2>&1 || true
  fi

  install_bash_completion "$binary"
  return 0
}

safe_branch_name() {
  local value="$1"
  value="${value//$'\n'/}"
  value="${value//$'\r'/}"
  printf '%s\n' "$value"
}

detect_remote_default_branch() {
  local repo="$1"
  local remote="$2"
  local head_ref branch

  head_ref="$(git -C "$repo" symbolic-ref --quiet "refs/remotes/$remote/HEAD" 2>/dev/null || true)"
  if [[ -n "$head_ref" ]]; then
    branch="${head_ref#refs/remotes/$remote/}"
    if [[ -n "$branch" ]]; then
      printf '%s\n' "$branch"
      return 0
    fi
  fi

  for branch in main master dev develop trunk; do
    if git -C "$repo" show-ref --verify --quiet "refs/remotes/$remote/$branch" 2>/dev/null; then
      printf '%s\n' "$branch"
      return 0
    fi
  done

  return 1
}

current_git_hash_short() {
  git -C "$PROJECT_ROOT" rev-parse --short HEAD 2>/dev/null || true
}

current_git_branch() {
  git -C "$PROJECT_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || true
}

current_git_revision() {
  git -C "$PROJECT_ROOT" rev-list --count --first-parent HEAD 2>/dev/null || true
}

is_git_worktree_dirty() {
  [[ -n "$(git -C "$PROJECT_ROOT" status --porcelain 2>/dev/null || true)" ]]
}

is_non_negative_integer() {
  local value="$1"
  [[ "$value" =~ ^[0-9]+$ ]]
}

binary_build_info() {
  local binary="$1"
  KANO_GIT_MASTER_ROOT="${KANO_GIT_MASTER_ROOT:-$PROJECT_ROOT}" "$binary" version 2>/dev/null || true
}

build_info_field() {
  local info="$1"
  local field="$2"
  printf '%s\n' "$info" | tr ' ' '\n' | awk -F= -v key="$field" '$1==key {print $2; exit}'
}

binary_build_hash_short() {
  local binary="$1"
  local output

  output="$(binary_build_info "$binary")"
  if [[ "$output" =~ hash_short=([^[:space:]]+) ]]; then
    printf '%s\n' "${BASH_REMATCH[1]}"
    return 0
  fi

  printf '%s\n' ""
}

should_rebuild_native_binary() {
  local binary="$1"
  local build_hash git_hash build_branch git_branch build_revision git_revision
  local build_info direction_text
  local version_file cmake_file preset_file
  local skip_when_dirty

  REBUILD_DIRECTION="unknown"
  REBUILD_REASON=""

  if [[ ! -f "$binary" ]]; then
    REBUILD_REASON="binary missing"
    return 0
  fi

  skip_when_dirty="${KOG_SKIP_AUTO_REBUILD_WHEN_DIRTY:-1}"
  if [[ "$skip_when_dirty" == "1" ]] && is_git_worktree_dirty; then
    log_launcher_status "auto-rebuild" "skip" "dirty worktree detected in $PROJECT_ROOT; skipping rebuild hash/timestamp checks"
    return 1
  fi

  build_info="$(binary_build_info "$binary")"
  git_hash="$(current_git_hash_short)"
  git_branch="$(current_git_branch)"
  git_revision="$(current_git_revision)"

  build_hash="$(build_info_field "$build_info" "hash_short")"
  build_branch="$(build_info_field "$build_info" "branch")"
  build_revision="$(build_info_field "$build_info" "rev")"

  direction_text="unknown"
  if is_non_negative_integer "$git_revision" && is_non_negative_integer "$build_revision"; then
    if (( git_revision > build_revision )); then
      REBUILD_DIRECTION="upgrade"
      direction_text="upgrade"
    elif (( git_revision < build_revision )); then
      REBUILD_DIRECTION="downgrade"
      direction_text="downgrade"
    else
      REBUILD_DIRECTION="same-revision"
      direction_text="same-revision"
    fi
  fi

  if [[ -n "$git_hash" && -n "$build_hash" && "$build_hash" != "unknown" && "$git_hash" != "$build_hash" ]]; then
    REBUILD_REASON="hash mismatch: binary(branch=${build_branch:-unknown}, rev=${build_revision:-unknown}, hash=${build_hash:-unknown}) vs git(branch=${git_branch:-unknown}, rev=${git_revision:-unknown}, hash=${git_hash:-unknown}), direction=$direction_text"
    return 0
  fi

  version_file="$PROJECT_ROOT/VERSION"
  cmake_file="$PROJECT_ROOT/src/cpp/CMakeLists.txt"
  preset_file="$PROJECT_ROOT/src/cpp/CMakePresets.json"

  if [[ -f "$version_file" && "$version_file" -nt "$binary" ]]; then
    REBUILD_REASON="VERSION file is newer than binary"
    return 0
  fi

  if [[ -f "$cmake_file" && "$cmake_file" -nt "$binary" ]]; then
    REBUILD_REASON="CMakeLists changed after binary build"
    return 0
  fi

  if [[ -f "$preset_file" && "$preset_file" -nt "$binary" ]]; then
    REBUILD_REASON="CMakePresets changed after binary build"
    return 0
  fi

  return 1
}

maybe_rebuild_binary_if_needed() {
  local binary="$1"
  local rebuilt_binary
  local allow_noninteractive_downgrade="${KANO_GIT_ALLOW_NONINTERACTIVE_DOWNGRADE_REBUILD:-0}"

  if should_rebuild_native_binary "$binary"; then
    if [[ "$REBUILD_DIRECTION" == "downgrade" ]]; then
      if ! is_interactive_terminal; then
        if [[ "$allow_noninteractive_downgrade" != "1" ]]; then
          printf '%s\n' "$binary"
          return 0
        fi
        echo "Detected downgrade rebuild in non-interactive mode; override enabled, proceeding with rebuild." >&2
      fi
      if ! maybe_prompt_yes_no "Detected downgrade rebuild. $REBUILD_REASON Proceed with downgrade rebuild?"; then
        echo "User declined downgrade rebuild; keep current binary." >&2
        printf '%s\n' "$binary"
        return 0
      fi
    fi

    if [[ -n "$REBUILD_REASON" ]]; then
      echo "$REBUILD_REASON" >&2
    fi
    echo "Detected stale C++ binary; triggering rebuild..." >&2
    if try_auto_prepare_binary; then
      rebuilt_binary="$(find_binary || true)"
      if [[ -n "$rebuilt_binary" && -f "$rebuilt_binary" ]]; then
        printf '%s\n' "$rebuilt_binary"
        return 0
      fi
      echo "Rebuild completed but no binary path was resolved." >&2
    fi

    if [[ -n "$binary" && -f "$binary" ]]; then
      printf '%s\n' "$binary"
      return 0
    fi
    return 1
  fi

  if [[ -z "$binary" || ! -f "$binary" ]]; then
    return 1
  fi

  printf '%s\n' "$binary"
}

should_skip_update_prompt_for_command() {
  local command="${1:-}"
  case "$command" in
    ""|help|-h|--help|-v|--version|version|completion|complete|__complete|sync|tui|discover|remote|slog|log|uplog|plan|ignore)
      return 0
      ;;
  esac
  return 1
}

int32_max() {
  printf '%s\n' "2147483647"
}

is_valid_int32_positive() {
  local value="$1"
  local max
  max="$(int32_max)"

  [[ "$value" =~ ^[0-9]+$ ]] || return 1
  [[ "$value" != "0" ]] || return 1

  while [[ ${#value} -gt 1 && "${value:0:1}" == "0" ]]; do
    value="${value:1}"
  done

  if [[ ${#value} -lt ${#max} ]]; then
    return 0
  fi
  if [[ ${#value} -gt ${#max} ]]; then
    return 1
  fi

  [[ "$value" < "$max" || "$value" == "$max" ]]
}

rewrite_slog_shorthand_args() {
  local -n out_ref="$1"
  shift

  local -a incoming=("$@")
  local first="${incoming[0]:-}"
  local count_part="${first#slog}"

  if [[ -z "$first" || "$first" == "slog" ]]; then
    out_ref=("${incoming[@]}")
    return 0
  fi

  if [[ "$first" =~ ^slog[0-9]+$ ]]; then
    if ! is_valid_int32_positive "$count_part"; then
      echo "Error: slog count must be a positive integer <= $(int32_max)" >&2
      return 2
    fi
    out_ref=("slog" "$count_part" "${incoming[@]:1}")
    return 0
  fi

  out_ref=("${incoming[@]}")
  return 0
}

rewrite_discover_command_args() {
  local -n out_ref="$1"
  shift

  local -a incoming=("$@")
  local arg
  local has_max_depth=0

  out_ref=("workspace" "discover")

  for arg in "${incoming[@]:1}"; do
    case "$arg" in
      --native-max-depth)
        out_ref+=("--max-depth")
        has_max_depth=1
        continue
        ;;
      --native-max-depth=*)
        out_ref+=("--max-depth=${arg#--native-max-depth=}")
        has_max_depth=1
        continue
        ;;
      --max-depth|--max-depth=*)
        has_max_depth=1
        ;;
      --no-cache)
        out_ref+=("--no-cache")
        continue
        ;;
      --native-no-cache)
        out_ref+=("--no-cache")
        continue
        ;;
      --native-refresh-cache)
        continue
        ;;
    esac
    out_ref+=("$arg")
  done

  if [[ "$has_max_depth" -eq 0 ]]; then
    out_ref+=("--max-depth" "${KOG_DISCOVER_MAX_DEPTH:-8}")
  fi
}

run_dev_mode_update_flow() {
  local preferred_remote branch ahead_count sync_script

  if ! is_interactive_terminal; then
    return 0
  fi

  if is_git_worktree_dirty; then
    echo "[launcher] Skip remote update check: dirty worktree in $PROJECT_ROOT" >&2
    return 0
  fi

  preferred_remote="upstream"
  if ! git -C "$PROJECT_ROOT" remote get-url "$preferred_remote" >/dev/null 2>&1; then
    preferred_remote="origin"
  fi
  if ! git -C "$PROJECT_ROOT" remote get-url "$preferred_remote" >/dev/null 2>&1; then
    return 0
  fi

  echo "[launcher] Checking remote updates from $preferred_remote..." >&2
  git -C "$PROJECT_ROOT" fetch "$preferred_remote" --prune >/dev/null 2>&1 || true

  branch="$(detect_remote_default_branch "$PROJECT_ROOT" "$preferred_remote" || true)"
  branch="$(safe_branch_name "$branch")"
  if [[ -z "$branch" ]]; then
    branch="$(safe_branch_name "$(git -C "$PROJECT_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || true)")"
  fi
  [[ -z "$branch" ]] && return 0

  ahead_count="$(git -C "$PROJECT_ROOT" rev-list --count "HEAD..$preferred_remote/$branch" 2>/dev/null || printf '0')"
  if [[ ! "$ahead_count" =~ ^[0-9]+$ || "$ahead_count" -le 0 ]]; then
    return 0
  fi

  if maybe_prompt_yes_no "[launcher] Found $ahead_count upstream commit(s) on $preferred_remote/$branch. Run sync now?"; then
    sync_script="$PROJECT_ROOT/src/shell/commit-tools/sync/smart-sync-origin-latest.sh"
    if [[ -f "$sync_script" ]]; then
      run_shell_script "$sync_script" --repo "$PROJECT_ROOT" --remote "$preferred_remote" || true
    fi
  fi
}

run_package_mode_update_flow() {
  local interval stamp_file latest_version current_version check_cmd update_cmd

  if ! is_interactive_terminal; then
    return 0
  fi

  interval="${KANO_GIT_PACKAGE_UPDATE_CHECK_INTERVAL_SECONDS:-21600}"
  if [[ ! "$interval" =~ ^[0-9]+$ ]]; then
    interval=21600
  fi

  stamp_file="$(state_file_for package-update-check.stamp)"
  if ! should_run_interval_check "$stamp_file" "$interval"; then
    return 0
  fi

  touch_stamp_file "$stamp_file"

  check_cmd="${KANO_GIT_PACKAGE_VERSION_CHECK_CMD:-}"
  [[ -z "$check_cmd" ]] && return 0

  latest_version="$(bash -lc "$check_cmd" 2>/dev/null | tr -d '\r\n' || true)"
  [[ -z "$latest_version" ]] && return 0

  current_version="$(tr -d '\r\n' < "$PROJECT_ROOT/VERSION" 2>/dev/null || echo "unknown")"
  if [[ "$latest_version" == "$current_version" ]]; then
    return 0
  fi

  if maybe_prompt_yes_no "[launcher] New package version available ($current_version -> $latest_version). Update now?"; then
    update_cmd="${KANO_GIT_PACKAGE_UPDATE_CMD:-}"
    if [[ -z "$update_cmd" ]]; then
      echo "[launcher] Set KANO_GIT_PACKAGE_UPDATE_CMD to enable one-click package updates." >&2
      return 0
    fi
    run_with_progress "package update" bash -lc "$update_cmd" || true
  fi
}

maybe_run_launcher_update_flow() {
  local command="${1:-}"

  if [[ "${KANO_GIT_AUTO_UPDATE_CHECK:-1}" != "1" ]]; then
    return 0
  fi

  if [[ "${KANO_AGENT_MODE:-0}" == "1" ]]; then
    return 0
  fi

  if should_skip_update_prompt_for_command "$command"; then
    return 0
  fi

  if is_packaged_install; then
    run_package_mode_update_flow
    return 0
  fi

  if git -C "$PROJECT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    run_dev_mode_update_flow
  fi
}

platform_name() {
  local os_name
  os_name="$(uname -s 2>/dev/null || true)"
  case "$os_name" in
    Darwin*) echo "macos" ;;
    Linux*) echo "linux" ;;
    MINGW*|MSYS*|CYGWIN*|Windows_NT) echo "windows" ;;
    *) echo "${os_name,,}" ;;
  esac
}

arch_name() {
  local machine
  machine="$(uname -m 2>/dev/null || true)"
  case "$machine" in
    arm64|aarch64) echo "arm64" ;;
    *) echo "x64" ;;
  esac
}

find_bash() {
  if command -v bash >/dev/null 2>&1; then
    command -v bash
    return 0
  fi

  if [[ -n "${GIT_BASH_PATH:-}" && -f "${GIT_BASH_PATH}" ]]; then
    printf '%s\n' "$GIT_BASH_PATH"
    return 0
  fi

  if [[ -f "C:/Program Files/Git/bin/bash.exe" ]]; then
    printf '%s\n' "C:/Program Files/Git/bin/bash.exe"
    return 0
  fi

  return 1
}

binary_name() {
  case "$(platform_name)" in
    windows) echo "kano-git.exe" ;;
    *) echo "kano-git" ;;
  esac
}

candidate_presets() {
  local os_name arch
  os_name="$(platform_name)"
  arch="$(arch_name)"

  case "$os_name" in
    windows)
      if [[ "$arch" == "arm64" ]]; then
        printf '%s\n' "windows-ninja-msvc-arm64" "windows-ninja-msvc"
      else
        printf '%s\n' "windows-ninja-msvc"
      fi
      ;;
    linux)
      printf '%s\n' "linux-ninja-gcc"
      ;;
    macos)
      if [[ "$arch" == "arm64" ]]; then
        printf '%s\n' "macos-ninja-clang-arm64" "macos-ninja-clang" "macos-ninja-llvm-arm64" "macos-make-clang-arm64" "macos-make-llvm-arm64"
      else
        printf '%s\n' "macos-ninja-clang-x64" "macos-ninja-clang" "macos-ninja-llvm-x64" "macos-make-clang-x64" "macos-make-llvm-x64"
      fi
      ;;
  esac
}

find_binary() {
  local exe_name build_dir candidate preset resolved_path resolved_dir
  exe_name="$(binary_name)"
  build_dir="$PROJECT_ROOT/src/cpp/build"

  if [[ -n "${KANO_GIT_BIN:-}" ]]; then
    if [[ -f "$KANO_GIT_BIN" ]]; then
      printf '%s\n' "$KANO_GIT_BIN"
      return 0
    fi
    if [[ -f "$KANO_GIT_BIN/$exe_name" ]]; then
      printf '%s\n' "$KANO_GIT_BIN/$exe_name"
      return 0
    fi
  fi

  while IFS= read -r preset; do
    [[ -z "$preset" ]] && continue
    candidate="$build_dir/bin/$preset/release/$exe_name"
    if [[ -f "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
    candidate="$build_dir/bin/$preset/debug/$exe_name"
    if [[ -f "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done < <(candidate_presets)

  candidate="$build_dir/release/$exe_name"
  [[ -f "$candidate" ]] && { printf '%s\n' "$candidate"; return 0; }
  candidate="$build_dir/debug/$exe_name"
  [[ -f "$candidate" ]] && { printf '%s\n' "$candidate"; return 0; }

  if command -v kano-git >/dev/null 2>&1; then
    resolved_path="$(command -v kano-git)"
    if [[ -n "$resolved_path" ]]; then
      resolved_dir="$(cd "$(dirname "$resolved_path")" && pwd)"
      resolved_path="$resolved_dir/$(basename "$resolved_path")"
      if [[ "$resolved_path" != "$SCRIPT_DIR/kano-git" ]]; then
        printf '%s\n' "$resolved_path"
        return 0
      fi
    fi
  fi

  return 1
}

script_paths() {
  local base os_name arch prereq build
  base="$PROJECT_ROOT/src/cpp/build/script"
  os_name="$(platform_name)"
  arch="$(arch_name)"

  case "$os_name" in
    windows)
      prereq="$base/windows/prerequisite_windows.sh"
      if [[ "$arch" == "arm64" ]]; then
        build="$base/windows/build_windows_ninja_msvc_arm64_release.sh"
      else
        build="$base/windows/build_windows_ninja_msvc_release.sh"
      fi
      ;;
    linux)
      prereq="$base/linux/prerequisite_linux.sh"
      build="$base/linux/build_linux_ninja_gcc_release.sh"
      ;;
    macos)
      prereq="$base/macos/prerequisite_macos.sh"
      if [[ "$arch" == "arm64" ]]; then
        build="$base/macos/build_macos_ninja_clang_arm64_release.sh"
      else
        build="$base/macos/build_macos_ninja_clang_x64_release.sh"
      fi
      ;;
    *)
      return 1
      ;;
  esac

  printf '%s\n%s\n' "$prereq" "$build"
}

install_marker_file() {
  if [[ -n "${KANO_GIT_INSTALL_MARKER:-}" ]]; then
    printf '%s\n' "$KANO_GIT_INSTALL_MARKER"
  else
    printf '%s\n' "$PROJECT_ROOT/.kano-installed-marker"
  fi
}

is_packaged_install() {
  local marker
  marker="$(install_marker_file)"
  [[ -f "$marker" ]]
}

run_shell_script() {
  local script bash_path start end elapsed
  local script_name
  script="$1"
  shift || true
  script_name="$(basename "$script")"
  if ! bash_path="$(find_bash)"; then
    echo "Warning: bash not found; cannot run shell script automation." >&2
    return 1
  fi
  if [[ ! -f "$script" ]]; then
    echo "Warning: script not found: $script" >&2
    return 1
  fi

  start="$(current_epoch)"
  log_launcher_status "$script_name" "start" "args=$*"

  if [[ "$script_name" == prerequisite_* ]]; then
    if env KANO_GIT_MASTER_ROOT="${KANO_GIT_MASTER_ROOT:-$PROJECT_ROOT}" KOG_BUILD_USE_LLVM="$KOG_BUILD_USE_LLVM" KOG_BUILD_ENABLE_MODULES="$KOG_BUILD_ENABLE_MODULES" "$bash_path" "$script" "$@"; then
      end="$(current_epoch)"
      elapsed=$((end - start))
      log_launcher_status "$script_name" "ok" "elapsed=${elapsed}s"
      return 0
    fi
  elif run_with_progress "$script_name" env KANO_GIT_MASTER_ROOT="${KANO_GIT_MASTER_ROOT:-$PROJECT_ROOT}" KOG_BUILD_USE_LLVM="$KOG_BUILD_USE_LLVM" KOG_BUILD_ENABLE_MODULES="$KOG_BUILD_ENABLE_MODULES" "$bash_path" "$script" "$@"; then
    end="$(current_epoch)"
    elapsed=$((end - start))
    log_launcher_status "$script_name" "ok" "elapsed=${elapsed}s"
    return 0
  fi

  end="$(current_epoch)"
  elapsed=$((end - start))
  log_launcher_status "$script_name" "fail" "elapsed=${elapsed}s"
  return 1
}

try_auto_prepare_binary() {
  local prereq_script build_script
  local step_idx=0
  local -a build_submodules=(
    "src/cpp/code/thirdparty/cli11"
    "src/cpp/code/thirdparty/ftxui"
  )

  if [[ -f "$PROJECT_ROOT/.gitmodules" ]] && command -v git >/dev/null 2>&1; then
    log_launcher_status "auto-prepare" "step" "prepare-submodules"
    (
      cd "$PROJECT_ROOT"
      git submodule sync -- "${build_submodules[@]}" >/dev/null
      git submodule update --init --recursive -- "${build_submodules[@]}"
    ) || {
      echo "Warning: failed to prepare C++ thirdparty submodules (cli11/ftxui); build may fail." >&2
    }
  fi

  if ! mapfile -t _scripts < <(script_paths); then
    echo "Warning: no build automation scripts for platform $(platform_name) ($(arch_name))." >&2
    return 1
  fi

  prereq_script="${_scripts[0]:-}"
  build_script="${_scripts[1]:-}"
  if [[ -z "$prereq_script" || -z "$build_script" ]]; then
    echo "Warning: missing prerequisite/build script mapping for this platform." >&2
    return 1
  fi

  step_idx=$((step_idx + 1))
  log_launcher_status "auto-prepare" "step" "${step_idx}: direct-build"
  echo "Attempting C++ binary build/refresh..." >&2
  if run_shell_script "$build_script"; then
    log_launcher_status "auto-prepare" "ok" "direct-build succeeded"
    return 0
  fi

  step_idx=$((step_idx + 1))
  log_launcher_status "auto-prepare" "step" "${step_idx}: prerequisite-install"
  echo "Direct build failed. Installing/upgrading prerequisites..." >&2
  run_shell_script "$prereq_script" || {
    log_launcher_status "auto-prepare" "fail" "prerequisite-install failed"
    echo "Warning: prerequisite installation failed." >&2
    return 1
  }

  step_idx=$((step_idx + 1))
  log_launcher_status "auto-prepare" "step" "${step_idx}: rebuild-after-prereq"
  echo "Retrying C++ accelerated kano-git binary build..." >&2
  run_shell_script "$build_script" || {
    log_launcher_status "auto-prepare" "fail" "rebuild-after-prereq failed"
    echo "Warning: C++ binary build failed after prerequisite installation." >&2
    return 1
  }

  log_launcher_status "auto-prepare" "ok" "binary ready"
  return 0
}

print_launcher_help_extras() {
  cat >&2 <<'EOF'

Launcher commands:
  build                               Build native binary (incremental; auto-prepare required C++ submodules)
  rebuild                             Rebuild native binary (full clean rebuild; auto-prepare required C++ submodules)
  discover                            Run manual repo discovery, refresh cache, and print cache file path
  plan init                           Write plan template from assets
    -ai, --ai-auto                    Generate and fill plan via one AI request
    --ai-provider <name>              AI provider for plan generation (codex|opencode|copilot|auto)
    --ai-model <name>                 AI model for plan generation
  plan apply                          Apply plan stages (default: all)
    --stage ignore|commit|all         Run only selected stage(s)
  plan verify                         Verify plan schema
    --stage ignore|commit|all         Verify selected stage requirements
  ignore doctor                       Scan tracked files and suggest likely ignore candidates
    --repo <path>                     Limit scan root (default: current workspace)
    --limit <n>                       Max findings (default: 200)
    --json                            Output JSON
    --apply                           Apply untrack actions (git rm --cached) for findings
    --dry-run                         Print planned untrack actions only
    --yes                             Skip interactive confirmation for --apply
  pi ...                              Alias of plan init ...
  pia ...                             Alias of plan init --ai-auto ...
  pa ...                              Alias of commit-push --ai-auto (auto adds --plan-file)
                                      Auto-prepares plan via AI when missing/placeholder
    --no-plan-auto                    Launcher-only: disable AI->plan auto routing
    --allow-ignore-gate               Launcher-only: bypass ignore gate for this run
    --llvm                            Use Homebrew LLVM clang/clang++ toolchain (macOS)
    --modules                         Enable C++20 modules (requires compatible toolchain)
    --no-modules                      Disable C++20 modules
  completion install bash             Install bash completion script
  completion-install bash             Alias of completion install bash

Launcher env:
  KANO_AGENT_MODE=1                Force non-interactive agent mode in launcher flows
  KANO_GIT_ALLOW_NONINTERACTIVE_DOWNGRADE_REBUILD=1
                                      Allow downgrade rebuild in non-interactive mode
  KOG_BUILD_USE_LLVM=0|1              Build with LLVM toolchain (macOS default: 1)
  KOG_BUILD_ENABLE_MODULES=0|1        Build with C++20 modules (macOS default: 1)
  KOG_PLAN_FILE=<path>                Default plan file used when AI flags are present
                                      AI mode enforces required plan fields before execution,
                                      including per-commit review (verdict=pass + reason)
  KOG_PA_AUTO_PLAN_DEBUG=1            Enable --debug-ai during pa auto plan prepare
  KOG_MERKLE_ENABLE_FIND_SCAN=1       Include filesystem .git scan for unregistered nested repos
                                      (default: 0; use discover cache + submodule list)
  KOG_ALLOW_IGNORE_GATE=1             Bypass ignore gate (not recommended)
  KOG_IGNORE_GATE=off                 Disable ignore gate globally (not recommended)
                                      Static allowlist: assets/gitignore/ignore-gate-allowlist.txt
  KOG_SKIP_AUTO_REBUILD_WHEN_DIRTY=0|1
                                      Skip auto-rebuild checks when git worktree is dirty (default: 1)
EOF
}

run_native_binary() {
  local binary="$1"
  shift || true

  local first="${1:-}"
  local arg_count=$#
  local -a native_args=("$@")
  local i arg next_is_plan_path converted

  if [[ ! -x "$binary" ]]; then
    chmod u+x "$binary" >/dev/null 2>&1 || true
  fi

  if [[ "$binary" == *.exe ]]; then
    next_is_plan_path=0
    for ((i = 0; i < ${#native_args[@]}; i++)); do
      arg="${native_args[$i]}"
      if [[ "$next_is_plan_path" -eq 1 ]]; then
        if converted="$(to_windows_path "$arg" 2>/dev/null)"; then
          native_args[$i]="$converted"
        fi
        next_is_plan_path=0
        continue
      fi
      case "$arg" in
        --plan-file)
          next_is_plan_path=1
          ;;
        --plan-file=*)
          if converted="$(to_windows_path "${arg#--plan-file=}" 2>/dev/null)"; then
            native_args[$i]="--plan-file=$converted"
          fi
          ;;
      esac
    done
  fi

  KANO_GIT_MASTER_ROOT="${KANO_GIT_MASTER_ROOT:-$PROJECT_ROOT}" KANO_GIT_BINARY_PATH="$binary" "$binary" "${native_args[@]}"
  local status=$?

  if [[ "$status" -eq 0 ]]; then
    case "$first" in
      ""|-h|--help|help)
        if [[ "$arg_count" -le 1 ]]; then
          print_launcher_help_extras
        fi
        ;;
    esac
  fi

  return "$status"
}

main() {
  local binary marker
  local -a args=()
  local -a exec_args=()

  normalize_launcher_args args "$@"
  apply_agent_mode_from_args "${args[@]}"

  case "${args[0]:-}" in
    build|rebuild)
      maybe_handle_launcher_build_request "${args[@]}"
      exit $?
      ;;
  esac

  local plan_init_status=0
  if maybe_handle_plan_init_request "${args[@]}"; then
    exit 0
  else
    plan_init_status=$?
  fi
  if [[ "$plan_init_status" -ne 1 ]]; then
    exit "$plan_init_status"
  fi

  local completion_status=0
  if maybe_handle_completion_install_request "${args[@]}"; then
    exit 0
  else
    completion_status=$?
  fi
  if [[ "$completion_status" -ne 1 ]]; then
    exit "$completion_status"
  fi

  maybe_run_launcher_update_flow "${args[0]:-}"

  exec_args=("${args[@]}")
  if ! rewrite_slog_shorthand_args exec_args "${exec_args[@]}"; then
    exit $?
  fi
  if [[ "${args[0]:-}" == "discover" ]]; then
    rewrite_discover_command_args exec_args "${args[@]}"
  fi
  maybe_auto_prepare_plan_for_ai_command "${exec_args[@]}"
  local auto_plan_status=$?
  if [[ "$auto_plan_status" -ne 0 ]]; then
    exit "$auto_plan_status"
  fi
  maybe_show_plan_summary_for_ai_command "${exec_args[@]}"
  validate_plan_required_fields_for_ai_mode "${exec_args[@]}"
  local plan_validate_status=$?
  if [[ "$plan_validate_status" -ne 0 ]]; then
    exit "$plan_validate_status"
  fi

  if binary="$(find_binary)"; then
    if ! binary="$(maybe_rebuild_binary_if_needed "$binary")"; then
      binary=""
    fi

    if [[ -z "$binary" || ! -f "$binary" ]]; then
      echo "Warning: resolved binary path is unavailable after rebuild checks; retrying auto-prepare." >&2
      if ! is_packaged_install && try_auto_prepare_binary; then
        binary="$(find_binary || true)"
      fi
    fi

    if [[ -n "$binary" && -f "$binary" ]]; then
      run_native_binary "$binary" "${exec_args[@]}"
      exit $?
    fi
  fi

  if is_packaged_install; then
    marker="$(install_marker_file)"
    echo "Error: kano-git packaged install marker detected, but C++ binary is missing." >&2
    echo "Error: marker file: $marker" >&2
    echo "Error: this installation may be corrupted. Please reinstall the package." >&2
  else
    if try_auto_prepare_binary; then
      if binary="$(find_binary)"; then
        run_native_binary "$binary" "${exec_args[@]}"
        exit $?
      fi
    fi
  fi

  echo "Error: strict native-only mode is enabled and C++ binary is unavailable." >&2
  echo "Error: shell fallback is disabled by design." >&2
  echo "Hint: run the platform build script under src/cpp/build/script/ and retry." >&2
  exit 1
}

main "$@"
