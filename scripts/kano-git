#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Source shared pixi bootstrap helper (lib/, not directly executable)
# This provides kano_pixi_bootstrap_activate() which activates the pixi environment
# via shell-hook when not already active, and fail-fast when the canonical shared
# Pixi manifest exists but
# pixi is unavailable. PATH-first tool resolution is preserved.
KANO_PIXI_BOOTSTRAP_SCRIPT="$PROJECT_ROOT/src/cpp/shared/infra/scripts/lib/pixi_bootstrap.sh"
if [[ ! -f "$KANO_PIXI_BOOTSTRAP_SCRIPT" ]]; then
  echo "Error: shared infra bootstrap is missing: $KANO_PIXI_BOOTSTRAP_SCRIPT" >&2
  echo "Hint: initialize submodules, or use a release archive that includes shared infra." >&2
  exit 1
fi

# Deliberately no OPAM result capture — the eval inside activate() emits to the shell.
# Disable shellcheck SC1091 (not following resolved path) for this source directive.
# shellcheck source=/dev/null
source "$KANO_PIXI_BOOTSTRAP_SCRIPT"

if ! declare -F kano_pixi_bootstrap_activate >/dev/null 2>&1; then
  echo "Error: kano_pixi_bootstrap_activate was not loaded from shared infra." >&2
  exit 1
fi

# Activate pixi environment from the canonical shared infra manifest.
# This ensures build tools (cmake, ninja, git, bash, python) are resolved from
# the shared-infra pixi environment before any PATH lookups occur.
# If that manifest is present but pixi is unavailable, bootstrap fails fast here
# rather than silently falling back to system tools.
kano_pixi_bootstrap_activate 2>&1 | head -1

PATH="$SCRIPT_DIR:$PATH"
LAUNCHER_STATE_DIR="$PROJECT_ROOT/.kano/launcher"
REBUILD_DIRECTION="unknown"
REBUILD_REASON=""
if [[ "$(uname -s  || true)" == "Darwin" ]]; then
  KOG_BUILD_USE_LLVM="${KOG_BUILD_USE_LLVM:-1}"
  KOG_BUILD_ENABLE_MODULES="${KOG_BUILD_ENABLE_MODULES:-1}"
else
  KOG_BUILD_USE_LLVM="${KOG_BUILD_USE_LLVM:-0}"
  KOG_BUILD_ENABLE_MODULES="${KOG_BUILD_ENABLE_MODULES:-0}"
fi
KOG_ALLOW_IGNORE_GATE="${KOG_ALLOW_IGNORE_GATE:-0}"
KOG_GIT_INTERACTIVE="${KOG_GIT_INTERACTIVE:-auto}"

# Non-interactive git defaults:
# - agent mode => non-interactive by default
# - human/manual mode => interactive by default
# Override with KOG_GIT_INTERACTIVE=1|true|0|false.
__kog_git_interactive_mode="${KOG_GIT_INTERACTIVE,,}"
if [[ "$__kog_git_interactive_mode" == "auto" || -z "$__kog_git_interactive_mode" ]]; then
  if [[ "${KANO_AGENT_MODE:-0}" == "1" || "${KANO_AGENT_MODE:-}" == "true" ]]; then
    __kog_git_interactive_mode="0"
  else
    __kog_git_interactive_mode="1"
  fi
fi

if [[ "$__kog_git_interactive_mode" != "1" && "$__kog_git_interactive_mode" != "true" ]]; then
  export GIT_TERMINAL_PROMPT="${GIT_TERMINAL_PROMPT:-0}"
  export GIT_EDITOR="${GIT_EDITOR:-true}"
  export GIT_SEQUENCE_EDITOR="${GIT_SEQUENCE_EDITOR:-true}"
  export EDITOR="${EDITOR:-true}"
  export VISUAL="${VISUAL:-true}"
fi
unset __kog_git_interactive_mode

is_interactive_terminal() {
  [[ -t 0 && -t 1 ]]
}

ensure_launcher_state_dir() {
  mkdir -p "$LAUNCHER_STATE_DIR"
}

state_file_for() {
  local name="$1"
  printf '%s/%s\n' "$LAUNCHER_STATE_DIR" "$name"
}

file_mtime_epoch() {
  local file="$1"
  if [[ ! -e "$file" ]]; then
    printf '%s\n' "0"
    return 0
  fi

  if stat -c %Y "$file" >/dev/null 2>&1; then
    stat -c %Y "$file"
    return 0
  fi

  if stat -f %m "$file" >/dev/null 2>&1; then
    stat -f %m "$file"
    return 0
  fi

  printf '%s\n' "0"
}

current_epoch() {
  date +%s  || printf '%s\n' "0"
}

should_run_interval_check() {
  local stamp_file="$1"
  local interval_seconds="$2"
  local now last delta

  if [[ "$interval_seconds" -le 0 ]]; then
    return 0
  fi

  now="$(current_epoch)"
  last="$(file_mtime_epoch "$stamp_file")"
  if [[ "$last" -le 0 ]]; then
    return 0
  fi

  delta=$((now - last))
  [[ "$delta" -ge "$interval_seconds" ]]
}

touch_stamp_file() {
  local stamp_file="$1"
  ensure_launcher_state_dir
  : > "$stamp_file"
}

log_launcher_status() {
  local step="$1"
  local status="$2"
  local message="${3:-}"

  if [[ -n "$message" ]]; then
    echo "[launcher][$step][$status] $message" >&2
  else
    echo "[launcher][$step][$status]" >&2
  fi
}

run_with_progress() {
  local label="$1"
  shift

  local interval pid start now elapsed
  interval="${KANO_GIT_PROGRESS_INTERVAL_SECONDS:-30}"
  if [[ ! "$interval" =~ ^[0-9]+$ || "$interval" -le 0 ]]; then
    interval=30
  fi

  if [[ "${KANO_GIT_PROGRESS_HEARTBEAT:-1}" == "1" && -t 1 ]]; then
    "$@" &
    pid=$!
    start="$(current_epoch)"
    while kill -0 "$pid" ; do
      sleep "$interval"
      if ! kill -0 "$pid" ; then
        break
      fi
      now="$(current_epoch)"
      elapsed=$((now - start))
      log_launcher_status "$label" "running" "elapsed=${elapsed}s"
    done
    wait "$pid"
    return $?
  fi

  "$@"
}

maybe_prompt_yes_no() {
  local prompt="$1"
  local answer

  if ! is_interactive_terminal; then
    return 1
  fi

  read -r -p "$prompt [y/N]: " answer
  case "${answer,,}" in
    y|yes) return 0 ;;
  esac
  return 1
}

is_windows_compat_shell() {
  local os_name
  os_name="$(uname -s  || true)"
  case "$os_name" in
    MINGW*|MSYS*|CYGWIN*)
      return 0
      ;;
  esac
  return 1
}

ensure_windows_build_runtime_paths() {
  # Only for Windows-compat shells (Git Bash / Cygwin).
  # WSL is treated as Linux build environment and should not consume Windows .exe toolchain shims.
  if ! is_windows_compat_shell; then
    return 0
  fi

  # Ensure cmake/ninja are reachable in Windows-compat shells.
  local cmake_exe="" ninja_exe=""
  if [[ -x "/mnt/c/Program Files/CMake/bin/cmake.exe" ]]; then
    cmake_exe="/mnt/c/Program Files/CMake/bin/cmake.exe"
  elif [[ -x "/c/Program Files/CMake/bin/cmake.exe" ]]; then
    cmake_exe="/c/Program Files/CMake/bin/cmake.exe"
  elif [[ -x "/cygdrive/c/Program Files/CMake/bin/cmake.exe" ]]; then
    cmake_exe="/cygdrive/c/Program Files/CMake/bin/cmake.exe"
  fi
  if [[ -x "/mnt/c/Program Files/CMake/bin/ninja.exe" ]]; then
    ninja_exe="/mnt/c/Program Files/CMake/bin/ninja.exe"
  elif [[ -x "/c/Program Files/CMake/bin/ninja.exe" ]]; then
    ninja_exe="/c/Program Files/CMake/bin/ninja.exe"
  elif [[ -x "/cygdrive/c/Program Files/CMake/bin/ninja.exe" ]]; then
    ninja_exe="/cygdrive/c/Program Files/CMake/bin/ninja.exe"
  fi

  if [[ -n "$cmake_exe" || -n "$ninja_exe" ]]; then
    local shim_dir="$PROJECT_ROOT/.kano/cache/runtime-shims"
    mkdir -p "$shim_dir"
    if [[ -n "$cmake_exe" && ! -x "$shim_dir/cmake" ]]; then
      cat > "$shim_dir/cmake" <<EOF
#!/usr/bin/env bash
exec "$cmake_exe" "\$@"
EOF
      chmod +x "$shim_dir/cmake" >/dev/null 2>&1 || true
    fi
    if [[ -n "$ninja_exe" && ! -x "$shim_dir/ninja" ]]; then
      cat > "$shim_dir/ninja" <<EOF
#!/usr/bin/env bash
exec "$ninja_exe" "\$@"
EOF
      chmod +x "$shim_dir/ninja" >/dev/null 2>&1 || true
    fi
    PATH="$shim_dir:$PATH"
  fi
}

resolve_pixi_command() {
  if command -v pixi >/dev/null 2>&1; then
    command -v pixi
    return 0
  fi

  if [[ -n "${USERPROFILE:-}" && -x "${USERPROFILE}/.pixi/bin/pixi" ]]; then
    printf '%s\n' "${USERPROFILE}/.pixi/bin/pixi"
    return 0
  fi

  if [[ -n "${HOME:-}" && -x "${HOME}/.pixi/bin/pixi" ]]; then
    printf '%s\n' "${HOME}/.pixi/bin/pixi"
    return 0
  fi

  return 1
}

shared_pixi_manifest_path() {
  if [[ -n "${KANO_PIXI_MANIFEST_PATH:-}" ]]; then
    printf '%s\n' "$KANO_PIXI_MANIFEST_PATH"
    return 0
  fi
  printf '%s\n' "$PROJECT_ROOT/src/cpp/shared/infra/pixi.toml"
}

shared_pixi_project_root() {
  dirname "$(shared_pixi_manifest_path)"
}

windows_pixi_build_bin_dir() {
  # 1. Per-project pixi env (pixi install)
  local pixi_bin_dir="$(shared_pixi_project_root)/.pixi/envs/default/Library/bin"
  if [[ -x "$pixi_bin_dir/cmake.exe" && -x "$pixi_bin_dir/ninja.exe" ]]; then
    printf '%s\n' "$pixi_bin_dir"
    return 0
  fi

  # 2. pixi global tools (~/.pixi/bin via USERPROFILE or HOME)
  local global_bin=""
  if [[ -n "${USERPROFILE:-}" ]]; then
    local win_home
    if command -v cygpath >/dev/null 2>&1; then
      win_home="$(cygpath -u "${USERPROFILE}")"
    else
      win_home="$(printf '%s' "${USERPROFILE}" | sed 's|\\|/|g; s|^\([A-Za-z]\):|/\L\1|')"
    fi
    global_bin="${win_home}/.pixi/bin"
  fi
  if [[ -z "$global_bin" || ! -d "$global_bin" ]]; then
    global_bin="${HOME}/.pixi/bin"
  fi
  if [[ -x "${global_bin}/cmake.exe" && -x "${global_bin}/ninja.exe" ]]; then
    printf '%s\n' "$global_bin"
    return 0
  fi
  # cmake/ninja may be exposed without .exe suffix via pixi global shims
  if command -v cmake >/dev/null 2>&1 && command -v ninja >/dev/null 2>&1; then
    printf '%s\n' "$global_bin"
    return 0
  fi

  return 1
}

run_pixi_build_task() {
  local task_name="$1" pixi_cmd="" manifest_path=""

  manifest_path="$(shared_pixi_manifest_path)"

  if [[ ! -f "$manifest_path" ]]; then
    echo "Error: shared Pixi manifest not found at $manifest_path" >&2
    return 1
  fi

  if ! pixi_cmd="$(resolve_pixi_command)"; then
    echo "Error: pixi is not available in this shell." >&2
    echo "Hint: run 'kog self install-prereq' first." >&2
    return 1
  fi

  run_with_progress "build.sh" "$pixi_cmd" run --manifest-path "$manifest_path" "$task_name"
}


make_self_build_log_path() {
  local mode="${1:-build}"
  local log_dir="$PROJECT_ROOT/.kano/tmp/build"
  mkdir -p "$log_dir"
  printf '%s/self-%s-%s-%s.log\n' "$log_dir" "$mode" "$(date -u +%Y%m%dT%H%M%SZ 2>/dev/null || date +%s)" "$$"
}

looks_like_dependency_fetch_failure() {
  local log_file="$1"
  [[ -f "$log_file" ]] || return 1

  grep -Eqi \
    'FetchContent|GIT_REPOSITORY|github\.com|git clone|Failed to clone repository|Could not resolve host|Could not resolve proxy|Failed to connect|Network is unreachable|Operation timed out|Connection timed out|TLS|GnuTLS|SSL|unable to access .+https?://|The requested URL returned error' \
    "$log_file"
}

print_dependency_fetch_failure_hint() {
  local log_file="$1"
  cat >&2 <<EOF

Dependency fetch appears to have failed during native self build.
This is expected when the build runs in an offline or DNS-restricted environment.

Default source mode uses CMake FetchContent and may fetch third-party libraries
from GitHub, such as nlohmann/json, CLI11, FTXUI, toml++, Catch2, or rapidcheck.

This does not indicate a launcher or shared-infra script failure.
Use one of these paths:
  - Re-run with network access for normal developer builds.
  - Use system/submodule source modes where available for controlled CI.
  - Add a future vendor/offline dependency cache if offline self build is required.

Build log:
  $log_file
EOF
}

print_generic_self_build_failure_hint() {
  local log_file="$1"
  cat >&2 <<EOF

Self build failed. Check the build log before assuming the launcher is broken.

Build log:
  $log_file

Prerequisites may be missing. To install them manually, run:
  kog self install-prereq
EOF
}

apply_launcher_env_overrides() {
  local arg
  for arg in "$@"; do
    case "$arg" in
      --allow-ignore-gate)
        KOG_ALLOW_IGNORE_GATE=1
        export KOG_ALLOW_IGNORE_GATE
        ;;
    esac
  done
}

has_help_request_arg() {
  local arg
  for arg in "$@"; do
    case "$arg" in
      -h|--help|help)
        return 0
        ;;
    esac
  done
  return 1
}

is_lightweight_query_command() {
  local -a args=("$@")
  local cmd="${args[0]:-}"
  if [[ "$cmd" == "--version" || "$cmd" == "-v" || "$cmd" == "version" ]]; then
    return 0
  fi
  if has_help_request_arg "${args[@]}"; then
    return 0
  fi
  return 1
}

maybe_alias_self_shortcuts() {
  local -n out_args_ref="$1"
  local cmd="${out_args_ref[0]:-}"
  local -a rest=()
  if ((${#out_args_ref[@]} > 1)); then
    rest=("${out_args_ref[@]:1}")
  fi

  case "$cmd" in
    sb)
      out_args_ref=("self" "build" "${rest[@]}")
      log_launcher_status "alias-self" "ok" "map sb -> self build"
      ;;
    srb)
      out_args_ref=("self" "rebuild" "${rest[@]}")
      log_launcher_status "alias-self" "ok" "map srb -> self rebuild"
      ;;
  esac
}

apply_agent_mode_from_args() {
  local arg next
  next=""

  if [[ "${KANO_AGENT_MODE:-}" == "1" || "${KANO_AGENT_MODE:-}" == "true" ]]; then
    return 0
  fi

  for arg in "$@"; do
    if [[ "$next" == "agent" ]]; then
      if [[ -n "$arg" && "$arg" != "manual" ]]; then
        export KANO_AGENT_MODE=1
        return 0
      fi
      next=""
      continue
    fi

    case "$arg" in
      --agent)
        next="agent"
        ;;
      --agent=*)
        local agent_value="${arg#--agent=}"
        if [[ -n "$agent_value" && "$agent_value" != "manual" ]]; then
          export KANO_AGENT_MODE=1
          return 0
        fi
        ;;
    esac
  done
}

clean_native_build_artifacts() {
  remove_tree_best_effort() {
    local target_path="$1"
    [[ -e "$target_path" ]] || return 0

    if rm -rf "$target_path" ; then
      return 0
    fi

    sleep 0.1
    rm -rf "$target_path"  || true

    if [[ -e "$target_path" ]]; then
      log_launcher_status "build-native" "warn" "cleanup skipped (path still exists): $target_path"
    fi
  }

  local preset
  local base_build="$PROJECT_ROOT/src/cpp/build"

  while IFS= read -r preset; do
    [[ -z "$preset" ]] && continue
    remove_tree_best_effort "$base_build/_intermediate/$preset"
    remove_tree_best_effort "$base_build/bin/$preset"
    remove_tree_best_effort "$base_build/lib/$preset"
  done < <(candidate_presets)

  remove_tree_best_effort "$base_build/release"
  remove_tree_best_effort "$base_build/debug"
}

prepare_cpp_build_submodules() {
  local context_label="${1:-build-native}"
  local -a discovered_paths update_paths
  local line path abs_path status_line state

  if [[ ! -f "$PROJECT_ROOT/.gitmodules" ]]; then
    return 0
  fi

  if ! command -v git >/dev/null 2>&1; then
    echo "Error: git command not found; cannot prepare required submodules." >&2
    return 1
  fi

  log_launcher_status "$context_label" "step" "prepare-submodules"

  local -a discovered_paths=()
  local -a update_paths=()
  # Discover explicitly vendored/forked C++ dependencies from .gitmodules dynamically.
  # Only dependencies intentionally kept as submodules under src/cpp/code/thirdparty/
  # should be prepared here. Upstream third-party libraries that can be consumed
  # unmodified should use CMake FetchContent/_deps instead.
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    path="${line#* }"
    if [[ "$path" == src/cpp/code/thirdparty/* ]]; then
      discovered_paths+=("$path")
    fi
  done < <(git -C "$PROJECT_ROOT" config -f .gitmodules --get-regexp '^submodule\..*\.path$'  || true)

  if [[ "${#discovered_paths[@]}" -eq 0 ]]; then
    log_launcher_status "$context_label" "ok" "no vendored C++ thirdparty submodules registered in .gitmodules"
    return 0
  fi

  for path in "${discovered_paths[@]}"; do
    abs_path="$PROJECT_ROOT/$path"
    status_line="$(git -C "$PROJECT_ROOT" submodule status -- "$path"  || true)"
    state="${status_line:0:1}"

    if [[ "$state" == "-" && -d "$abs_path" ]]; then
      if find "$abs_path" -mindepth 1 -print -quit  | grep -q .; then
        log_launcher_status "$context_label" "warn" "removing stale uninitialized submodule dir: $path"
        rm -rf "$abs_path" || {
          echo "Error: failed to clean stale submodule directory: $path" >&2
          return 1
        }
      fi
    fi

    if [[ -z "$status_line" ]]; then
      continue
    fi

    update_paths+=("$path")
  done

  if [[ "${#update_paths[@]}" -eq 0 ]]; then
    log_launcher_status "$context_label" "ok" "no registered C++ submodules to prepare"
    return 0
  fi

  (
    cd "$PROJECT_ROOT"
    git submodule sync -- "${update_paths[@]}" >/dev/null
    git submodule update --init --recursive -- "${update_paths[@]}"
  ) || {
    echo "Error: failed to initialize required vendored C++ thirdparty submodules." >&2
    echo "Hint: run 'git submodule update --init --recursive -- src/cpp/code/thirdparty/*' and retry only for intentionally forked/customized dependencies." >&2
    return 1
  }

  log_launcher_status "$context_label" "ok" "submodules ready"
  return 0
}

check_build_prerequisites() {
  local os_name="" missing=""
  os_name="$(platform_name)"

  if [[ "$os_name" == "windows" ]]; then
    if ! resolve_pixi_command >/dev/null 2>&1; then
      missing="$missing pixi"
    fi
    if ! windows_pixi_build_bin_dir >/dev/null 2>&1; then
      missing="$missing pixi env (cmake+ninja)"
    fi

    if [[ -n "$missing" ]]; then
      echo "Missing or broken build tools:$missing" >&2
      echo "" >&2
      echo "To install prerequisites, run:" >&2
      echo "  kog self install-prereq" >&2
      return 1
    fi

    return 0
  fi

  # Check cmake
  if ! command -v cmake >/dev/null 2>&1; then
    missing="$missing cmake"
  elif ! cmake --version >/dev/null 2>&1; then
    missing="$missing cmake (broken)"
  fi

  # Check ninja
  if ! command -v ninja >/dev/null 2>&1; then
    missing="$missing ninja"
  elif ! ninja --version >/dev/null 2>&1; then
    missing="$missing ninja (broken)"
  fi

  if [[ -n "$missing" ]]; then
    echo "Missing or broken build tools:$missing" >&2
    echo "" >&2
    echo "To install prerequisites, run:" >&2
    echo "  ./kog self install-prereq" >&2
    return 1
  fi

  return 0
}

run_native_build_mode() {
  local mode="$1"
  local build_task
  local prereq_script build_script prereq_stamp prereq_interval now_epoch last_epoch cooldown_left os_name

  ensure_windows_build_runtime_paths
  prepare_cpp_build_submodules "build-native" || return 1
  os_name="$(platform_name)"

  if ! mapfile -t _scripts < <(script_paths); then
    echo "Error: no native build scripts for platform $(platform_name) ($(arch_name))." >&2
    return 1
  fi

  prereq_script="${_scripts[0]:-}"
  build_script="${_scripts[1]:-}"
  if [[ -z "$prereq_script" || -z "$build_script" ]]; then
    echo "Error: missing native build script mapping for this platform." >&2
    return 1
  fi

  case "$mode" in
    incremental)
      log_launcher_status "build-native" "start" "mode=incremental"
      ;;
    incremental-debug)
      log_launcher_status "build-native" "start" "mode=incremental-debug"
      ;;
    incremental-pgo)
      log_launcher_status "build-native" "start" "mode=incremental-pgo"
      ;;
    full)
      log_launcher_status "build-native" "start" "mode=full"
      log_launcher_status "build-native" "step" "clean-artifacts"
      clean_native_build_artifacts
      ;;
    full-debug)
      log_launcher_status "build-native" "start" "mode=full-debug"
      log_launcher_status "build-native" "step" "clean-artifacts"
      clean_native_build_artifacts
      ;;
    full-pgo)
      log_launcher_status "build-native" "start" "mode=full-pgo"
      log_launcher_status "build-native" "step" "clean-artifacts"
      clean_native_build_artifacts
      ;;
    *)
      echo "Error: unsupported build mode: $mode (expected: incremental|full)" >&2
      return 2
      ;;
  esac

  # Pre-check: verify toolchain availability before attempting build
  if ! check_build_prerequisites; then
    log_launcher_status "build-native" "fail" "prerequisites missing"
    return 1
  fi

  local build_log
  build_log="$(make_self_build_log_path "$mode")"

  if [[ "$os_name" == "windows" ]]; then
    case "$mode" in
      *-debug) build_task="build-debug" ;;
      *-pgo)   build_task="pgo-rebuild" ;;
      *)        build_task="build-release" ;;
    esac
    if run_pixi_build_task "$build_task" 2>&1 | tee "$build_log"; then
      log_launcher_status "build-native" "ok" "build completed via pixi task=$build_task"
    else
      log_launcher_status "build-native" "fail" "build failed via pixi task=$build_task"
      if looks_like_dependency_fetch_failure "$build_log"; then
        print_dependency_fetch_failure_hint "$build_log"
      else
        print_generic_self_build_failure_hint "$build_log"
      fi
      return 1
    fi
  elif run_shell_script "$build_script" 2>&1 | tee "$build_log"; then
    log_launcher_status "build-native" "ok" "build completed"
  else
    log_launcher_status "build-native" "fail" "build failed"
    if looks_like_dependency_fetch_failure "$build_log"; then
      print_dependency_fetch_failure_hint "$build_log"
    else
      print_generic_self_build_failure_hint "$build_log"
    fi
    return 1
  fi

  local binary
  case "$mode" in
    *-debug)
      # For debug builds, report the debug binary directly
      local os_name_bin
      os_name_bin="$(platform_name)"
      local exe_name_bin
      [[ "$os_name_bin" == "windows" ]] && exe_name_bin="kano-git.exe" || exe_name_bin="kano-git"
      local debug_bin="$PROJECT_ROOT/src/cpp/out/bin/windows-ninja-msvc/debug/$exe_name_bin"
      if [[ -f "$debug_bin" ]]; then
        echo "Debug binary ready: $debug_bin"
        echo "  Use: KANO_GIT_BINARY_PATH=$debug_bin kog <command>"
        return 0
      fi
      ;;
  esac
  binary="$(find_binary || true)"
  if [[ -n "$binary" && -f "$binary" ]]; then
    echo "Native binary ready: $binary"
    return 0
  fi

  echo "Warning: build finished but binary path could not be resolved." >&2
  return 1
}

maybe_handle_launcher_build_request() {
  if [[ "$#" -eq 0 ]]; then
    return 1
  fi

  local first="$1"
  shift || true
  local mode=""
  local debug_mode=0
  local pgo_mode=0
  local extra

  case "$first" in
    build)
      mode="incremental"
      ;;
    rebuild)
      mode="full"
      ;;
    *)
      return 1
      ;;
  esac

  for extra in "$@"; do
    case "$extra" in
      --pgo)
        pgo_mode=1
        ;;
      --debug)
        debug_mode=1
        ;;
      --llvm)
        KOG_BUILD_USE_LLVM="1"
        ;;
      --modules)
        KOG_BUILD_ENABLE_MODULES="1"
        ;;
      --no-modules)
        KOG_BUILD_ENABLE_MODULES="0"
        ;;
      --apple-clang)
        KOG_BUILD_USE_LLVM="0"
        ;;
      *)
        echo "Error: unsupported build option: $extra" >&2
        echo "Hint: supported options are --debug, --pgo, --llvm, --apple-clang, --modules, --no-modules" >&2
        return 2
        ;;
    esac
  done

  if [[ "$pgo_mode" -eq 1 ]]; then
    mode="${mode}-pgo"
  elif [[ "$debug_mode" -eq 1 ]]; then
    mode="${mode}-debug"
  fi

  run_native_build_mode "$mode"
  return $?
}

manual_self_update_shell() {
  local repo_root="$1"
  local preferred_remote="$2"
  local auto_sync="$3"
  local non_interactive="$4"
  local remote="" branch="" ahead_raw="" ahead_count=0

  if [[ "$(git -C "$repo_root" rev-parse --is-inside-work-tree  || true)" != "true" ]]; then
    echo "Error: self update requires a git worktree: $repo_root" >&2
    return 1
  fi

  if [[ -n "$(git -C "$repo_root" status --porcelain  || true)" ]]; then
    echo "Error: self update aborted: dirty worktree in $repo_root" >&2
    echo "Hint: commit/stash/discard changes before running 'kog self update'." >&2
    return 1
  fi

  if [[ -n "$preferred_remote" ]] && git -C "$repo_root" remote get-url "$preferred_remote" >/dev/null 2>&1; then
    remote="$preferred_remote"
  elif git -C "$repo_root" remote get-url upstream >/dev/null 2>&1; then
    remote="upstream"
  elif git -C "$repo_root" remote get-url origin >/dev/null 2>&1; then
    remote="origin"
  else
    echo "Error: no git remote found for self update." >&2
    return 1
  fi

  echo "[self-update] fetching from remote: $remote" >&2
  git -C "$repo_root" fetch "$remote" --prune >/dev/null

  branch="$(git -C "$repo_root" symbolic-ref --quiet --short "refs/remotes/$remote/HEAD"  || true)"
  if [[ -n "$branch" ]]; then
    branch="${branch#${remote}/}"
  else
    branch="$(git -C "$repo_root" rev-parse --abbrev-ref HEAD  || true)"
  fi
  if [[ -z "$branch" ]]; then
    echo "Error: unable to resolve target branch for self update." >&2
    return 1
  fi

  ahead_raw="$(git -C "$repo_root" rev-list --count "HEAD..$remote/$branch"  || true)"
  if [[ "$ahead_raw" =~ ^[0-9]+$ ]]; then
    ahead_count="$ahead_raw"
  fi
  if [[ "$ahead_count" -le 0 ]]; then
    echo "[self-update] already up to date: $remote/$branch" >&2
    return 0
  fi

  local should_sync=0
  if [[ "$auto_sync" == "1" ]]; then
    should_sync=1
  elif [[ "$non_interactive" == "1" || "${KANO_AGENT_MODE:-0}" == "1" ]]; then
    should_sync=0
  elif is_interactive_terminal && maybe_prompt_yes_no "[self-update] Found ${ahead_count} commit(s) on ${remote}/${branch}. Sync now?"; then
    should_sync=1
  fi

  if [[ "$should_sync" != "1" ]]; then
    echo "[self-update] updates available (${ahead_count}) but not applied." >&2
    return 0
  fi

  echo "[self-update] syncing with rebase: $remote/$branch" >&2
  git -C "$repo_root" rebase "$remote/$branch"
  return $?
}

maybe_handle_manual_self_request() {
  if [[ "$#" -lt 2 ]]; then
    return 1
  fi

  local first="$1"
  local second="$2"
  shift 2 || true

  if [[ "$first" != "self" ]]; then
    return 1
  fi

  case "$second" in
    build|rebuild)
      maybe_handle_launcher_build_request "$second" "$@"
      return $?
      ;;
    install-prereq)
      if ! mapfile -t _prereq_scripts < <(script_paths); then
        echo "Error: no native build scripts for platform $(platform_name) ($(arch_name))." >&2
        return 1
      fi
      local prereq_script="${_prereq_scripts[0]:-}"
      if [[ -z "$prereq_script" ]]; then
        echo "Error: missing prerequisite script for this platform." >&2
        return 1
      fi
      run_shell_script "$prereq_script" || {
        log_launcher_status "install-prereq" "fail" "prerequisite install failed"
        return 1
      }
      log_launcher_status "install-prereq" "ok" "prerequisites installed"
      return 0
      ;;
    update)
      local binary=""
      local remote="upstream"
      local auto_sync="0"
      local non_interactive="0"
      local arg
      while [[ "$#" -gt 0 ]]; do
        arg="$1"
        shift || true
        case "$arg" in
          --remote)
            if [[ "$#" -gt 0 ]]; then
              remote="$1"
              shift || true
            fi
            ;;
          --remote=*)
            remote="${arg#--remote=}"
            ;;
          --auto-sync)
            auto_sync="1"
            ;;
          --non-interactive)
            non_interactive="1"
            ;;
        esac
      done
      if ! binary="$(find_existing_binary )"; then
        echo "Warning: native binary unavailable; using shell fallback for self update." >&2
        manual_self_update_shell "$PROJECT_ROOT" "$remote" "$auto_sync" "$non_interactive" || return $?
        prepare_cpp_build_submodules "self-update" || return $?
        echo "[self-update] bootstrap ready: required C++ submodules are prepared for self build." >&2
        return 0
      fi
      local -a native_args=("self" "update-check" "--repo" "$PROJECT_ROOT" "--mode" "auto" "--remote" "$remote")
      [[ "$auto_sync" == "1" ]] && native_args+=("--auto-update")
      [[ "$non_interactive" == "1" ]] && native_args+=("--non-interactive")
      run_native_binary "$binary" "${native_args[@]}"
      return $?
      ;;
    *)
      return 1
      ;;
  esac
}

append_once_to_file() {
  local file="$1"
  local marker="$2"
  local content="$3"

  mkdir -p "$(dirname "$file")"
  touch "$file"

  if grep -Fq "$marker" "$file" ; then
    return 0
  fi

  printf '\n%s\n' "$content" >> "$file"
}

remove_block_from_file() {
  local file="$1"
  local block_start="$2"
  local block_end="$3"
  local tmp_file

  [[ -f "$file" ]] || return 0

  tmp_file="${file}.tmp.$$"
  awk -v start="$block_start" -v end="$block_end" '
    $0 == start { skip=1; next }
    skip && $0 == end { skip=0; next }
    !skip { print }
  ' "$file" > "$tmp_file"
  mv "$tmp_file" "$file"
}

install_bash_completion() {
  local binary="$1"
  local completion_dir completion_file bash_rc source_block block_start block_end

  completion_dir="${HOME}/.local/share/bash-completion/completions"
  completion_file="$completion_dir/kog"
  bash_rc="${HOME}/.bashrc"
  block_start="# >>> kano-git completion hook >>>"
  block_end="# <<< kano-git completion hook <<<"

  mkdir -p "$completion_dir"
  KANO_GIT_MASTER_ROOT="${KANO_GIT_MASTER_ROOT:-$PROJECT_ROOT}" "$binary" completion bash > "$completion_file"
  chmod 0644 "$completion_file"  || true

  source_block=$(cat <<EOF
$block_start
if [[ -r "$completion_file" ]]; then
  source "$completion_file"
fi
$block_end
EOF
)
  append_once_to_file "$bash_rc" "$block_start" "$source_block"

  echo "Bash completion installed: $completion_file"
  echo "Completion/profile hooks are launcher-owned. PATH is not modified here."
  echo "Reload shell with: source $bash_rc"
}

uninstall_bash_completion() {
  local completion_file bash_rc block_start block_end

  completion_file="${HOME}/.local/share/bash-completion/completions/kog"
  bash_rc="${HOME}/.bashrc"
  block_start="# >>> kano-git completion hook >>>"
  block_end="# <<< kano-git completion hook <<<"

  rm -f "$completion_file"
  remove_block_from_file "$bash_rc" "$block_start" "$block_end"

  echo "Bash completion removed: $completion_file"
  echo "Completion/profile hooks are launcher-owned. PATH is not modified here."
  echo "Reload shell with: source $bash_rc"
}

maybe_handle_completion_management_request() {
  if [[ "$#" -eq 0 ]]; then
    return 1
  fi

  local first="$1"
  local second="${2:-}"
  local third="${3:-}"
  local action=""
  local shell_name=""
  local binary=""

  case "$first" in
    completion-install)
      action="install"
      shell_name="${second:-bash}"
      ;;
    completion-uninstall)
      action="uninstall"
      shell_name="${second:-bash}"
      ;;
    completion)
      if [[ "$second" != "install" && "$second" != "uninstall" ]]; then
        return 1
      fi
      action="$second"
      shell_name="${third:-bash}"
      ;;
    *)
      return 1
      ;;
  esac

  if [[ "$shell_name" != "bash" ]]; then
    echo "Error: completion install currently supports bash only." >&2
    echo "Hint: use './kog completion install bash' or './kog completion uninstall bash'" >&2
    return 2
  fi

  if [[ "$action" == "uninstall" ]]; then
    uninstall_bash_completion
    return 0
  fi

  binary="$(find_binary || true)"
  if [[ -z "$binary" || ! -f "$binary" ]]; then
    echo "Error: native binary unavailable; cannot install completion." >&2
    echo "Hint: run './kog self build' first." >&2
    return 1
  fi

  if [[ ! -x "$binary" ]]; then
    chmod u+x "$binary" >/dev/null 2>&1 || true
  fi

  install_bash_completion "$binary"
  return 0
}

platform_name() {
  local os_name
  os_name="$(uname -s  || true)"
  case "$os_name" in
    Darwin*) echo "macos" ;;
    Linux*) echo "linux" ;;
    MINGW*|MSYS*|CYGWIN*|Windows_NT) echo "windows" ;;
    *) echo "${os_name,,}" ;;
  esac
}

is_wsl_shell() {
  if [[ -n "${WSL_DISTRO_NAME:-}" || -n "${WSL_INTEROP:-}" ]]; then
    return 0
  fi
  if [[ "$(uname -s  || true)" != "Linux" ]]; then
    return 1
  fi
  if [[ -r "/proc/version" ]] && grep -qi "microsoft" /proc/version ; then
    return 0
  fi
  return 1
}

is_binary_compatible_with_shell() {
  return 0
}

ensure_binary_shell_compatibility() {
  local binary="$1"
  local allow_cross="${KOG_ALLOW_CROSS_PLATFORM_BINARY:-0}"

  if is_binary_compatible_with_shell "$binary"; then
    return 0
  fi
  if [[ "$allow_cross" == "1" ]]; then
    return 0
  fi

  if is_wsl_shell && [[ "$binary" == *.exe ]]; then
    echo "Error: detected Windows .exe binary in WSL shell: $binary" >&2
    echo "Hint: WSL is Linux runtime. Build/use Linux binary, or run this command in Git Bash/Cygwin on Windows." >&2
    echo "Hint: set KOG_ALLOW_CROSS_PLATFORM_BINARY=1 only for one-off debugging." >&2
    return 1
  fi

  echo "Error: binary/shell platform mismatch: $binary" >&2
  echo "Hint: use a shell matching the target binary platform (Windows shell for .exe, Linux/macOS shell for native)." >&2
  echo "Hint: set KOG_ALLOW_CROSS_PLATFORM_BINARY=1 only for one-off debugging." >&2
  return 1
}

arch_name() {
  local machine
  machine="$(uname -m  || true)"
  case "$machine" in
    arm64|aarch64) echo "arm64" ;;
    *) echo "x64" ;;
  esac
}

candidate_presets() {
  local os_name arch
  os_name="$(platform_name)"
  arch="$(arch_name)"
  case "$os_name" in
    windows)
      if [[ "$arch" == "arm64" ]]; then
        printf '%s\n' "windows-ninja-msvc-arm64" "windows-ninja-msvc"
      else
        printf '%s\n' "windows-ninja-msvc"
      fi
      ;;
    linux)
      printf '%s\n' "linux-ninja-gcc"
      ;;
    macos)
      if [[ "$arch" == "arm64" ]]; then
        printf '%s\n' "macos-ninja-clang-arm64" "macos-ninja-clang" "macos-ninja-llvm-arm64" "macos-make-clang-arm64" "macos-make-llvm-arm64"
      else
        printf '%s\n' "macos-ninja-clang-x64" "macos-ninja-clang" "macos-ninja-llvm-x64" "macos-make-clang-x64" "macos-make-llvm-x64"
      fi
      ;;
  esac
}

to_windows_path() {
  local p="$1"
  if command -v cygpath >/dev/null 2>&1; then
    cygpath -w "$p"  && return 0
  fi
  if [[ "$p" =~ ^/mnt/([a-zA-Z])/(.*)$ ]]; then
    local drive="${BASH_REMATCH[1]}"
    local rest="${BASH_REMATCH[2]}"
    rest="${rest//\//\\}"
    printf '%s:\\%s\n' "${drive^^}" "$rest"
    return 0
  fi
  if [[ "$p" =~ ^([A-Za-z]):[\\/] ]]; then
    printf '%s\n' "$p"
    return 0
  fi
  return 1
}

find_bash() {
  if command -v bash >/dev/null 2>&1; then
    command -v bash
    return 0
  fi

  if [[ -n "${GIT_BASH_PATH:-}" && -f "${GIT_BASH_PATH}" ]]; then
    printf '%s\n' "$GIT_BASH_PATH"
    return 0
  fi

  if [[ -f "C:/Program Files/Git/bin/bash.exe" ]]; then
    printf '%s\n' "C:/Program Files/Git/bin/bash.exe"
    return 0
  fi

  return 1
}

find_binary() {
  local exe_name build_dir candidate preset resolved_path resolved_dir os_name arch
  os_name="$(platform_name)"
  arch="$(arch_name)"
  case "$os_name" in
    windows) exe_name="kano-git.exe" ;;
    *) exe_name="kano-git" ;;
  esac
  local build_dirs=("$PROJECT_ROOT/src/cpp/out" "$PROJECT_ROOT/src/cpp/build" "$PROJECT_ROOT/build"); local bdir

  local find_start now elapsed
  find_start="$(current_epoch)"

  if [[ -n "${KANO_GIT_BINARY_PATH:-}" ]]; then
    if [[ -f "$KANO_GIT_BINARY_PATH" ]]; then
      if is_binary_compatible_with_shell "$KANO_GIT_BINARY_PATH"; then
        printf '%s\n' "$KANO_GIT_BINARY_PATH"
        return 0
      fi
    fi
    if [[ -f "$KANO_GIT_BINARY_PATH/$exe_name" ]]; then
      if is_binary_compatible_with_shell "$KANO_GIT_BINARY_PATH/$exe_name"; then
        printf '%s\n' "$KANO_GIT_BINARY_PATH/$exe_name"
        return 0
      fi
    fi
  fi

  if [[ -n "${KANO_GIT_BIN:-}" ]]; then
    if [[ -f "$KANO_GIT_BIN" ]]; then
      if is_binary_compatible_with_shell "$KANO_GIT_BIN"; then
        printf '%s\n' "$KANO_GIT_BIN"
        return 0
      fi
    fi
    if [[ -f "$KANO_GIT_BIN/$exe_name" ]]; then
      if is_binary_compatible_with_shell "$KANO_GIT_BIN/$exe_name"; then
        printf '%s\n' "$KANO_GIT_BIN/$exe_name"
        return 0
      fi
    fi
  fi

  candidate="$PROJECT_ROOT/bin/$exe_name"
  [[ -f "$candidate" ]] && is_binary_compatible_with_shell "$candidate" && { printf '%s\n' "$candidate"; return 0; }

  for bdir in "${build_dirs[@]}"; do
    [[ -d "$bdir" ]] || continue

    while IFS= read -r preset; do
      [[ -z "$preset" ]] && continue
      candidate="$bdir/bin/$preset/release/$exe_name"
      now="$(current_epoch)"; elapsed=$((now - find_start))
      echo "[$elapsed ms] Checking: $candidate" >&2
      if [[ -f "$candidate" ]]; then
        if is_binary_compatible_with_shell "$candidate" ]; then
          printf '%s\n' "$candidate"
          return 0
        fi
      fi
      candidate="$bdir/bin/$preset/debug/$exe_name"
      now="$(current_epoch)"; elapsed=$((now - find_start))
      echo "[$elapsed ms] Checking: $candidate" >&2
      if [[ -f "$candidate" ]]; then
        if is_binary_compatible_with_shell "$candidate" ]; then
          printf '%s\n' "$candidate"
          return 0
        fi
      fi
    done < <(candidate_presets)

    candidate="$bdir/release/$exe_name"
    now="$(current_epoch)"; elapsed=$((now - find_start))
    echo "[$elapsed ms] Checking: $candidate" >&2
    [[ -f "$candidate" ]] && is_binary_compatible_with_shell "$candidate" && { printf '%s\n' "$candidate"; return 0; }
    candidate="$bdir/debug/$exe_name"
    now="$(current_epoch)"; elapsed=$((now - find_start))
    echo "[$elapsed ms] Checking: $candidate" >&2
    [[ -f "$candidate" ]] && is_binary_compatible_with_shell "$candidate" && { printf '%s\n' "$candidate"; return 0; }
  done

  if command -v kano-git >/dev/null 2>&1; then
    resolved_path="$(command -v kano-git)"
    if [[ -n "$resolved_path" ]]; then
      resolved_dir="$(cd "$(dirname "$resolved_path")" && pwd)"
      resolved_path="$resolved_dir/$(basename "$resolved_path")"
      if [[ "$resolved_path" != "$SCRIPT_DIR/kano-git" ]]; then
        if is_binary_compatible_with_shell "$resolved_path"; then
          printf '%s\n' "$resolved_path"
          return 0
        fi
      fi
    fi
  fi

  return 1
}

find_existing_binary() {
  local binary=""
  if ! binary="$(find_binary )"; then
    return 1
  fi
  [[ -n "$binary" && -f "$binary" ]] || return 1
  printf '%s\n' "$binary"
}

script_paths() {
  local base os_name arch prereq build
  base="$PROJECT_ROOT/src/cpp/shared/infra/scripts"
  os_name="$(platform_name)"
  arch="$(arch_name)"

  case "$os_name" in
    windows)
      prereq="$base/stages/prerequisite-windows.sh"
      build="$base/self/build.sh"
      ;;
    linux)
      prereq="$base/stages/prerequisite-linux.sh"
      build="$base/self/build.sh"
      ;;
    macos)
      prereq="$base/stages/prerequisite-macos.sh"
      build="$base/self/build.sh"
      ;;
    *)
      return 1
      ;;
  esac

  printf '%s\n%s\n' "$prereq" "$build"
}

fallback_install_state_file() {
  if [[ -n "${KANO_GIT_INSTALL_STATE_FILE:-}" ]]; then
    printf '%s\n' "$KANO_GIT_INSTALL_STATE_FILE"
  else
    printf '%s\n' "${HOME}/.kano/git/kog-install-state.json"
  fi
}

install_state_file() {
  local binary="" state_file=""
  if binary="$(find_existing_binary )"; then
    state_file="$(run_native_binary "$binary" self install-state-path  || true)"
    state_file="$(printf '%s' "$state_file" | tr -d '\r' | tail -n 1)"
    if [[ -n "$state_file" ]]; then
      printf '%s\n' "$state_file"
      return 0
    fi
  fi
  fallback_install_state_file
}

is_packaged_install() {
  local binary=""
  if binary="$(find_existing_binary )"; then
    run_native_binary "$binary" self is-packaged >/dev/null 2>&1
    local status=$?
    if [[ "$status" -eq 0 || "$status" -eq 1 ]]; then
      return "$status"
    fi
  fi
  local state_file
  state_file="$(fallback_install_state_file)"
  [[ -f "$state_file" ]]
}

run_shell_script() {
  local script bash_path start end elapsed
  local script_name
  script="$1"
  shift || true
  script_name="$(basename "$script")"
  if ! bash_path="$(find_bash)"; then
    echo "Warning: bash not found; cannot run shell script automation." >&2
    return 1
  fi
  if [[ ! -f "$script" ]]; then
    echo "Warning: script not found: $script" >&2
    return 1
  fi

  start="$(current_epoch)"
  log_launcher_status "$script_name" "start" "args=$*"

  if [[ "$script_name" == prerequisite_* ]]; then
    if env KANO_GIT_MASTER_ROOT="${KANO_GIT_MASTER_ROOT:-$PROJECT_ROOT}" KOG_BUILD_USE_LLVM="$KOG_BUILD_USE_LLVM" KOG_BUILD_ENABLE_MODULES="$KOG_BUILD_ENABLE_MODULES" "$bash_path" "$script" "$@"; then
      end="$(current_epoch)"
      elapsed=$((end - start))
      log_launcher_status "$script_name" "ok" "elapsed=${elapsed}s"
      return 0
    fi
  elif run_with_progress "$script_name" env KANO_GIT_MASTER_ROOT="${KANO_GIT_MASTER_ROOT:-$PROJECT_ROOT}" KOG_BUILD_USE_LLVM="$KOG_BUILD_USE_LLVM" KOG_BUILD_ENABLE_MODULES="$KOG_BUILD_ENABLE_MODULES" "$bash_path" "$script" "$@"; then
    end="$(current_epoch)"
    elapsed=$((end - start))
    log_launcher_status "$script_name" "ok" "elapsed=${elapsed}s"
    return 0
  fi

  end="$(current_epoch)"
  elapsed=$((end - start))
  log_launcher_status "$script_name" "fail" "elapsed=${elapsed}s"
  return 1
}

print_launcher_help_extras() {
  cat >&2 <<'EOF'

Launcher commands:
  self build                          Build native binary (incremental; may fetch C++ dependencies from GitHub)
    --debug                           Build Debug binary instead of Release (fast iteration)
    --pgo                             Build with PGO (collect → gather → merge → use); replaces release binary
  self rebuild                        Rebuild native binary (full clean rebuild; may fetch C++ dependencies from GitHub)
    --debug                           Rebuild Debug binary instead of Release
    --pgo                             Full clean PGO rebuild
  self install-prereq                 Install build prerequisites (CMake, Ninja, MSVC)
  self update                         Run manual launcher update check flow
                                      When native binary is unavailable, fallback sync also prepares required C++ submodules.
    --remote <name>                   Preferred remote (default: upstream, fallback origin)
    --auto-sync                       Apply update without prompt when commits are available
    --non-interactive                 Do not prompt; report availability only unless --auto-sync
  status                              Show dirty repositories across the workspace by default
    --all                             Show all repos instead of only dirty ones
  overview                            Show cached workspace repo overview without re-running discover
  discover                            Run manual repo discovery, refresh cache, and print cache file path
  plan new                           Write plan template from assets
    -ai, --ai-auto                    Generate and fill plan via one AI request
    --ai-provider <name>              AI provider for plan generation (codex|opencode|copilot|auto)
    --ai-model <name>                 AI model for plan generation
    --ignore-datasource-root <path>   Override plan meta ignore datasource root
    --ignore-datasource-manifest <p>  Override plan meta ignore datasource manifest
  plan apply                          Apply plan stages (default: all)
    --stage ignore|commit|all         Run only selected stage(s)
  plan verify pre-apply               Verify plan schema before apply
    --stage ignore|commit|all         Verify selected stage requirements
  plan verify post-apply              Verify apply result state after apply
    --stage ignore|commit|all         Verify selected stage results
  plan verify ignore                  Run ignore gate verification only
  plan verify secret                  Run secret gate verification only
  plan finish-report                        Print compact plan summary
    --max-commits <n>                 Limit printed commit lines (default: 10)
  plan refresh-check                  Exit 0 when plan should be regenerated
  plan ensure-prepare-ready          Ensure plan is prepared and AI-ready (fill + validate)
  plan runbook commit                 Run commit runbook (prepare + summary + validate)
  plan runbook ignore                 Run ignore runbook (init + pre-apply verify)
  plan runbook full                   Run full runbook (ignore + commit + pre-apply verify)
  plan datasource-sync                Update ignore-plan reference datasource (default: github-gitignore)
    --source github-gitignore         Datasource source id
    --dry-run                         Print revision metadata without updating
  ignore doctor                       Scan tracked files and suggest likely ignore candidates
    --repo <path>                     Limit scan root (default: current workspace)
    --limit <n>                       Max findings (default: 200)
    --json                            Output JSON
    --apply                           Apply untrack actions (git rm --cached) for findings
    --dry-run                         Print planned untrack actions only
    --yes                             Skip interactive confirmation for --apply
  pi ...                              Alias of plan new ...
  pia ...                             Alias of plan new --ai-auto ...
  ca ...                              Alias of commit --ai-auto
  cp ...                              Alias of commit-push (non-AI; no implicit --ai-auto)
  cpa ...                             Alias of commit-push --ai-auto
                                      AI planning/preflight/apply is handled by native command layer.
    --no-plan-auto                    Disable AI->plan auto routing
    --allow-ignore-gate               Bypass ignore gate for this run
    --llvm                            Use Homebrew LLVM clang/clang++ toolchain (macOS)
    --modules                         Enable C++20 modules (requires compatible toolchain)
    --no-modules                      Disable C++20 modules
  completion install bash             Install bash completion file and shell hook only
  completion uninstall bash           Remove launcher-owned bash completion file and hook
  completion-install bash             Alias of completion install bash
  completion-uninstall bash           Alias of completion uninstall bash
  sb ...                              Alias of self build ...
  srb ...                             Alias of self rebuild ...

MSI/package model:
  MSI install                         Per-user deployment to ~/.agents/skills/kano/kano-git-master-skill
                                      Optional ShellIntegration owns PATH only
                                      MSI install aborts if that fixed target already contains a manual repo checkout
  completion install/uninstall        Launcher-owned completion file and profile hook flow
                                      Does not modify PATH
  self install state                  Native-owned state at ~/.kano/git/kog-install-state.json

Launcher env:
  KANO_AGENT_MODE=1                Force non-interactive agent mode in launcher flows
  KOG_BUILD_USE_LLVM=0|1              Build with LLVM toolchain (macOS default: 1)
  KOG_BUILD_ENABLE_MODULES=0|1        Build with C++20 modules (macOS default: 1)
  KOG_PLAN_FILE=<path>                Default plan file used when AI flags are present
                                      AI mode enforces required plan fields before execution,
                                      including per-commit review (verdict=pass + reason)
  KOG_ALLOW_IGNORE_GATE=1             Bypass ignore gate (not recommended)
  KOG_GIT_INTERACTIVE=auto            Git prompt/editor mode: auto|1|0
                                      auto: agent mode -> non-interactive, human mode -> interactive
  KOG_DISABLE_SECRET_GATE=1           Disable secret gate (not recommended)
  KOG_IGNORE_GATE=off                 Disable ignore gate globally (not recommended)
                                      Static allowlist: assets/ignore-sources/local/ignore-gate-allowlist.txt
EOF
}

run_native_binary() {
  local binary="$1"
  shift || true

  local first="${1:-}"
  local arg_count=$#
  local -a native_args=("$@")
  local i arg next_is_plan_path converted

  if ! ensure_binary_shell_compatibility "$binary"; then
    return 2
  fi

  if [[ ! -x "$binary" ]]; then
    chmod u+x "$binary" >/dev/null 2>&1 || true
  fi

  if [[ "$binary" == *.exe ]]; then
    next_is_plan_path=0
    for ((i = 0; i < ${#native_args[@]}; i++)); do
      arg="${native_args[$i]}"
      if [[ "$next_is_plan_path" -eq 1 ]]; then
        if converted="$(to_windows_path "$arg" )"; then
          native_args[$i]="$converted"
        fi
        next_is_plan_path=0
        continue
      fi
      case "$arg" in
        --plan-file)
          next_is_plan_path=1
          ;;
        --plan-file=*)
          if converted="$(to_windows_path "${arg#--plan-file=}" )"; then
            native_args[$i]="--plan-file=$converted"
          fi
          ;;
      esac
    done
  fi

  local status=0
  if [[ -n "${KANO_AGENT_MODE:-}" ]]; then
    KANO_GIT_MASTER_ROOT="${KANO_GIT_MASTER_ROOT:-$PROJECT_ROOT}" \
    KANO_GIT_BINARY_PATH="$binary" \
    KANO_AGENT_MODE="$KANO_AGENT_MODE" \
    "$binary" "${native_args[@]}"
    status=$?
  else
    KANO_GIT_MASTER_ROOT="${KANO_GIT_MASTER_ROOT:-$PROJECT_ROOT}" \
    KANO_GIT_BINARY_PATH="$binary" \
    "$binary" "${native_args[@]}"
    status=$?
  fi

  if [[ "$status" -eq 0 ]]; then
    case "$first" in
      ""|-h|--help|help)
        if [[ "$arg_count" -le 1 ]]; then
          print_launcher_help_extras
        fi
        ;;
    esac
  fi

  return "$status"
}

main() {
  local binary marker
  local -a args=()
  local -a exec_args=()
  local explicit_bin=""

  args=("$@")
  apply_launcher_env_overrides "${args[@]}"
  apply_agent_mode_from_args "${args[@]}"

  # Fail fast when user explicitly points to an incompatible binary for current shell.
  if [[ -n "${KANO_GIT_BIN:-}" ]]; then
    explicit_bin="$KANO_GIT_BIN"
  elif [[ -n "${KANO_GIT_BINARY_PATH:-}" ]]; then
    explicit_bin="$KANO_GIT_BINARY_PATH"
  fi
  if [[ -n "$explicit_bin" && -e "$explicit_bin" ]]; then
    if ! ensure_binary_shell_compatibility "$explicit_bin"; then
      exit 2
    fi
  fi

  maybe_alias_self_shortcuts args

  if [[ "${args[0]:-}" == "self" ]]; then
    case "${args[1]:-}" in
      build|rebuild|update|install-prereq)
        maybe_handle_manual_self_request "${args[@]}"
        exit $?
        ;;
    esac
  fi

  local completion_status=0
  if maybe_handle_completion_management_request "${args[@]}"; then
    exit 0
  else
    completion_status=$?
  fi
  if [[ "$completion_status" -ne 1 ]]; then
    exit "$completion_status"
  fi

  exec_args=("${args[@]}")
  # Temporary launcher-side rewrite for cp/cpa.
  # Native alias routing is expected to handle this, but current native parser path
  # does not accept cp/cpa consistently. Keep shell behavior aligned with help text
  # until the native alias path is corrected.
  if [[ "${exec_args[0]:-}" == "ca" ]]; then
    exec_args=("commit" "--ai-auto" "${exec_args[@]:1}")
  elif [[ "${exec_args[0]:-}" == "cp" ]]; then
    exec_args=("commit-push" "${exec_args[@]:1}")
  elif [[ "${exec_args[0]:-}" == "cpa" ]]; then
    if [[ "${KANO_AGENT_MODE:-0}" == "1" || "${KANO_AGENT_MODE:-}" == "true" ]]; then
      exec_args=("commit-push" "--plan-file" "$PWD/.kano/tmp/git/plans/default-plan.json" "${exec_args[@]:1}")
    else
      exec_args=("commit-push" "--ai-auto" "${exec_args[@]:1}")
    fi
  fi

  # Manual mode: no auto-rebuild/auto-prepare in execution path.
  if binary="$(find_binary)"; then
    if [[ -n "$binary" && -f "$binary" ]]; then
      run_native_binary "$binary" "${exec_args[@]}"
      exit $?
    fi
  fi

  if is_lightweight_query_command "${exec_args[@]}"; then
    if has_help_request_arg "${exec_args[@]}"; then
      echo "kano-git native binary is not built for the current shell." >&2
      echo "Run './scripts/kog self build' from the repository root, then retry the native command." >&2
      print_launcher_help_extras
      exit 0
    fi
    echo "Error: no compatible native binary found for current shell." >&2
    echo "Hint: do not mix WSL shell with Windows .exe binary. Use Linux build in WSL, or run Git Bash/Cygwin for Windows build." >&2
    echo "Hint: run './kog self build' in the current shell environment." >&2
    exit 1
  fi

  if is_packaged_install; then
    marker="$(install_state_file)"
    echo "Error: kano-git packaged install state detected, but C++ binary is missing." >&2
    echo "Error: install state file: $marker" >&2
    echo "Error: this installation may be corrupted. Please reinstall the package." >&2
  else
    :
  fi

  echo "Error: strict native-only mode is enabled and C++ binary is unavailable." >&2
  echo "Error: shell fallback is disabled by design; auto build/update are disabled in manual mode." >&2
  echo "Hint: run './kog self build' (or './kog self rebuild') in this shell, then retry." >&2
  exit 1
}

main "$@"
