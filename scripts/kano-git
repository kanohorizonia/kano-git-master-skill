#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
PATH="$SCRIPT_DIR:$PATH"
LAUNCHER_STATE_DIR="$PROJECT_ROOT/.kano/launcher"
REBUILD_DIRECTION="unknown"
REBUILD_REASON=""
if [[ "$(uname -s 2>/dev/null || true)" == "Darwin" ]]; then
  KOG_BUILD_USE_LLVM="${KOG_BUILD_USE_LLVM:-1}"
  KOG_BUILD_ENABLE_MODULES="${KOG_BUILD_ENABLE_MODULES:-1}"
else
  KOG_BUILD_USE_LLVM="${KOG_BUILD_USE_LLVM:-0}"
  KOG_BUILD_ENABLE_MODULES="${KOG_BUILD_ENABLE_MODULES:-0}"
fi
KOG_ALLOW_IGNORE_GATE="${KOG_ALLOW_IGNORE_GATE:-0}"

is_interactive_terminal() {
  [[ -t 0 && -t 1 ]]
}

ensure_launcher_state_dir() {
  mkdir -p "$LAUNCHER_STATE_DIR"
}

state_file_for() {
  local name="$1"
  printf '%s/%s\n' "$LAUNCHER_STATE_DIR" "$name"
}

file_mtime_epoch() {
  local file="$1"
  if [[ ! -e "$file" ]]; then
    printf '%s\n' "0"
    return 0
  fi

  if stat -c %Y "$file" >/dev/null 2>&1; then
    stat -c %Y "$file"
    return 0
  fi

  if stat -f %m "$file" >/dev/null 2>&1; then
    stat -f %m "$file"
    return 0
  fi

  printf '%s\n' "0"
}

current_epoch() {
  date +%s 2>/dev/null || printf '%s\n' "0"
}

should_run_interval_check() {
  local stamp_file="$1"
  local interval_seconds="$2"
  local now last delta

  if [[ "$interval_seconds" -le 0 ]]; then
    return 0
  fi

  now="$(current_epoch)"
  last="$(file_mtime_epoch "$stamp_file")"
  if [[ "$last" -le 0 ]]; then
    return 0
  fi

  delta=$((now - last))
  [[ "$delta" -ge "$interval_seconds" ]]
}

touch_stamp_file() {
  local stamp_file="$1"
  ensure_launcher_state_dir
  : > "$stamp_file"
}

log_launcher_status() {
  local step="$1"
  local status="$2"
  local message="${3:-}"

  if [[ -n "$message" ]]; then
    echo "[launcher][$step][$status] $message" >&2
  else
    echo "[launcher][$step][$status]" >&2
  fi
}

run_with_progress() {
  local label="$1"
  shift

  local interval pid start now elapsed
  interval="${KANO_GIT_PROGRESS_INTERVAL_SECONDS:-30}"
  if [[ ! "$interval" =~ ^[0-9]+$ || "$interval" -le 0 ]]; then
    interval=30
  fi

  if [[ "${KANO_GIT_PROGRESS_HEARTBEAT:-1}" == "1" && -t 1 ]]; then
    "$@" &
    pid=$!
    start="$(current_epoch)"
    while kill -0 "$pid" 2>/dev/null; do
      sleep "$interval"
      if ! kill -0 "$pid" 2>/dev/null; then
        break
      fi
      now="$(current_epoch)"
      elapsed=$((now - start))
      log_launcher_status "$label" "running" "elapsed=${elapsed}s"
    done
    wait "$pid"
    return $?
  fi

  "$@"
}

maybe_prompt_yes_no() {
  local prompt="$1"
  local answer

  if ! is_interactive_terminal; then
    return 1
  fi

  read -r -p "$prompt [y/N]: " answer
  case "${answer,,}" in
    y|yes) return 0 ;;
  esac
  return 1
}

is_windows_compat_shell() {
  local os_name
  os_name="$(uname -s 2>/dev/null || true)"
  case "$os_name" in
    MINGW*|MSYS*|CYGWIN*)
      return 0
      ;;
  esac
  return 1
}

ensure_windows_build_runtime_paths() {
  # Only for Windows-compat shells (Git Bash / Cygwin).
  # WSL is treated as Linux build environment and should not consume Windows .exe toolchain shims.
  if ! is_windows_compat_shell; then
    return 0
  fi

  # Ensure cmake/ninja are reachable in Windows-compat shells.
  local cmake_exe="" ninja_exe=""
  if [[ -x "/mnt/c/Program Files/CMake/bin/cmake.exe" ]]; then
    cmake_exe="/mnt/c/Program Files/CMake/bin/cmake.exe"
  elif [[ -x "/c/Program Files/CMake/bin/cmake.exe" ]]; then
    cmake_exe="/c/Program Files/CMake/bin/cmake.exe"
  fi
  if [[ -x "/mnt/c/Program Files/CMake/bin/ninja.exe" ]]; then
    ninja_exe="/mnt/c/Program Files/CMake/bin/ninja.exe"
  elif [[ -x "/c/Program Files/CMake/bin/ninja.exe" ]]; then
    ninja_exe="/c/Program Files/CMake/bin/ninja.exe"
  fi

  if [[ -n "$cmake_exe" || -n "$ninja_exe" ]]; then
    local shim_dir="$PROJECT_ROOT/.kano/cache/runtime-shims"
    mkdir -p "$shim_dir"
    if [[ -n "$cmake_exe" && ! -x "$shim_dir/cmake" ]]; then
      cat > "$shim_dir/cmake" <<EOF
#!/usr/bin/env bash
exec "$cmake_exe" "\$@"
EOF
      chmod +x "$shim_dir/cmake" >/dev/null 2>&1 || true
    fi
    if [[ -n "$ninja_exe" && ! -x "$shim_dir/ninja" ]]; then
      cat > "$shim_dir/ninja" <<EOF
#!/usr/bin/env bash
exec "$ninja_exe" "\$@"
EOF
      chmod +x "$shim_dir/ninja" >/dev/null 2>&1 || true
    fi
    PATH="$shim_dir:$PATH"
  fi
}

apply_launcher_env_overrides() {
  local arg
  for arg in "$@"; do
    case "$arg" in
      --allow-ignore-gate)
        KOG_ALLOW_IGNORE_GATE=1
        export KOG_ALLOW_IGNORE_GATE
        ;;
    esac
  done
}

has_no_plan_auto_arg() {
  local arg
  for arg in "$@"; do
    [[ "$arg" == "--no-plan-auto" ]] && return 0
  done
  return 1
}

has_help_request_arg() {
  local arg
  for arg in "$@"; do
    case "$arg" in
      -h|--help|help)
        return 0
        ;;
    esac
  done
  return 1
}

is_lightweight_query_command() {
  local -a args=("$@")
  local cmd="${args[0]:-}"
  if [[ "$cmd" == "--version" || "$cmd" == "-v" || "$cmd" == "version" ]]; then
    return 0
  fi
  if has_help_request_arg "${args[@]}"; then
    return 0
  fi
  return 1
}

has_message_arg() {
  local arg
  for arg in "$@"; do
    case "$arg" in
      -m|--message|--message=*)
        return 0
        ;;
    esac
  done
  return 1
}

has_repos_arg() {
  local arg
  for arg in "$@"; do
    case "$arg" in
      --repos|--repos=*)
        return 0
        ;;
    esac
  done
  return 1
}

maybe_apply_cpa_single_change_shortcut() {
  local -n io_args_ref="$1"
  local cmd binary scope_line dirty_repos total_changes
  local default_message

  cmd="${io_args_ref[0]:-}"
  if [[ "$cmd" != "cpa" ]]; then
    return 0
  fi
  if has_help_request_arg "${io_args_ref[@]}"; then
    return 0
  fi
  if has_no_plan_auto_arg "${io_args_ref[@]}"; then
    return 0
  fi
  if has_message_arg "${io_args_ref[@]}"; then
    return 0
  fi
  if has_repos_arg "${io_args_ref[@]}"; then
    return 0
  fi
  local plan_file=""
  if extract_plan_file_from_args plan_file "${io_args_ref[@]}"; then
    return 0
  fi
  if [[ "${KOG_CPA_DISABLE_SINGLE_CHANGE_SHORTCUT:-0}" == "1" ]]; then
    return 0
  fi

  if ! binary="$(find_existing_binary)"; then
    return 0
  fi
  if ! scope_line="$(
      KANO_GIT_MASTER_ROOT="${KANO_GIT_MASTER_ROOT:-$PROJECT_ROOT}" \
      KANO_GIT_BINARY_PATH="$binary" \
      "$binary" plan prepare-scope 2>/dev/null | tr -d '\r' | tail -n 1
    )"; then
    return 0
  fi
  read -r dirty_repos total_changes _ <<<"$scope_line"
  if [[ ! "$dirty_repos" =~ ^[0-9]+$ || ! "$total_changes" =~ ^[0-9]+$ ]]; then
    return 0
  fi
  if [[ "$dirty_repos" -ne 1 || "$total_changes" -ne 1 ]]; then
    return 0
  fi

  default_message="${KOG_CPA_SHORTCUT_MESSAGE:-chore(workspace): apply single-change update}"
  io_args_ref=("cp" "-m" "$default_message")
  log_launcher_status "cpa-shortcut" "ok" "single dirty repo + single change; bypass plan preflight with cp -m"
  return 0
}

maybe_alias_cpa_for_agent_mode() {
  local -n io_args_ref="$1"
  local cmd="${io_args_ref[0]:-}"
  local agent_mode="${KANO_AGENT_MODE:-0}"

  if [[ "$cmd" != "cpa" ]]; then
    return 0
  fi
  if [[ "$agent_mode" != "1" && "$agent_mode" != "true" ]]; then
    return 0
  fi

  io_args_ref[0]="cp"
  log_launcher_status "agent-cpa-alias" "ok" "agent mode enabled; map cpa -> cp (skip launcher AI preflight)"
  return 0
}

is_ai_mode_commit_command() {
  local -a args=("$@")
  local cmd="${args[0]:-}"
  local arg

  if [[ "$cmd" == "cpa" ]]; then
    return 0
  fi
  if [[ "$cmd" != "commit" && "$cmd" != "commit-push" ]]; then
    return 1
  fi

  for arg in "${args[@]:1}"; do
    case "$arg" in
      -ai|--ai-auto|--ai-provider|--ai-model|--provider|--model)
        return 0
        ;;
      --ai-provider=*|--ai-model=*|--provider=*|--model=*)
        return 0
        ;;
    esac
  done

  return 1
}

extract_plan_file_from_args() {
  local -n out_ref="$1"
  shift
  local -a args=("$@")
  local i arg

  out_ref=""
  for ((i = 0; i < ${#args[@]}; i++)); do
    arg="${args[$i]}"
    case "$arg" in
      --plan-file)
        if ((i + 1 < ${#args[@]})); then
          out_ref="${args[$((i + 1))]}"
          return 0
        fi
        ;;
      --plan-file=*)
        out_ref="${arg#--plan-file=}"
        return 0
        ;;
    esac
  done

  return 1
}

extract_ai_options_from_args() {
  local -n out_provider_ref="$1"
  local -n out_model_ref="$2"
  shift 2

  local -a args=("$@")
  local i arg

  out_provider_ref="auto"
  out_model_ref="auto"

  for ((i = 0; i < ${#args[@]}; i++)); do
    arg="${args[$i]}"
    case "$arg" in
      --ai-provider|--provider)
        if ((i + 1 < ${#args[@]})); then
          out_provider_ref="${args[$((i + 1))]}"
          i=$((i + 1))
        fi
        ;;
      --ai-provider=*|--provider=*)
        out_provider_ref="${arg#*=}"
        ;;
      --ai-model|--model)
        if ((i + 1 < ${#args[@]})); then
          out_model_ref="${args[$((i + 1))]}"
          i=$((i + 1))
        fi
        ;;
      --ai-model=*|--model=*)
        out_model_ref="${arg#*=}"
        ;;
    esac
  done
}

maybe_run_plan_preflight_for_ai_command() {
  local -a args=("$@")
  local cmd="${args[0]:-}"
  local plan_file="" ai_provider="auto" ai_model="auto"
  local allow_ignore_gate=0
  local i arg status
  local -a preflight_args=()
  local -a secret_gate_args=()
  local binary=""

  if [[ "$cmd" != "commit" && "$cmd" != "commit-push" && "$cmd" != "cpa" ]]; then
    return 0
  fi
  if has_help_request_arg "${args[@]}"; then
    return 0
  fi
  if has_no_plan_auto_arg "${args[@]}"; then
    return 0
  fi
  if ! is_ai_mode_commit_command "${args[@]}"; then
    return 0
  fi

  extract_ai_options_from_args ai_provider ai_model "${args[@]}"
  extract_plan_file_from_args plan_file "${args[@]}" || true

  for ((i = 0; i < ${#args[@]}; i++)); do
    arg="${args[$i]}"
    case "$arg" in
      --allow-ignore-gate)
        allow_ignore_gate=1
        ;;
    esac
  done

  preflight_args=("plan" "runbook" "commit" "--ai-provider" "$ai_provider" "--ai-model" "$ai_model" "--max-commits" "10")
  if [[ -n "$plan_file" ]]; then
    preflight_args+=("--plan-file" "$plan_file")
  fi
  if [[ "$allow_ignore_gate" -eq 1 ]]; then
    preflight_args+=("--allow-ignore-gate")
  fi
  if [[ "${KOG_CPA_AUTO_PLAN_DEBUG:-${KOG_PA_AUTO_PLAN_DEBUG:-0}}" == "1" ]]; then
    preflight_args+=("--debug-ai")
  fi

  if binary="$(find_existing_binary)"; then
    if run_native_binary "$binary" "${preflight_args[@]}"; then
      secret_gate_args=("plan" "verify" "secret" "--context" "ai-commit" "--limit" "20")
      if "$binary" plan verify secret --help >/dev/null 2>&1; then
        if run_native_binary "$binary" "${secret_gate_args[@]}"; then
          return 0
        fi
        status=$?
        echo "Error: secret gate failed via native binary (exit=$status)." >&2
        return "$status"
      fi
      echo "Warning: native binary does not support plan verify secret yet; skipping secret gate." >&2
      return 0
    else
      status=$?
      echo "Error: AI plan preflight failed via native binary (exit=$status)." >&2
      return "$status"
    fi
  fi
  echo "Error: AI plan preflight failed: native binary unavailable." >&2
  return 2
}

apply_agent_mode_from_args() {
  local arg next
  next=""

  if [[ "${KANO_AGENT_MODE:-}" == "1" || "${KANO_AGENT_MODE:-}" == "true" ]]; then
    return 0
  fi

  for arg in "$@"; do
    if [[ "$next" == "agent" ]]; then
      if [[ -n "$arg" && "$arg" != "manual" ]]; then
        export KANO_AGENT_MODE=1
        return 0
      fi
      next=""
      continue
    fi

    case "$arg" in
      --agent)
        next="agent"
        ;;
      --agent=*)
        local agent_value="${arg#--agent=}"
        if [[ -n "$agent_value" && "$agent_value" != "manual" ]]; then
          export KANO_AGENT_MODE=1
          return 0
        fi
        ;;
    esac
  done
}

clean_native_build_artifacts() {
  remove_tree_best_effort() {
    local target_path="$1"
    [[ -e "$target_path" ]] || return 0

    if rm -rf "$target_path" 2>/dev/null; then
      return 0
    fi

    sleep 0.1
    rm -rf "$target_path" 2>/dev/null || true

    if [[ -e "$target_path" ]]; then
      log_launcher_status "build-native" "warn" "cleanup skipped (path still exists): $target_path"
    fi
  }

  local preset
  local base_build="$PROJECT_ROOT/src/cpp/build"

  while IFS= read -r preset; do
    [[ -z "$preset" ]] && continue
    remove_tree_best_effort "$base_build/_intermediate/$preset"
    remove_tree_best_effort "$base_build/bin/$preset"
    remove_tree_best_effort "$base_build/lib/$preset"
  done < <(candidate_presets)

  remove_tree_best_effort "$base_build/release"
  remove_tree_best_effort "$base_build/debug"
}

prepare_cpp_build_submodules() {
  local context_label="${1:-build-native}"
  local -a discovered_paths update_paths
  local line path abs_path status_line state

  if [[ ! -f "$PROJECT_ROOT/.gitmodules" ]]; then
    return 0
  fi

  if ! command -v git >/dev/null 2>&1; then
    echo "Error: git command not found; cannot prepare required submodules." >&2
    return 1
  fi

  log_launcher_status "$context_label" "step" "prepare-submodules"

  # Discover C++ build dependencies from .gitmodules dynamically.
  # Any registered submodule under src/cpp/code/thirdparty/ is treated as build dependency.
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    path="${line#* }"
    if [[ "$path" == src/cpp/code/thirdparty/* ]]; then
      discovered_paths+=("$path")
    fi
  done < <(git -C "$PROJECT_ROOT" config -f .gitmodules --get-regexp '^submodule\..*\.path$' 2>/dev/null || true)

  if [[ "${#discovered_paths[@]}" -eq 0 ]]; then
    log_launcher_status "$context_label" "ok" "no C++ thirdparty submodules registered in .gitmodules"
    return 0
  fi

  for path in "${discovered_paths[@]}"; do
    abs_path="$PROJECT_ROOT/$path"
    status_line="$(git -C "$PROJECT_ROOT" submodule status -- "$path" 2>/dev/null || true)"
    state="${status_line:0:1}"

    if [[ "$state" == "-" && -d "$abs_path" ]]; then
      if find "$abs_path" -mindepth 1 -print -quit 2>/dev/null | grep -q .; then
        log_launcher_status "$context_label" "warn" "removing stale uninitialized submodule dir: $path"
        rm -rf "$abs_path" || {
          echo "Error: failed to clean stale submodule directory: $path" >&2
          return 1
        }
      fi
    fi

    if [[ -z "$status_line" ]]; then
      continue
    fi

    update_paths+=("$path")
  done

  if [[ "${#update_paths[@]}" -eq 0 ]]; then
    log_launcher_status "$context_label" "ok" "no registered C++ submodules to prepare"
    return 0
  fi

  (
    cd "$PROJECT_ROOT"
    git submodule sync -- "${update_paths[@]}" >/dev/null
    git submodule update --init --recursive -- "${update_paths[@]}"
  ) || {
    echo "Error: failed to initialize required C++ thirdparty submodules." >&2
    echo "Hint: run 'git submodule update --init --recursive -- src/cpp/code/thirdparty/*' and retry." >&2
    return 1
  }

  log_launcher_status "$context_label" "ok" "submodules ready"
  return 0
}

run_native_build_mode() {
  local mode="$1"
  local prereq_script build_script prereq_stamp prereq_interval now_epoch last_epoch cooldown_left

  ensure_windows_build_runtime_paths
  prepare_cpp_build_submodules "build-native" || return 1

  if ! mapfile -t _scripts < <(script_paths); then
    echo "Error: no native build scripts for platform $(platform_name) ($(arch_name))." >&2
    return 1
  fi

  prereq_script="${_scripts[0]:-}"
  build_script="${_scripts[1]:-}"
  if [[ -z "$prereq_script" || -z "$build_script" ]]; then
    echo "Error: missing native build script mapping for this platform." >&2
    return 1
  fi

  case "$mode" in
    incremental)
      log_launcher_status "build-native" "start" "mode=incremental"
      ;;
    full)
      log_launcher_status "build-native" "start" "mode=full"
      log_launcher_status "build-native" "step" "clean-artifacts"
      clean_native_build_artifacts
      ;;
    *)
      echo "Error: unsupported build mode: $mode (expected: incremental|full)" >&2
      return 2
      ;;
  esac

  if run_shell_script "$build_script"; then
    log_launcher_status "build-native" "ok" "build completed"
  else
    prereq_stamp="$(state_file_for build-prereq.stamp)"
    prereq_interval="${KANO_GIT_PREREQ_RETRY_INTERVAL_SECONDS:-21600}"
    if [[ ! "$prereq_interval" =~ ^[0-9]+$ || "$prereq_interval" -lt 0 ]]; then
      prereq_interval=21600
    fi

    if should_run_interval_check "$prereq_stamp" "$prereq_interval"; then
      log_launcher_status "build-native" "step" "install-prerequisites"
      touch_stamp_file "$prereq_stamp"
    else
      now_epoch="$(current_epoch)"
      last_epoch="$(file_mtime_epoch "$prereq_stamp")"
      cooldown_left=$((prereq_interval - (now_epoch - last_epoch)))
      if [[ "$cooldown_left" -lt 0 ]]; then
        cooldown_left=0
      fi
      log_launcher_status "build-native" "warn" "skip prerequisite reinstall (cooldown=${cooldown_left}s)"
      log_launcher_status "build-native" "fail" "build failed"
      return 1
    fi

    run_shell_script "$prereq_script" || {
      log_launcher_status "build-native" "fail" "prerequisite install failed"
      return 1
    }
    run_shell_script "$build_script" || {
      log_launcher_status "build-native" "fail" "build failed after prerequisite install"
      return 1
    }
    log_launcher_status "build-native" "ok" "build completed after prerequisite install"
  fi

  local binary
  binary="$(find_binary || true)"
  if [[ -n "$binary" && -f "$binary" ]]; then
    echo "Native binary ready: $binary"
    return 0
  fi

  echo "Warning: build finished but binary path could not be resolved." >&2
  return 1
}

maybe_handle_launcher_build_request() {
  if [[ "$#" -eq 0 ]]; then
    return 1
  fi

  local first="$1"
  shift || true
  local mode=""
  local extra

  case "$first" in
    build)
      mode="incremental"
      ;;
    rebuild)
      mode="full"
      ;;
    *)
      return 1
      ;;
  esac

  for extra in "$@"; do
    case "$extra" in
      --llvm)
        KOG_BUILD_USE_LLVM="1"
        ;;
      --modules)
        KOG_BUILD_ENABLE_MODULES="1"
        ;;
      --no-modules)
        KOG_BUILD_ENABLE_MODULES="0"
        ;;
      --apple-clang)
        KOG_BUILD_USE_LLVM="0"
        ;;
      *)
        echo "Error: unsupported build option: $extra" >&2
        echo "Hint: supported options are --llvm, --apple-clang, --modules, --no-modules" >&2
        return 2
        ;;
    esac
  done

  run_native_build_mode "$mode"
  return $?
}

manual_self_update_shell() {
  local repo_root="$1"
  local preferred_remote="$2"
  local auto_sync="$3"
  local non_interactive="$4"
  local remote="" branch="" ahead_raw="" ahead_count=0

  if [[ "$(git -C "$repo_root" rev-parse --is-inside-work-tree 2>/dev/null || true)" != "true" ]]; then
    echo "Error: self update requires a git worktree: $repo_root" >&2
    return 1
  fi

  if [[ -n "$(git -C "$repo_root" status --porcelain 2>/dev/null || true)" ]]; then
    echo "Error: self update aborted: dirty worktree in $repo_root" >&2
    echo "Hint: commit/stash/discard changes before running 'kog self update'." >&2
    return 1
  fi

  if [[ -n "$preferred_remote" ]] && git -C "$repo_root" remote get-url "$preferred_remote" >/dev/null 2>&1; then
    remote="$preferred_remote"
  elif git -C "$repo_root" remote get-url upstream >/dev/null 2>&1; then
    remote="upstream"
  elif git -C "$repo_root" remote get-url origin >/dev/null 2>&1; then
    remote="origin"
  else
    echo "Error: no git remote found for self update." >&2
    return 1
  fi

  echo "[self-update] fetching from remote: $remote" >&2
  git -C "$repo_root" fetch "$remote" --prune >/dev/null

  branch="$(git -C "$repo_root" symbolic-ref --quiet --short "refs/remotes/$remote/HEAD" 2>/dev/null || true)"
  if [[ -n "$branch" ]]; then
    branch="${branch#${remote}/}"
  else
    branch="$(git -C "$repo_root" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  fi
  if [[ -z "$branch" ]]; then
    echo "Error: unable to resolve target branch for self update." >&2
    return 1
  fi

  ahead_raw="$(git -C "$repo_root" rev-list --count "HEAD..$remote/$branch" 2>/dev/null || true)"
  if [[ "$ahead_raw" =~ ^[0-9]+$ ]]; then
    ahead_count="$ahead_raw"
  fi
  if [[ "$ahead_count" -le 0 ]]; then
    echo "[self-update] already up to date: $remote/$branch" >&2
    return 0
  fi

  local should_sync=0
  if [[ "$auto_sync" == "1" ]]; then
    should_sync=1
  elif [[ "$non_interactive" == "1" || "${KANO_AGENT_MODE:-0}" == "1" ]]; then
    should_sync=0
  elif is_interactive_terminal && maybe_prompt_yes_no "[self-update] Found ${ahead_count} commit(s) on ${remote}/${branch}. Sync now?"; then
    should_sync=1
  fi

  if [[ "$should_sync" != "1" ]]; then
    echo "[self-update] updates available (${ahead_count}) but not applied." >&2
    return 0
  fi

  echo "[self-update] syncing with rebase: $remote/$branch" >&2
  git -C "$repo_root" rebase "$remote/$branch"
  return $?
}

maybe_handle_manual_self_request() {
  if [[ "$#" -lt 2 ]]; then
    return 1
  fi

  local first="$1"
  local second="$2"
  shift 2 || true

  if [[ "$first" != "self" ]]; then
    return 1
  fi

  case "$second" in
    build|rebuild)
      maybe_handle_launcher_build_request "$second" "$@"
      return $?
      ;;
    update)
      local binary=""
      local remote="upstream"
      local auto_sync="0"
      local non_interactive="0"
      local arg
      while [[ "$#" -gt 0 ]]; do
        arg="$1"
        shift || true
        case "$arg" in
          --remote)
            if [[ "$#" -gt 0 ]]; then
              remote="$1"
              shift || true
            fi
            ;;
          --remote=*)
            remote="${arg#--remote=}"
            ;;
          --auto-sync)
            auto_sync="1"
            ;;
          --non-interactive)
            non_interactive="1"
            ;;
        esac
      done
      if ! binary="$(find_existing_binary 2>/dev/null)"; then
        echo "Warning: native binary unavailable; using shell fallback for self update." >&2
        manual_self_update_shell "$PROJECT_ROOT" "$remote" "$auto_sync" "$non_interactive" || return $?
        prepare_cpp_build_submodules "self-update" || return $?
        echo "[self-update] bootstrap ready: required C++ submodules are prepared for self build." >&2
        return 0
      fi
      local -a native_args=("self" "update-check" "--repo" "$PROJECT_ROOT" "--mode" "auto" "--remote" "$remote")
      [[ "$auto_sync" == "1" ]] && native_args+=("--auto-update")
      [[ "$non_interactive" == "1" ]] && native_args+=("--non-interactive")
      run_native_binary "$binary" "${native_args[@]}"
      return $?
      ;;
    *)
      return 1
      ;;
  esac
}

append_once_to_file() {
  local file="$1"
  local marker="$2"
  local content="$3"

  mkdir -p "$(dirname "$file")"
  touch "$file"

  if grep -Fq "$marker" "$file" 2>/dev/null; then
    return 0
  fi

  printf '\n%s\n' "$content" >> "$file"
}

install_bash_completion() {
  local binary="$1"
  local completion_dir completion_file bash_rc source_block

  completion_dir="${HOME}/.local/share/bash-completion/completions"
  completion_file="$completion_dir/kog"
  bash_rc="${HOME}/.bashrc"

  mkdir -p "$completion_dir"
  KANO_GIT_MASTER_ROOT="${KANO_GIT_MASTER_ROOT:-$PROJECT_ROOT}" "$binary" completion bash > "$completion_file"
  chmod 0644 "$completion_file" 2>/dev/null || true

  source_block=$(cat <<EOF
# kano-git bash completion
if [[ -r "$completion_file" ]]; then
  source "$completion_file"
fi
EOF
)
  append_once_to_file "$bash_rc" "# kano-git bash completion" "$source_block"

  echo "Bash completion installed: $completion_file"
  echo "Reload shell with: source $bash_rc"
}

maybe_handle_completion_install_request() {
  if [[ "$#" -eq 0 ]]; then
    return 1
  fi

  local first="$1"
  local second="${2:-}"
  local third="${3:-}"
  local shell_name=""
  local binary=""

  case "$first" in
    completion-install)
      shell_name="${second:-bash}"
      ;;
    completion)
      if [[ "$second" != "install" ]]; then
        return 1
      fi
      shell_name="${third:-bash}"
      ;;
    *)
      return 1
      ;;
  esac

  if [[ "$shell_name" != "bash" ]]; then
    echo "Error: completion install currently supports bash only." >&2
    echo "Hint: use './kog completion install bash'" >&2
    return 2
  fi

  binary="$(find_binary || true)"
  if [[ -z "$binary" || ! -f "$binary" ]]; then
    echo "Error: native binary unavailable; cannot install completion." >&2
    echo "Hint: run './kog self build' first." >&2
    return 1
  fi

  if [[ ! -x "$binary" ]]; then
    chmod u+x "$binary" >/dev/null 2>&1 || true
  fi

  install_bash_completion "$binary"
  return 0
}

should_rebuild_native_binary() {
  local binary="$1"
  local native_out native_status native_reason native_dir

  REBUILD_DIRECTION="unknown"
  REBUILD_REASON=""

  if [[ ! -f "$binary" ]]; then
    REBUILD_REASON="binary missing"
    return 0
  fi

  native_out="$(run_native_binary "$binary" self stale-check --repo "$PROJECT_ROOT" --binary "$binary" 2>/dev/null)"
  native_status=$?
  if [[ "$native_status" -eq 0 || "$native_status" -eq 1 ]]; then
    native_dir="$(printf '%s\n' "$native_out" | sed -n 's/.*direction=\([^ ]*\).*/\1/p' | head -n1)"
    native_reason="$(printf '%s\n' "$native_out" | sed -n 's/.*reason=\(.*\)$/\1/p' | head -n1)"
    if [[ -n "$native_dir" ]]; then
      REBUILD_DIRECTION="$native_dir"
    fi
    if [[ -n "$native_reason" ]]; then
      REBUILD_REASON="$native_reason"
    fi
    if [[ "$native_status" -eq 0 ]]; then
      return 0
    fi
    return 1
  fi

  # Strict native-only behavior: stale-check must be provided by C++ binary.
  log_launcher_status "auto-rebuild" "skip" "native self stale-check unavailable; skip launcher-side rebuild heuristics"
  return 1
}

maybe_rebuild_binary_if_needed() {
  local binary="$1"
  local rebuilt_binary
  local allow_noninteractive_downgrade="${KANO_GIT_ALLOW_NONINTERACTIVE_DOWNGRADE_REBUILD:-0}"

  if should_rebuild_native_binary "$binary"; then
    if [[ "$REBUILD_DIRECTION" == "downgrade" ]]; then
      if ! is_interactive_terminal; then
        if [[ "$allow_noninteractive_downgrade" != "1" ]]; then
          printf '%s\n' "$binary"
          return 0
        fi
        echo "Detected downgrade rebuild in non-interactive mode; override enabled, proceeding with rebuild." >&2
      fi
      if ! maybe_prompt_yes_no "Detected downgrade rebuild. $REBUILD_REASON Proceed with downgrade rebuild?"; then
        echo "User declined downgrade rebuild; keep current binary." >&2
        printf '%s\n' "$binary"
        return 0
      fi
    fi

    if [[ -n "$REBUILD_REASON" ]]; then
      echo "$REBUILD_REASON" >&2
    fi
    echo "Detected stale C++ binary; triggering rebuild..." >&2
    if try_auto_prepare_binary; then
      rebuilt_binary="$(find_binary || true)"
      if [[ -n "$rebuilt_binary" && -f "$rebuilt_binary" ]]; then
        printf '%s\n' "$rebuilt_binary"
        return 0
      fi
      echo "Rebuild completed but no binary path was resolved." >&2
    fi

    if [[ -n "$binary" && -f "$binary" ]]; then
      printf '%s\n' "$binary"
      return 0
    fi
    return 1
  fi

  if [[ -z "$binary" || ! -f "$binary" ]]; then
    return 1
  fi

  printf '%s\n' "$binary"
}

maybe_run_launcher_update_flow() {
  local command="${1:-}"
  local binary=""
  local wsl_update_check="${KOG_WSL_AUTO_UPDATE_CHECK:-0}"
  if is_wsl_shell && [[ "$wsl_update_check" != "1" ]]; then
    return 0
  fi
  if ! binary="$(find_existing_binary 2>/dev/null)"; then
    return 0
  fi
  run_native_binary "$binary" self maybe-auto-update --repo "$PROJECT_ROOT" --command "$command" || true
}

platform_name() {
  local os_name
  os_name="$(uname -s 2>/dev/null || true)"
  case "$os_name" in
    Darwin*) echo "macos" ;;
    Linux*) echo "linux" ;;
    MINGW*|MSYS*|CYGWIN*|Windows_NT) echo "windows" ;;
    *) echo "${os_name,,}" ;;
  esac
}

is_wsl_shell() {
  if [[ -n "${WSL_DISTRO_NAME:-}" || -n "${WSL_INTEROP:-}" ]]; then
    return 0
  fi
  if [[ "$(uname -s 2>/dev/null || true)" != "Linux" ]]; then
    return 1
  fi
  if [[ -r "/proc/version" ]] && grep -qi "microsoft" /proc/version 2>/dev/null; then
    return 0
  fi
  return 1
}

is_binary_compatible_with_shell() {
  local binary="$1"
  local os_name
  os_name="$(platform_name)"

  case "$os_name" in
    windows)
      [[ "$binary" == *.exe ]]
      return $?
      ;;
    linux|macos)
      [[ "$binary" == *.exe ]] && return 1
      return 0
      ;;
    *)
      return 0
      ;;
  esac
}

ensure_binary_shell_compatibility() {
  local binary="$1"
  local allow_cross="${KOG_ALLOW_CROSS_PLATFORM_BINARY:-0}"

  if is_binary_compatible_with_shell "$binary"; then
    return 0
  fi
  if [[ "$allow_cross" == "1" ]]; then
    return 0
  fi

  if is_wsl_shell && [[ "$binary" == *.exe ]]; then
    echo "Error: detected Windows .exe binary in WSL shell: $binary" >&2
    echo "Hint: WSL is Linux runtime. Build/use Linux binary, or run this command in Git Bash/Cygwin on Windows." >&2
    echo "Hint: set KOG_ALLOW_CROSS_PLATFORM_BINARY=1 only for one-off debugging." >&2
    return 1
  fi

  echo "Error: binary/shell platform mismatch: $binary" >&2
  echo "Hint: use a shell matching the target binary platform (Windows shell for .exe, Linux/macOS shell for native)." >&2
  echo "Hint: set KOG_ALLOW_CROSS_PLATFORM_BINARY=1 only for one-off debugging." >&2
  return 1
}

arch_name() {
  local machine
  machine="$(uname -m 2>/dev/null || true)"
  case "$machine" in
    arm64|aarch64) echo "arm64" ;;
    *) echo "x64" ;;
  esac
}

candidate_presets() {
  local os_name arch
  os_name="$(platform_name)"
  arch="$(arch_name)"
  case "$os_name" in
    windows)
      if [[ "$arch" == "arm64" ]]; then
        printf '%s\n' "windows-ninja-msvc-arm64" "windows-ninja-msvc"
      else
        printf '%s\n' "windows-ninja-msvc"
      fi
      ;;
    linux)
      printf '%s\n' "linux-ninja-gcc"
      ;;
    macos)
      if [[ "$arch" == "arm64" ]]; then
        printf '%s\n' "macos-ninja-clang-arm64" "macos-ninja-clang" "macos-ninja-llvm-arm64" "macos-make-clang-arm64" "macos-make-llvm-arm64"
      else
        printf '%s\n' "macos-ninja-clang-x64" "macos-ninja-clang" "macos-ninja-llvm-x64" "macos-make-clang-x64" "macos-make-llvm-x64"
      fi
      ;;
  esac
}

to_windows_path() {
  local p="$1"
  if command -v cygpath >/dev/null 2>&1; then
    cygpath -w "$p" 2>/dev/null && return 0
  fi
  if [[ "$p" =~ ^/mnt/([a-zA-Z])/(.*)$ ]]; then
    local drive="${BASH_REMATCH[1]}"
    local rest="${BASH_REMATCH[2]}"
    rest="${rest//\//\\}"
    printf '%s:\\%s\n' "${drive^^}" "$rest"
    return 0
  fi
  if [[ "$p" =~ ^([A-Za-z]):[\\/] ]]; then
    printf '%s\n' "$p"
    return 0
  fi
  return 1
}

find_bash() {
  if command -v bash >/dev/null 2>&1; then
    command -v bash
    return 0
  fi

  if [[ -n "${GIT_BASH_PATH:-}" && -f "${GIT_BASH_PATH}" ]]; then
    printf '%s\n' "$GIT_BASH_PATH"
    return 0
  fi

  if [[ -f "C:/Program Files/Git/bin/bash.exe" ]]; then
    printf '%s\n' "C:/Program Files/Git/bin/bash.exe"
    return 0
  fi

  return 1
}

find_binary() {
  local exe_name build_dir candidate preset resolved_path resolved_dir os_name arch
  os_name="$(platform_name)"
  arch="$(arch_name)"
  case "$os_name" in
    windows) exe_name="kano-git.exe" ;;
    *) exe_name="kano-git" ;;
  esac
  build_dir="$PROJECT_ROOT/src/cpp/build"

  if [[ -n "${KANO_GIT_BIN:-}" ]]; then
    if [[ -f "$KANO_GIT_BIN" ]]; then
      if is_binary_compatible_with_shell "$KANO_GIT_BIN"; then
        printf '%s\n' "$KANO_GIT_BIN"
        return 0
      fi
    fi
    if [[ -f "$KANO_GIT_BIN/$exe_name" ]]; then
      if is_binary_compatible_with_shell "$KANO_GIT_BIN/$exe_name"; then
        printf '%s\n' "$KANO_GIT_BIN/$exe_name"
        return 0
      fi
    fi
  fi

  while IFS= read -r preset; do
    [[ -z "$preset" ]] && continue
    candidate="$build_dir/bin/$preset/release/$exe_name"
    if [[ -f "$candidate" ]]; then
      if is_binary_compatible_with_shell "$candidate"; then
        printf '%s\n' "$candidate"
        return 0
      fi
    fi
    candidate="$build_dir/bin/$preset/debug/$exe_name"
    if [[ -f "$candidate" ]]; then
      if is_binary_compatible_with_shell "$candidate"; then
        printf '%s\n' "$candidate"
        return 0
      fi
    fi
  done < <(candidate_presets)

  candidate="$build_dir/release/$exe_name"
  [[ -f "$candidate" ]] && is_binary_compatible_with_shell "$candidate" && { printf '%s\n' "$candidate"; return 0; }
  candidate="$build_dir/debug/$exe_name"
  [[ -f "$candidate" ]] && is_binary_compatible_with_shell "$candidate" && { printf '%s\n' "$candidate"; return 0; }

  if command -v kano-git >/dev/null 2>&1; then
    resolved_path="$(command -v kano-git)"
    if [[ -n "$resolved_path" ]]; then
      resolved_dir="$(cd "$(dirname "$resolved_path")" && pwd)"
      resolved_path="$resolved_dir/$(basename "$resolved_path")"
      if [[ "$resolved_path" != "$SCRIPT_DIR/kano-git" ]]; then
        if is_binary_compatible_with_shell "$resolved_path"; then
          printf '%s\n' "$resolved_path"
          return 0
        fi
      fi
    fi
  fi

  return 1
}

find_existing_binary() {
  local binary=""
  if ! binary="$(find_binary 2>/dev/null)"; then
    return 1
  fi
  [[ -n "$binary" && -f "$binary" ]] || return 1
  printf '%s\n' "$binary"
}

script_paths() {
  local base os_name arch prereq build
  base="$PROJECT_ROOT/src/cpp/build/script"
  os_name="$(platform_name)"
  arch="$(arch_name)"

  case "$os_name" in
    windows)
      prereq="$base/windows/prerequisite_windows.sh"
      if [[ "$arch" == "arm64" ]]; then
        build="$base/windows/build_windows_ninja_msvc_arm64_release.sh"
      else
        build="$base/windows/build_windows_ninja_msvc_release.sh"
      fi
      ;;
    linux)
      prereq="$base/linux/prerequisite_linux.sh"
      build="$base/linux/build_linux_ninja_gcc_release.sh"
      ;;
    macos)
      prereq="$base/macos/prerequisite_macos.sh"
      if [[ "$arch" == "arm64" ]]; then
        build="$base/macos/build_macos_ninja_clang_arm64_release.sh"
      else
        build="$base/macos/build_macos_ninja_clang_x64_release.sh"
      fi
      ;;
    *)
      return 1
      ;;
  esac

  printf '%s\n%s\n' "$prereq" "$build"
}

fallback_install_marker_file() {
  if [[ -n "${KANO_GIT_INSTALL_MARKER:-}" ]]; then
    printf '%s\n' "$KANO_GIT_INSTALL_MARKER"
  else
    printf '%s\n' "$PROJECT_ROOT/.kano-installed-marker"
  fi
}

install_marker_file() {
  local binary="" marker=""
  if binary="$(find_existing_binary 2>/dev/null)"; then
    marker="$(run_native_binary "$binary" self marker-path --repo "$PROJECT_ROOT" 2>/dev/null || true)"
    marker="$(printf '%s' "$marker" | tr -d '\r' | tail -n 1)"
    if [[ -n "$marker" ]]; then
      printf '%s\n' "$marker"
      return 0
    fi
  fi
  fallback_install_marker_file
}

is_packaged_install() {
  local binary=""
  if binary="$(find_existing_binary 2>/dev/null)"; then
    run_native_binary "$binary" self is-packaged --repo "$PROJECT_ROOT" >/dev/null 2>&1
    local status=$?
    if [[ "$status" -eq 0 || "$status" -eq 1 ]]; then
      return "$status"
    fi
  fi
  local marker
  marker="$(fallback_install_marker_file)"
  [[ -f "$marker" ]]
}

run_shell_script() {
  local script bash_path start end elapsed
  local script_name
  script="$1"
  shift || true
  script_name="$(basename "$script")"
  if ! bash_path="$(find_bash)"; then
    echo "Warning: bash not found; cannot run shell script automation." >&2
    return 1
  fi
  if [[ ! -f "$script" ]]; then
    echo "Warning: script not found: $script" >&2
    return 1
  fi

  start="$(current_epoch)"
  log_launcher_status "$script_name" "start" "args=$*"

  if [[ "$script_name" == prerequisite_* ]]; then
    if env KANO_GIT_MASTER_ROOT="${KANO_GIT_MASTER_ROOT:-$PROJECT_ROOT}" KOG_BUILD_USE_LLVM="$KOG_BUILD_USE_LLVM" KOG_BUILD_ENABLE_MODULES="$KOG_BUILD_ENABLE_MODULES" "$bash_path" "$script" "$@"; then
      end="$(current_epoch)"
      elapsed=$((end - start))
      log_launcher_status "$script_name" "ok" "elapsed=${elapsed}s"
      return 0
    fi
  elif run_with_progress "$script_name" env KANO_GIT_MASTER_ROOT="${KANO_GIT_MASTER_ROOT:-$PROJECT_ROOT}" KOG_BUILD_USE_LLVM="$KOG_BUILD_USE_LLVM" KOG_BUILD_ENABLE_MODULES="$KOG_BUILD_ENABLE_MODULES" "$bash_path" "$script" "$@"; then
    end="$(current_epoch)"
    elapsed=$((end - start))
    log_launcher_status "$script_name" "ok" "elapsed=${elapsed}s"
    return 0
  fi

  end="$(current_epoch)"
  elapsed=$((end - start))
  log_launcher_status "$script_name" "fail" "elapsed=${elapsed}s"
  return 1
}

try_auto_prepare_binary() {
  local prereq_script build_script
  local step_idx=0
  local -a build_submodules=(
    "src/cpp/code/thirdparty/cli11"
    "src/cpp/code/thirdparty/ftxui"
  )

  if [[ -f "$PROJECT_ROOT/.gitmodules" ]] && command -v git >/dev/null 2>&1; then
    log_launcher_status "auto-prepare" "step" "prepare-submodules"
    (
      cd "$PROJECT_ROOT"
      git submodule sync -- "${build_submodules[@]}" >/dev/null
      git submodule update --init --recursive -- "${build_submodules[@]}"
    ) || {
      echo "Warning: failed to prepare C++ thirdparty submodules (cli11/ftxui); build may fail." >&2
    }
  fi

  if ! mapfile -t _scripts < <(script_paths); then
    echo "Warning: no build automation scripts for platform $(platform_name) ($(arch_name))." >&2
    return 1
  fi

  prereq_script="${_scripts[0]:-}"
  build_script="${_scripts[1]:-}"
  if [[ -z "$prereq_script" || -z "$build_script" ]]; then
    echo "Warning: missing prerequisite/build script mapping for this platform." >&2
    return 1
  fi

  step_idx=$((step_idx + 1))
  log_launcher_status "auto-prepare" "step" "${step_idx}: direct-build"
  echo "Attempting C++ binary build/refresh..." >&2
  if run_shell_script "$build_script"; then
    log_launcher_status "auto-prepare" "ok" "direct-build succeeded"
    return 0
  fi

  step_idx=$((step_idx + 1))
  log_launcher_status "auto-prepare" "step" "${step_idx}: prerequisite-install"
  echo "Direct build failed. Installing/upgrading prerequisites..." >&2
  run_shell_script "$prereq_script" || {
    log_launcher_status "auto-prepare" "fail" "prerequisite-install failed"
    echo "Warning: prerequisite installation failed." >&2
    return 1
  }

  step_idx=$((step_idx + 1))
  log_launcher_status "auto-prepare" "step" "${step_idx}: rebuild-after-prereq"
  echo "Retrying C++ accelerated kano-git binary build..." >&2
  run_shell_script "$build_script" || {
    log_launcher_status "auto-prepare" "fail" "rebuild-after-prereq failed"
    echo "Warning: C++ binary build failed after prerequisite installation." >&2
    return 1
  }

  log_launcher_status "auto-prepare" "ok" "binary ready"
  return 0
}

print_launcher_help_extras() {
  cat >&2 <<'EOF'

Launcher commands:
  self build                          Build native binary (incremental)
  self rebuild                        Rebuild native binary (full clean rebuild)
  self update                         Run manual launcher update check flow
                                      When native binary is unavailable, fallback sync also prepares required C++ submodules.
    --remote <name>                   Preferred remote (default: upstream, fallback origin)
    --auto-sync                       Apply update without prompt when commits are available
    --non-interactive                 Do not prompt; report availability only unless --auto-sync
  discover                            Run manual repo discovery, refresh cache, and print cache file path
  plan new                           Write plan template from assets
    -ai, --ai-auto                    Generate and fill plan via one AI request
    --ai-provider <name>              AI provider for plan generation (codex|opencode|copilot|auto)
    --ai-model <name>                 AI model for plan generation
    --ignore-datasource-root <path>   Override plan meta ignore datasource root
    --ignore-datasource-manifest <p>  Override plan meta ignore datasource manifest
  plan apply                          Apply plan stages (default: all)
    --stage ignore|commit|all         Run only selected stage(s)
  plan verify pre-apply               Verify plan schema before apply
    --stage ignore|commit|all         Verify selected stage requirements
  plan verify post-apply              Verify apply result state after apply
    --stage ignore|commit|all         Verify selected stage results
  plan verify ignore                  Run ignore gate verification only
  plan verify secret                  Run secret gate verification only
  plan finish-report                        Print compact plan summary
    --max-commits <n>                 Limit printed commit lines (default: 10)
  plan refresh-check                  Exit 0 when plan should be regenerated
  plan ensure-prepare-ready          Ensure plan is prepared and AI-ready (fill + validate)
  plan runbook commit                 Run commit runbook (prepare + summary + validate)
  plan runbook ignore                 Run ignore runbook (init + pre-apply verify)
  plan runbook full                   Run full runbook (ignore + commit + pre-apply verify)
  plan datasource-sync                Update ignore-plan reference datasource (default: github-gitignore)
    --source github-gitignore         Datasource source id
    --dry-run                         Print revision metadata without updating
  ignore doctor                       Scan tracked files and suggest likely ignore candidates
    --repo <path>                     Limit scan root (default: current workspace)
    --limit <n>                       Max findings (default: 200)
    --json                            Output JSON
    --apply                           Apply untrack actions (git rm --cached) for findings
    --dry-run                         Print planned untrack actions only
    --yes                             Skip interactive confirmation for --apply
  pi ...                              Alias of plan new ...
  pia ...                             Alias of plan new --ai-auto ...
  cp ...                              Alias of commit-push (non-AI; no implicit --ai-auto)
  cpa ...                             Alias of commit-push --ai-auto (auto adds --plan-file)
                                      In agent mode (KANO_AGENT_MODE=1), cpa is treated as cp.
                                      Shortcut: if prepare-scope is 1 repo + 1 change and no -m/--plan-file/--repos,
                                      launcher auto-routes to `cp -m` for faster direct commit-push.
                                      Auto-prepares plan via AI when missing/placeholder
    --no-plan-auto                    Disable AI->plan auto routing
    --allow-ignore-gate               Bypass ignore gate for this run
    --llvm                            Use Homebrew LLVM clang/clang++ toolchain (macOS)
    --modules                         Enable C++20 modules (requires compatible toolchain)
    --no-modules                      Disable C++20 modules
  completion install bash             Install bash completion script
  completion-install bash             Alias of completion install bash

Launcher env:
  KANO_AGENT_MODE=1                Force non-interactive agent mode in launcher flows
  KANO_GIT_ALLOW_NONINTERACTIVE_DOWNGRADE_REBUILD=1
                                      Allow downgrade rebuild in non-interactive mode
  KOG_BUILD_USE_LLVM=0|1              Build with LLVM toolchain (macOS default: 1)
  KOG_BUILD_ENABLE_MODULES=0|1        Build with C++20 modules (macOS default: 1)
  KOG_PLAN_FILE=<path>                Default plan file used when AI flags are present
                                      AI mode enforces required plan fields before execution,
                                      including per-commit review (verdict=pass + reason)
  KOG_CPA_AUTO_PLAN_DEBUG=1           Enable --debug-ai during cpa auto plan prepare
  KOG_PA_AUTO_PLAN_DEBUG=1            Deprecated legacy alias (compat); use KOG_CPA_AUTO_PLAN_DEBUG
  KOG_CPA_DISABLE_SINGLE_CHANGE_SHORTCUT=1
                                      Disable cpa single-change shortcut auto-routing
  KOG_CPA_SHORTCUT_MESSAGE=<msg>      Override shortcut commit message used by auto-routed cp -m
  KOG_ALLOW_IGNORE_GATE=1             Bypass ignore gate (not recommended)
  KOG_DISABLE_SECRET_GATE=1           Disable secret gate (not recommended)
  KOG_IGNORE_GATE=off                 Disable ignore gate globally (not recommended)
                                      Static allowlist: assets/gitignore/ignore-gate-allowlist.txt
  KOG_SKIP_AUTO_REBUILD_WHEN_DIRTY=0|1
                                      Reserved (auto-rebuild disabled in manual mode)
  KOG_WSL_AUTO_UPDATE_CHECK=0|1       Reserved (auto-update disabled in manual mode)
EOF
}

run_native_binary() {
  local binary="$1"
  shift || true

  local first="${1:-}"
  local arg_count=$#
  local -a native_args=("$@")
  local i arg next_is_plan_path converted

  if ! ensure_binary_shell_compatibility "$binary"; then
    return 2
  fi

  if [[ ! -x "$binary" ]]; then
    chmod u+x "$binary" >/dev/null 2>&1 || true
  fi

  if [[ "$binary" == *.exe ]]; then
    next_is_plan_path=0
    for ((i = 0; i < ${#native_args[@]}; i++)); do
      arg="${native_args[$i]}"
      if [[ "$next_is_plan_path" -eq 1 ]]; then
        if converted="$(to_windows_path "$arg" 2>/dev/null)"; then
          native_args[$i]="$converted"
        fi
        next_is_plan_path=0
        continue
      fi
      case "$arg" in
        --plan-file)
          next_is_plan_path=1
          ;;
        --plan-file=*)
          if converted="$(to_windows_path "${arg#--plan-file=}" 2>/dev/null)"; then
            native_args[$i]="--plan-file=$converted"
          fi
          ;;
      esac
    done
  fi

  KANO_GIT_MASTER_ROOT="${KANO_GIT_MASTER_ROOT:-$PROJECT_ROOT}" KANO_GIT_BINARY_PATH="$binary" "$binary" "${native_args[@]}"
  local status=$?

  if [[ "$status" -eq 0 ]]; then
    case "$first" in
      ""|-h|--help|help)
        if [[ "$arg_count" -le 1 ]]; then
          print_launcher_help_extras
        fi
        ;;
    esac
  fi

  return "$status"
}

main() {
  local binary marker
  local -a args=()
  local -a exec_args=()
  local explicit_bin=""

  args=("$@")
  apply_launcher_env_overrides "${args[@]}"
  apply_agent_mode_from_args "${args[@]}"

  # Fail fast when user explicitly points to an incompatible binary for current shell.
  if [[ -n "${KANO_GIT_BIN:-}" ]]; then
    explicit_bin="$KANO_GIT_BIN"
  elif [[ -n "${KANO_GIT_BINARY_PATH:-}" ]]; then
    explicit_bin="$KANO_GIT_BINARY_PATH"
  fi
  if [[ -n "$explicit_bin" && -e "$explicit_bin" ]]; then
    if ! ensure_binary_shell_compatibility "$explicit_bin"; then
      exit 2
    fi
  fi

  case "${args[0]:-}" in
    build|rebuild)
      echo "Error: '${args[0]}' moved under 'self' lifecycle commands." >&2
      echo "Hint: use './kog self ${args[0]}' instead." >&2
      exit 2
      ;;
  esac

  if [[ "${args[0]:-}" == "self" ]]; then
    case "${args[1]:-}" in
      build|rebuild|update)
        maybe_handle_manual_self_request "${args[@]}"
        exit $?
        ;;
    esac
  fi

  local completion_status=0
  if maybe_handle_completion_install_request "${args[@]}"; then
    exit 0
  else
    completion_status=$?
  fi
  if [[ "$completion_status" -ne 1 ]]; then
    exit "$completion_status"
  fi

  exec_args=("${args[@]}")
  maybe_alias_cpa_for_agent_mode exec_args
  maybe_apply_cpa_single_change_shortcut exec_args
  maybe_run_plan_preflight_for_ai_command "${exec_args[@]}"
  local preflight_status=$?
  if [[ "$preflight_status" -ne 0 ]]; then
    exit "$preflight_status"
  fi

  # Manual mode: no auto-rebuild/auto-prepare in execution path.
  if binary="$(find_binary)"; then
    if [[ -n "$binary" && -f "$binary" ]]; then
      run_native_binary "$binary" "${exec_args[@]}"
      exit $?
    fi
  fi

  if is_lightweight_query_command "${exec_args[@]}"; then
    echo "Error: no compatible native binary found for current shell." >&2
    echo "Hint: do not mix WSL shell with Windows .exe binary. Use Linux build in WSL, or run Git Bash/Cygwin for Windows build." >&2
    echo "Hint: run './kog self build' in the current shell environment." >&2
    exit 1
  fi

  if is_packaged_install; then
    marker="$(install_marker_file)"
    echo "Error: kano-git packaged install marker detected, but C++ binary is missing." >&2
    echo "Error: marker file: $marker" >&2
    echo "Error: this installation may be corrupted. Please reinstall the package." >&2
  else
    :
  fi

  echo "Error: strict native-only mode is enabled and C++ binary is unavailable." >&2
  echo "Error: shell fallback is disabled by design; auto build/update are disabled in manual mode." >&2
  echo "Hint: run './kog self build' (or './kog self rebuild') in this shell, then retry." >&2
  exit 1
}

main "$@"
