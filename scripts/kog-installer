#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: kog-installer <install|uninstall> [options]

Manage launcher-owned Git Bash completion/profile hooks:
  - install: create/update bash completion file and add a launcher-owned source hook
  - uninstall: remove that completion file and source hook

This command does not modify PATH.
For packaged MSI installs, optional ShellIntegration owns PATH only.
For manual repo use, invoke `./scripts/kog` directly or add the scripts directory to PATH yourself.

Options:
  --dry-run             Show changes without writing
  -h, --help            Show this help
EOF
}

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ACTION="install"
DRY_RUN=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    install|uninstall)
      ACTION="$1"
      shift
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

if [[ "$DRY_RUN" -eq 1 ]]; then
  if [[ "$ACTION" == "install" ]]; then
    echo "[dry-run] Would run: kano-git completion install bash"
  else
    echo "[dry-run] Would run: kano-git completion uninstall bash"
  fi
  exit 0
fi

exec "$SCRIPT_DIR/kano-git" completion "$ACTION" bash
