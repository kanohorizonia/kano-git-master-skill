# Enforce LF for shell scripts and source code
*.sh text eol=lf
*.bash text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.md text eol=lf
*.toml text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.exe binary
*.dll binary
