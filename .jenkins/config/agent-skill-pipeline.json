{
  "projectName": "kano-git-master-skill",
  "skillName": "kano-git-master-skill",
  "bootstrapAgentLabel": "lightweight",
  "windowsAgentLabel": "windows && lightweight",
  "linuxAgentLabel": "linux && lightweight",
  "macAgentLabel": "mac && lightweight",
  "bRunReleasePhase": false,
  "bRunTests": true,
  "buildTasks": ["build"],
  "testTasks": ["quick-test"],
  "reportTasks": ["test-report", "coverage-report", "gather-reports"],
  "requiredPixiTasks": ["build", "quick-test"],
  "reportRoot": "out/reports",
  "coverageRoot": "out/coverage",
  "distRoot": "dist",
  "jenkinsRoot": "out/jenkins",
  "upstreamBuildJob": "KanoAgentSkills/kano-git-master-skill/Build/Release",
  "githubRepository": "kanohorizonia/kano-git-master-skill",
  "githubTokenCredentialId": "github-release-token",
  "siteBuildCommand": "pixi run docs-ci",
  "bBuildSite": true,
  "bPublishSite": false,
  "bCreateGitHubRelease": true,
  "bRequireExplicitReleaseTag": true,
  "releaseApprovalMessage": "Approve kano-git-master-skill Release/Publish? Confirm tag, artifacts, docs, and release plan before proceeding.",
  "branchPolicy": {
    "parameterName": "BUILD_BRANCH",
    "defaultBranch": "main",
    "mode": "git-parameter",
    "type": "PT_BRANCH",
    "branchFilter": "origin/(main|develop|feature/.+|users/.+|personal/.+|release/.+)",
    "useRepository": ".*kano-git-master-skill.*",
    "selectedValue": "DEFAULT",
    "sortMode": "DESCENDING_SMART",
    "quickFilterEnabled": true,
    "listSize": "20",
    "allowedRegex": "^(main|develop|feature/.+|users/.+|personal/.+|release/.+)$"
  }
}
