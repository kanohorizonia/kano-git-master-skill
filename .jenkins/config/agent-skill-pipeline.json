{
  "projectName": "kano-git-master-skill",
  "skillName": "kano-git-master-skill",
  "bootstrapAgentLabel": "lightweight",
  "windowsAgentLabel": "windows && lightweight",
  "linuxAgentLabel": "lightweight && (linux || docker) && !jenkins-controller && !built-in",
  "macAgentLabel": "mac && lightweight",
  "platformSharedWorkspaceRoots": {
    "windows": "C:/Mount/s/jenkins_ws/KanoAgentSkills",
    "linux": "/Users/Shared/jenkins_ws/KanoAgentSkills",
    "mac": "/Users/Shared/jenkins_ws/KanoAgentSkills"
  },
  "bRunReleasePhase": false,
  "bRunTests": true,
  "buildTasks": ["build"],
  "testTasks": ["quick-test"],
  "reportTasks": ["test-report", "coverage-all", "gather-reports"],
  "linuxBuildTasks": ["ci-linux-build"],
  "linuxTestTasks": ["ci-linux-quick-test"],
  "linuxReportTasks": ["ci-linux-test-report", "ci-linux-coverage-all", "gather-reports"],
  "linuxValidateCommand": "pixi run ci-linux-validate",
  "requiredPixiTasks": [
    "build",
    "quick-test",
    "test-report",
    "coverage-all",
    "gather-reports",
    "ci-linux-build",
    "ci-linux-quick-test",
    "ci-linux-test-report",
    "ci-linux-coverage-all",
    "ci-linux-validate",
    "ci-linux-export"
  ],
  "reportRoot": "out/reports",
  "coverageRoot": "out/coverage",
  "distRoot": "dist",
  "jenkinsRoot": "out/jenkins",
  "buildJobName": "Build_CI",
  "releaseJobName": "Release_Publish",
  "upstreamBuildJob": "KanoAgentSkills/kano-git-master-skill/Build_CI",
  "gitUrl": "https://github.com/kanohorizonia/kano-git-master-skill.git",
  "gitCredentialsId": "github-kanohorizonia-jenkins",
  "gitBranch": "__BUILD_BRANCH__",
  "bRunWindowsBuild": true,
  "bRunLinuxBuild": true,
  "bRunMacBuild": true,
  "linuxPackageExtension": "tar.gz",
  "macPackageExtension": "tar.gz",
  "platformPackageExportManifestFiles": "export-manifest.json, .kano/tmp/export-manifest.json, .kano/tmp/*.export-manifest.json, .kano/tmp/git/export/*.export-manifest.json, artifacts/export-manifest.json, artifacts/**/*.export-manifest.json, Release/export-manifest.json, Release/**/*.export-manifest.json",
  "linuxExportCommand": "pixi run ci-linux-export",
  "bBuildInstallers": true,
  "windowsInstallerCommand": "bash -lc \"src/wix/scripts/build.sh && mkdir -p artifacts/installers/windows && cp -f src/wix/out/*.msi artifacts/installers/windows/\"",
  "bGeneratePackageManagerRecipes": true,
  "bGenerateWingetRecipe": true,
  "wingetPackageId": "Kanohorizonia.KanoGitMasterSkill",
  "wingetGenerateCommand": "bash src/shell/release/02-generate-winget-skeleton.sh",
  "bGenerateHomebrewFormula": true,
  "homebrewFormulaName": "kano-git-master-skill",
  "homebrewGenerateCommand": "bash src/shell/release/03-generate-homebrew-skeleton.sh",
  "bPublishPackageManagerRecipes": true,
  "bPublishWingetRecipe": true,
  "wingetPublishCommand": "bash src/shell/release/04-publish-winget-internal.sh",
  "wingetManifestRepoUrl": "",
  "wingetManifestRepoCredentialId": "",
  "wingetManifestRepoBranch": "main",
  "bPublishHomebrewFormula": true,
  "homebrewPublishCommand": "bash src/shell/release/05-publish-homebrew-internal.sh",
  "homebrewTapRepoUrl": "",
  "homebrewTapCredentialId": "",
  "homebrewTapRepoBranch": "main",
  "releaseAssetBaseUrl": "",
  "githubRepository": "kanohorizonia/kano-git-master-skill",
  "githubTokenCredentialId": "github-release-token",
  "siteBuildCommand": "pixi run docs-ci",
  "bBuildSite": true,
  "bPublishSite": false,
  "bCreateGitHubRelease": true,
  "bRequireExplicitReleaseTag": true,
  "releaseApprovalMessage": "Approve kano-git-master-skill Release/Publish? Confirm tag, artifacts, docs, and release plan before proceeding.",
  "branchPolicy": {
    "parameterName": "BUILD_BRANCH",
    "defaultBranch": "main",
    "mode": "git-parameter",
    "type": "PT_BRANCH",
    "branchFilter": "origin/(main|develop|feature/.+|users/.+|personal/.+|release/.+)",
    "useRepository": ".*kano-git-master-skill.*",
    "selectedValue": "DEFAULT",
    "sortMode": "DESCENDING_SMART",
    "quickFilterEnabled": true,
    "listSize": "20",
    "allowedRegex": "^(main|develop|feature/.+|users/.+|personal/.+|release/.+)$"
  }
}
