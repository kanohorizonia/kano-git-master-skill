{
  "projectName": "kano-git-master-skill",
  "bootstrapAgentLabel": "lightweight",
  "windowsAgentLabel": "windows && lightweight",
  "linuxAgentLabel": "linux && lightweight",
  "macAgentLabel": "mac && lightweight",
  "githubRepository": "kanohorizonia/kano-git-master-skill",
  "githubTokenCredentialId": "github-release-token",
  "bRunTests": true,
  "bRunCoverage": true,
  "bPublishJunitReports": true,
  "bPublishCoverageReports": true,
  "bPublishArtifactLinksPage": true,
  "bBuildSite": true,
  "siteBuildCommand": "pixi run docs-ci",
  "releaseApprovalMessage": "Approve kano-git-master-skill Release/Publish? Confirm tag, artifacts, docs, and release plan before proceeding.",
  "windowsBuildCommand": "scripts\\kog.bat self build",
  "windowsTestCommand": "pixi run --manifest-path src/cpp/shared/infra/pixi.toml test && pixi run --manifest-path src/cpp/shared/infra/pixi.toml test-report",
  "windowsCoverageCommand": "pixi run --manifest-path src/cpp/shared/infra/pixi.toml coverage-all",
  "windowsValidateCommand": "bash -lc \"src/shell/test/pre-commit-quality-gate.sh\"",
  "windowsExportCommand": "bash -lc \"./scripts/kog export --single --validate-release-archive\"",
  "linuxBuildCommand": "./scripts/kog self build",
  "linuxTestCommand": "pixi run --manifest-path src/cpp/shared/infra/pixi.toml test && pixi run --manifest-path src/cpp/shared/infra/pixi.toml test-report",
  "linuxCoverageCommand": "pixi run --manifest-path src/cpp/shared/infra/pixi.toml coverage-all",
  "linuxValidateCommand": "src/shell/test/pre-commit-quality-gate.sh",
  "linuxExportCommand": "./scripts/kog export --single --validate-release-archive",
  "macBuildCommand": "./scripts/kog self build",
  "macTestCommand": "pixi run --manifest-path src/cpp/shared/infra/pixi.toml test && pixi run --manifest-path src/cpp/shared/infra/pixi.toml test-report",
  "macCoverageCommand": "pixi run --manifest-path src/cpp/shared/infra/pixi.toml coverage-all",
  "macValidateCommand": "src/shell/test/pre-commit-quality-gate.sh",
  "macExportCommand": "./scripts/kog export --single --validate-release-archive",
  "buildJobName": "Build_Shipping",
  "releaseJobName": "Release_Publish",
  "upstreamBuildJob": "KanoAgentSkills/kano-git-master-skill/Build_Shipping"
}
